PKGNAME=fex
PKGSEC=utils
PKGDEP="gcc-runtime glibc qt-6 xxhash curl \
        squashfuse squashfs-tools erofs-utils"
# Note:
# FEXRootFSFetcher can fall back to TTY when zenity is not available.
PKGRECOM="zenity"
BUILDDEP="llvm"
PKGDES="Usermode x86 and x86-64 emulator for ARM64"

USECLANG=1

ABTYPE=cmakeninja
CMAKE_AFTER=(
    '-DBUILD_TESTING=OFF'
    '-DENABLE_GDB_SYMBOLS=OFF'
    '-DTUNE_ARCH=armv8-a'
    '-DTUNE_CPU=none'
)

FAIL_ARCH="!(arm64)"
