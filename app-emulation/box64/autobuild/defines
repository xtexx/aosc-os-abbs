PKGNAME=box64
PKGSEC=utils
PKGDEP="gcc-runtime glibc ncurses"
PKGDES="Userspace emulator for running x86-64 applications on non-x86 systems"
ABTYPE="cmakeninja"

# Note: -DCI=ON, regenerates function wrappers, which is unnecessary for packaging?
CMAKE_AFTER=(
    "-DCI=ON"
    "-DBOX32=ON"
    "-DBOX32_BINFMT=ON"
)

CMAKE_AFTER__ARM64=(
    "${CMAKE_AFTER[@]}"
    "-DARM64=ON"
    "-DARM_DYNAREC=ON"
)

CMAKE_AFTER__LOONGARCH64=(
    "${CMAKE_AFTER[@]}"
    "-DLARCH64=ON"
    "-DLARCH64_DYNAREC=ON"
)

CMAKE_AFTER__PPC64EL=(
    "${CMAKE_AFTER[@]}"
    "-DPPC64LE=ON"
    "-DPPC64LE_DYNAREC=ON"
)

CMAKE_AFTER__RISCV64=(
    "${CMAKE_AFTER[@]}"
    "-DRV64=ON"
    "-DRV64_DYNAREC=ON"
)

CMAKE_AFTER__LOONGARCH64_NOSIMD=(
    "${CMAKE_AFTER__LOONGARCH64[@]}"
)

FAIL_ARCH="!(arm64|loongarch64|ppc64el|riscv64|loongarch64_nosimd)"
