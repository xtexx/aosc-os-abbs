abinfo "Creating build directories ..."
mkdir -pv "$SRCDIR"/build{32,64}

# Note: All build configurations taken from /latxbuild/build-release-nw.sh
#
# Note: -O1, -O2, etc. in configure parameters do not correspond to
# compiler optimisation levels but were rather internally defined levels.
#
#     --optimize-O0           Close all optimization
#     --optimize-O1           Open stable optimization
#     --optimize-O2           Open unstable optimization
#     --optimize-O3           Open testing optimization
#
# FIXME: x86 (i386) target built as static as expected at present.

abinfo "Building LATX (x86_64) ..."
cd "$SRCDIR"/build64
"$SRCDIR"/configure \
    ${AUTOTOOLS_DEF[@]} \
    --target-list=x86_64-linux-user \
    --enable-latx \
    --disable-debug-info \
    --optimize-O1 \
    --extra-ldflags=-ldl \
    --enable-kzt \
    --disable-blobs \
    --disable-docs \
    --enable-new-world \
    --disable-werror \
    --disable-linux-io-uring
make
make install \
    DESTDIR="$PKGDIR"

abinfo "Buildijng LATX (x86) ..."
cd "$SRCDIR"/build32
"$SRCDIR"/configure \
    ${AUTOTOOLS_DEF[@]} \
    --target-list=i386-linux-user \
    --enable-latx \
    --enable-guest-base-zero \
    --disable-debug-info \
    --optimize-O1 \
    --extra-ldflags=-ldl \
    --disable-blobs \
    --disable-docs \
    --enable-new-world \
    --disable-werror \
    --disable-pie \
    --static \
    --disable-linux-io-uring
make
make install \
    DESTDIR="$PKGDIR"

abinfo "Installing documentation ..."
install -Dvm644 "$SRCDIR"/README* \
    -t "$PKGDIR"/usr/share/doc/latx/
