From ecdf9b2a6aab637eae4ff7a010ba50860b93b1f9 Mon Sep 17 00:00:00 2001
From: Simon Quigley <tsimonq2@debian.org>
Date: Fri, 28 Feb 2025 00:00:00 +0000
Subject: [PATCH 2/4] DEBIAN: Fix FTBFS with GCC 14 due to an incompatible
 pointer type

When initializing macro->actions[n], instead of initializing it as a char,
initialize it with the proper type.

This patch has also been tested with nascent releases of GCC 15.

Link: https://bugs.debian.org/cgi-bin/bugreport.cgi?bug=1075572
Signed-off-by: Mingcong Bai <jeffbai@aosc.io>
---
 gui/macro.c | 2 +-
 1 file changed, 1 insertion(+), 1 deletion(-)

diff --git a/gui/macro.c b/gui/macro.c
index ae8db8b..dfe2e4e 100644
--- a/gui/macro.c
+++ b/gui/macro.c
@@ -86,7 +86,7 @@ void tilem_macro_add_action(TilemMacro* macro, int type, char * value) {
 	macro->actions = tilem_macro_actions_new(macro, n + 1);
 
 	/* Then we need to save the action */	
-	macro->actions[n] =  g_new(char, strlen(value)); /* FIXME : gcc says : "assignment from incompatible pointer type" ??? */
+	macro->actions[n] = g_new(TilemMacroAtom, 1);
 	macro->actions[n]->value = g_strdup(value);
 	macro->actions[n]->type = type;
 	macro->n++;
-- 
2.52.0

