PKGNAME=pcsclite
PKGSEC=libs
PKGDES="PC/SC Architecture smartcard middleware library"
PKGDEP="polkit systemd"
PKGDEP__RETRO="systemd"

ABTYPE=meson
MESON_AFTER=(
	'-Dlibudev=true'
	'-Dlibusb=false'
	'-Dlibsystemd=true'
	'-Dsystemdunit=system'
	'-Dpolkit=true'
)
MESON_AFTER__RETRO=(
	"${MESON_AFTER[@]}"
	'-Dpolkit=false'
)
