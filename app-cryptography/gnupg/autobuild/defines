PKGNAME=gnupg
PKGSEC=libs
PKGDES="Complete and free implementation of the OpenGPG standard"

PKGDEP="openldap libusb bzip2 libksba libgcrypt \
        libassuan readline npth zlib libgpg-error gnutls sqlite"
PKGDEP__RETRO="bzip2 libgpg-error libgcrypt libassuan libksba \
         npth readline"
# gnupg has no library dependency on pinentry, but relies on it to enter passphrase
PKGSUG="pinentry"
BUILDDEP="transfig"

# Do NOT let gnupg try to regenerate version string from git
RECONF=0

AUTOTOOLS_AFTER=(
    '--enable-gpgsm'
    '--enable-scdaemon'
    '--enable-g13'
    '--enable-dirmngr'
    '--enable-keyboxd'
    '--enable-tpm2d'
    '--enable-doc'
    '--enable-gpgtar'
    '--enable-wks-tools'
    '--disable-selinux-support'
    '--enable-large-secmem'
    '--enable-trust-models'
    '--enable-tofu'
    '--enable-libdns'
    '--enable-gpg-rsa'
    '--enable-gpg-ecdh'
    '--enable-gpg-ecdsa'
    '--enable-gpg-eddsa'
    '--enable-gpg-idea'
    '--enable-gpg-cast5'
    '--enable-gpg-blowfish'
    '--enable-gpg-aes128'
    '--enable-gpg-aes192'
    '--enable-gpg-aes256'
    '--enable-gpg-twofish'
    '--enable-gpg-camellia128'
    '--enable-gpg-camellia192'
    '--enable-gpg-camellia256'
    '--enable-gpg-md5'
    '--enable-gpg-rmd160'
    '--enable-gpg-sha224'
    '--enable-gpg-sha384'
    '--enable-gpg-sha512'
    '--enable-zip'
    '--enable-bzip2'
    '--enable-exec'
    '--enable-photo-viewers'
    '--enable-key-cache=4096'
    '--enable-card-support'
    '--enable-ccid-driver'
    '--enable-dirmngr-auto-start'
    '--disable-maintainer-mode'
    '--enable-largefile'
    '--enable-sqlite'
    '--disable-npth-debug'
    '--disable-ntbtls'
    '--enable-gnutls'
    '--enable-ldap'
    '--disable-rpath'
    '--enable-nls'
    '--enable-endian-check'
    '--enable-optimization'
    '--enable-log-clock'
    '--disable-werror'
    '--disable-all-tests'
    '--disable-tests'
    '--enable-run-gnupg-user-socket'
    '--enable-build-timestamp'
    '--with-capabilities'
)

AUTOTOOLS_AFTER__RETRO=(
    "${AUTOTOOLS_AFTER[@]}"
    '--disable-g13'
    '--disable-wks-tools'
    '--disable-scdaemon'
    '--disable-dirmngr'
    '--disable-libdns'
    '--disable-photo-viewers'
    '--disable-card-support'
    '--disable-ccid-driver'
    '--disable-dirmngr-auto-start'
    '--disable-ldap'
)

PKGREP="gnupg+1 dirmngr"
PKGPROV="gnupg+1 dirmngr"
PKGCONFL="gnupg+1 dirmngr"
PKGEPOCH=2

# Note: Extra Provides for Spiral (Debian compatibility).
PKGPROV="${PKGPROV} gnupg2_spiral"
