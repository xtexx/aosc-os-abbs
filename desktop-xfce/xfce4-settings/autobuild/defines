PKGNAME=xfce4-settings
PKGSEC=xfce
PKGDEP="exo libxfce4ui garcon libnotify libxklavier gtk-engines-2 \
        gtk-layer-shell libcanberra sound-theme-freedesktop \
        xf86-input-libinput xiccd"
BUILDDEP="intltool"
PKGDES="Xfce settings manager"

