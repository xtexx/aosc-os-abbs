abinfo "Patching to find the correct Clang path ..."
# Note: Patch to find the correct Clang path (for v8).
# https://github.com/denoland/rusty_v8/issues/1587
pushd "$SRCDIR"/../rusty_v8/build
ab_apply_patches "$SRCDIR"/autobuild/patches/*.v8
popd

abinfo "Setting up build environment ..."
# FIXME: Deno's build system does not set these automatically.
export AR="/usr/bin/ar"
export NM="/usr/bin/nm"

# Use system gn and ninja (for v8).
export GN="/usr/bin/gn"
export NINJA="/usr/bin/ninja"

# Note: Build V8 from source as the upstream does not provide enough
# binaries for the architectures we support.
CLANG_VERSION=$(clang --version | sed -n 's/clang version //p' | cut -d. -f1)

export V8_FROM_SOURCE=1
export GN_ARGS="
    no_inline_line_tables=false
    v8_enable_pointer_compression=true
    treat_warnings_as_errors=false
    clang_base_path=\"/usr/lib/llvm-${CLANG_VERSION}\"
    clang_version=\"${CLANG_VERSION}\"
    custom_toolchain=\"//build/toolchain/linux/unbundle:default\"
    host_toolchain=\"//build/toolchain/linux/unbundle:default\"
"
