abinfo "Installing completions ..."
mkdir -pv "$PKGDIR"/usr/share/bash-completion/completions
"$PKGDIR"/usr/bin/deno completions bash \
    > "$PKGDIR"/usr/share/bash-completion/completions/deno
mkdir -pv "$PKGDIR"/usr/share/zsh/site-functions
"$PKGDIR"/usr/bin/deno completions zsh \
    > "$PKGDIR"/usr/share/zsh/site-functions/_deno
mkdir -pv "$PKGDIR"/usr/share/fish/vendor_completions.d
"$PKGDIR"/usr/bin/deno completions fish \
    > "$PKGDIR"/usr/share/fish/vendor_completions.d/deno.fish
