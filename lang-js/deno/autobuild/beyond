abinfo "Installing completions ..."
"$PKGDIR"/usr/bin/deno completions bash | install -Dvm644 /dev/stdin \
    "$PKGDIR"/usr/share/bash-completion/completions/deno
"$PKGDIR"/usr/bin/deno completions zsh | install -Dvm644 /dev/stdin \
    "$PKGDIR"/usr/share/zsh/site-functions/_deno
"$PKGDIR"/usr/bin/deno completions fish | install -Dvm644 /dev/stdin \
    "$PKGDIR"/usr/share/fish/vendor_completions.d/deno.fish
