From: CAB233 <yidaduizuoye@outlook.com>
Date: Wed, 4 Mar 2026 20:16:58 +0800
Subject: [PATCH 1/3] AOSCOS: use local patched rusty_v8

---
 Cargo.lock | 2 --
 Cargo.toml | 3 +++
 2 files changed, 3 insertions(+), 2 deletions(-)

diff --git a/Cargo.lock b/Cargo.lock
index e28296cac..df2c0f724 100644
--- a/Cargo.lock
+++ b/Cargo.lock
@@ -10895,8 +10895,6 @@ dependencies = [
 [[package]]
 name = "v8"
 version = "146.1.0"
-source = "registry+https://github.com/rust-lang/crates.io-index"
-checksum = "70bb6bcbb6a406fd720dad66d85337bd401d8276c7276f6a86164af6e1c57118"
 dependencies = [
  "bindgen 0.72.1",
  "bitflags 2.9.3",
diff --git a/Cargo.toml b/Cargo.toml
index b8ab59aaf..fa8ec89bc 100644
--- a/Cargo.toml
+++ b/Cargo.toml
@@ -598,3 +598,6 @@ opt-level = 3
 opt-level = 3
 [profile.release.package.twox-hash]
 opt-level = 3
+
+[patch.crates-io]
+v8 = { path = '../rusty_v8' }
