From b03d6882a77267ff0fbebd7eb9f88714f28ee1fb Mon Sep 17 00:00:00 2001
From: =?UTF-8?q?Sl=C3=A1vek=20Banko?= <slavek.banko@axis.cz>
Date: Tue, 16 Dec 2025 10:25:06 +0100
Subject: [PATCH 2/2] Fix FTBFS with ffmeg 8.0.
MIME-Version: 1.0
Content-Type: text/plain; charset=UTF-8
Content-Transfer-Encoding: 8bit

Signed-off-by: Slávek Banko <slavek.banko@axis.cz>
---
 akode/plugins/ffmpeg_decoder/ffmpeg_decoder.cpp | 2 +-
 1 file changed, 1 insertion(+), 1 deletion(-)

diff --git a/akode/plugins/ffmpeg_decoder/ffmpeg_decoder.cpp b/akode/plugins/ffmpeg_decoder/ffmpeg_decoder.cpp
index f4ec7c3..78b9946 100644
--- a/akode/plugins/ffmpeg_decoder/ffmpeg_decoder.cpp
+++ b/akode/plugins/ffmpeg_decoder/ffmpeg_decoder.cpp
@@ -282,10 +282,10 @@ void FFMPEGDecoder::closeFile() {
     }
 
     if( d->codec ) {
-        avcodec_close( d->audioStream_ctx );
 #if LIBAVFORMAT_VERSION_INT >= AV_VERSION_INT(57, 33, 100)
         avcodec_free_context(&d->audioStream_ctx);
 #else
+        avcodec_close( d->audioStream_ctx );
         d->audioStream_ctx = NULL;
 #endif
         d->codec = 0;
