abinfo "Building binaries ..."
make "EXTRA_LDFLAGS=-compressdwarf=false -linkmode=external" PREFIX=/usr

abinfo "Installing binaries ..."
make PODMAN_VERSION="$PKGVER" DESTDIR="$PKGDIR" PREFIX="/usr" ETCDIR="$PKGDIR/etc/" \
     install.bin \
     install.man \
     install.systemd \
     install.completions \
     install.remote
