abinfo "Installing kubo shell completions..."
"$PKGDIR"/usr/bin/ipfs commands completion bash |
    install -Dvm644 /dev/stdin \
    "$PKGDIR"/usr/share/bash-completion/completions/ipfs
"$PKGDIR"/usr/bin/ipfs commands completion zsh |
    install -Dvm644 /dev/stdin \
    "$PKGDIR"/usr/share/zsh/site-functions/_ipfs
"$PKGDIR"/usr/bin/ipfs commands completion fish |
    install -Dvm644 /dev/stdin \
    "$PKGDIR"/usr/share/fish/vendor_completions.d/ipfs.fish
