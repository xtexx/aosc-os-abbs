abinfo "Fetching FlClashCore submodule"
git submodule sync "$SRCDIR"/core/Clash.Meta
git submodule update --init "$SRCDIR"/core/Clash.Meta

abinfo "Disabling CGO ..."
export CGO_ENABLED=0

abinfo "Mapping Flutter architecture ..."
if ab_match_arch amd64; then
    export FLUTTER_ARCH="x64" 
elif ab_match_arch arm64; then
    export FLUTTER_ARCH="arm64"
fi

abinfo "Setting up flutter ..."
fvm install 3.35.4
fvm global 3.35.4
fvm flutter --disable-analytics
