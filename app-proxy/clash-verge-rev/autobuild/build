abinfo "Fetching dependencies and assets ..."
# FIXME: override in package.json conflicts with --frozen-lockfile
pnpm install # --frozen-lockfile

abinfo "Building Clash Verge ..."
pnpm run prebuild
cargo tauri build

abinfo "Installing Clash Verge ..."
install -Dvm755 "$SRCDIR"/src-tauri/target/release/clash-verge \
    "$PKGDIR"/usr/bin/clash-verge

abinfo "Installing icon ..."
install -Dvm644 "$SRCDIR"/src-tauri/icons/icon.png \
    "$PKGDIR"/usr/share/pixmaps/clash-verge.png

abinfo "Installing resources ..."
install -Dvm644 "$SRCDIR"/src-tauri/resources/locales/* \
	-t "$PKGDIR"/usr/lib/'Clash Verge'/resources/locales/

abinfo "Installing symlink for mihomo-rules-dat ..."
ln -sv /usr/share/mihomo-rules-dat/country.mmdb \
	"$PKGDIR"/usr/lib/'Clash Verge'/resources/Country.mmdb
ln -sv /usr/share/mihomo-rules-dat/geoip.dat \
	"$PKGDIR"/usr/lib/'Clash Verge'/resources/geoip.dat
ln -sv /usr/share/mihomo-rules-dat/geosite.dat \
	"$PKGDIR"/usr/lib/'Clash Verge'/resources/geosite.dat
