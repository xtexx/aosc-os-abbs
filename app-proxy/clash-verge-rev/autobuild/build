abinfo "Fetching dependencies and assets ..."
pnpm approve-builds --all
if ab_match_arch amd64 ; then
	export ARCH_STR=x64
elif ab_match_arch arm64 ; then
	export ARCH_STR=arm64
elif ab_match_arch loongarch64 || ab_match_arch loongarch64_nosimd ; then
	export ARCH_STR=loong64
elif ab_match_arch loongson3 ; then
	export ARCH_STR=mips64el
elif ab_match_arch riscv64 ; then
	export ARCH_STR=riscv64
elif ab_match_arch ppc64el ; then
	export ARCH_STR=ppc64
fi
pnpm i @esbuild/linux-"$ARCH_STR"
pnpm install
pnpm run prebuild

abinfo "Building Clash Verge ..."
cargo tauri build

abinfo "Installing Clash Verge ..."
install -Dvm755 "$SRCDIR"/target/release/clash-verge \
    "$PKGDIR"/usr/bin/clash-verge

abinfo "Installing icon ..."
install -Dvm644 "$SRCDIR"/src-tauri/icons/icon.png \
    "$PKGDIR"/usr/share/pixmaps/clash-verge.png

abinfo "Installing resources ..."
mkdir -pv "$PKGDIR"/usr/lib/'Clash Verge'/resources/locales/
cp -rvp "$SRCDIR"/src/locales/* "$PKGDIR"/usr/lib/'Clash Verge'/resources/locales/
chmod -R 644 "$PKGDIR"/usr/lib/'Clash Verge'/resources/locales/

abinfo "Installing symlink for mihomo-rules-dat ..."
ln -sv /usr/share/mihomo-rules-dat/country.mmdb \
	"$PKGDIR"/usr/lib/'Clash Verge'/resources/Country.mmdb
ln -sv /usr/share/mihomo-rules-dat/geoip.dat \
	"$PKGDIR"/usr/lib/'Clash Verge'/resources/geoip.dat
ln -sv /usr/share/mihomo-rules-dat/geosite.dat \
	"$PKGDIR"/usr/lib/'Clash Verge'/resources/geosite.dat
