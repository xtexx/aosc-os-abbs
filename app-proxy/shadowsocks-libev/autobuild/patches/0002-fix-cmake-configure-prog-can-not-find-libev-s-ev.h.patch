From 8d466c7fa339ef50d799863c2eee22a5ddd76ec7 Mon Sep 17 00:00:00 2001
From: "Lain \"Fearyncess\" Yang" <fsf@live.com>
Date: Sat, 2 May 2026 23:40:27 +0800
Subject: [PATCH 2/2] fix cmake configure prog can not find libev's ev.h

---
 cmake/configure.cmake | 2 +-
 src/cache.h           | 2 +-
 src/local.h           | 2 +-
 src/manager.h         | 2 +-
 src/redir.h           | 2 +-
 src/resolv.c          | 2 +-
 src/server.h          | 2 +-
 src/tunnel.h          | 2 +-
 src/udprelay.h        | 2 +-
 9 files changed, 9 insertions(+), 9 deletions(-)

diff --git a/cmake/configure.cmake b/cmake/configure.cmake
index 2c2d915..7c4c6cf 100644
--- a/cmake/configure.cmake
+++ b/cmake/configure.cmake
@@ -26,7 +26,7 @@ if (CMAKE_SYSTEM_NAME STREQUAL Darwin)
 endif ()
 
 check_include_files(dlfcn.h HAVE_DLFCN_H)
-check_include_files(ev.h HAVE_EV_H)
+check_include_files(libev/ev.h HAVE_EV_H)
 check_include_files(fcntl.h HAVE_FCNTL_H)
 check_function_exists(fork HAVE_FORK)
 check_function_exists(getpwnam_r HAVE_GETPWNAM_R)
diff --git a/src/cache.h b/src/cache.h
index 7ca8b3b..7972b38 100644
--- a/src/cache.h
+++ b/src/cache.h
@@ -33,7 +33,7 @@
 #ifdef HAVE_LIBEV_EV_H
 #include <libev/ev.h>
 #else
-#include <ev.h>
+#include <libev/ev.h>
 #endif
 
 /**
diff --git a/src/local.h b/src/local.h
index 96ee92a..39a73c2 100644
--- a/src/local.h
+++ b/src/local.h
@@ -28,7 +28,7 @@
 #ifdef HAVE_LIBEV_EV_H
 #include <libev/ev.h>
 #else
-#include <ev.h>
+#include <libev/ev.h>
 #endif
 
 #ifdef __MINGW32__
diff --git a/src/manager.h b/src/manager.h
index d5aa832..f8fef1c 100644
--- a/src/manager.h
+++ b/src/manager.h
@@ -29,7 +29,7 @@
 #ifdef HAVE_LIBEV_EV_H
 #include <libev/ev.h>
 #else
-#include <ev.h>
+#include <libev/ev.h>
 #endif
 
 #include "jconf.h"
diff --git a/src/redir.h b/src/redir.h
index 2544d65..517fdbb 100644
--- a/src/redir.h
+++ b/src/redir.h
@@ -25,7 +25,7 @@
 #ifdef HAVE_LIBEV_EV_H
 #include <libev/ev.h>
 #else
-#include <ev.h>
+#include <libev/ev.h>
 #endif
 
 #include "crypto.h"
diff --git a/src/resolv.c b/src/resolv.c
index 8d203fd..63f5a8d 100644
--- a/src/resolv.c
+++ b/src/resolv.c
@@ -46,7 +46,7 @@
 #ifdef HAVE_LIBEV_EV_H
 #include <libev/ev.h>
 #else
-#include <ev.h>
+#include <libev/ev.h>
 #endif
 
 #include <libcork/core.h>
diff --git a/src/server.h b/src/server.h
index cdff2c1..2bcf07e 100644
--- a/src/server.h
+++ b/src/server.h
@@ -29,7 +29,7 @@
 #ifdef HAVE_LIBEV_EV_H
 #include <libev/ev.h>
 #else
-#include <ev.h>
+#include <libev/ev.h>
 #endif
 
 #ifdef __MINGW32__
diff --git a/src/tunnel.h b/src/tunnel.h
index 4e9fbf8..d49100e 100644
--- a/src/tunnel.h
+++ b/src/tunnel.h
@@ -26,7 +26,7 @@
 #ifdef HAVE_LIBEV_EV_H
 #include <libev/ev.h>
 #else
-#include <ev.h>
+#include <libev/ev.h>
 #endif
 
 #ifdef __MINGW32__
diff --git a/src/udprelay.h b/src/udprelay.h
index 7242491..8d864d9 100644
--- a/src/udprelay.h
+++ b/src/udprelay.h
@@ -28,7 +28,7 @@
 #ifdef HAVE_LIBEV_EV_H
 #include <libev/ev.h>
 #else
-#include <ev.h>
+#include <libev/ev.h>
 #endif
 
 #include "crypto.h"
