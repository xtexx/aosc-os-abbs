From 05203718d4b725dbb968c8f023c91958167a3e52 Mon Sep 17 00:00:00 2001
From: xtex <xtexchooser@duck.com>
Date: Sat, 17 May 2025 17:14:43 +0800
Subject: [PATCH] AOSCOS: Disable multithreaded cythonize

On Python 3.14 with a default start method of forkserver,
this line leads to https://github.com/cython/cython/issues/3262
and an infinite-loop.
---
 setup.py | 2 +-
 1 file changed, 1 insertion(+), 1 deletion(-)

diff --git a/setup.py b/setup.py
index e339b9c6673f..8f1a7a3ceed9 100644
--- a/setup.py
+++ b/setup.py
@@ -18,7 +18,7 @@ try:
             os.path.join(p, "ext", "__init__.py"),
         ],
         # https://github.com/cython/cython/issues/3262
-        nthreads=0 if multiprocessing.get_start_method() == "spawn" else 2,
+        nthreads=0,
         compiler_directives={"language_level": 3},
         quiet=True,
     )

base-commit: 0c9891f66a40dcfc90f8e9576401673e84bcd829
