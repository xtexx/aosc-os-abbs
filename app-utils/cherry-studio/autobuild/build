abinfo "Installing NPM dependencies ..."
yarn install

abinfo "Building cherry-studio ..."
npx electron-vite build
npx electron-builder --dir --linux

abinfo "Installing cherry-studio ..."
install -dvm755 "$PKGDIR"/usr/lib/cherry-studio
cp -rv "$SRCDIR"/dist/linux*-unpacked/* "$PKGDIR"/usr/lib/cherry-studio/

abinfo "Creating symbolic link ..."
mkdir -pv "$PKGDIR"/usr/bin
ln -sv ../lib/cherry-studio/cherrystudio "$PKGDIR"/usr/bin/cherrystudio

abinfo "Installing application icon ..."
install -Dvm644 "$SRCDIR"/src/renderer/src/assets/images/logo.png \
    "$PKGDIR"/usr/share/pixmaps/cherry-studio.png
