From 2beca65c0a01fb51e37aa74ab2678d70bfc50466 Mon Sep 17 00:00:00 2001
From: CyberNeko-AI <cyberneko.ai@aosc.io>
Date: Mon, 16 Feb 2026 12:33:51 +0800
Subject: [PATCH] fix: modify `configure.ac` and `Makefile.am` in `icons` to
 allow proper reconfigure and shadow build

---
 Makefile.am                     | 9 +++++----
 configure.ac                    | 1 +
 icons/apps-scalable/Makefile.am | 2 +-
 icons/apps/Makefile.am          | 2 +-
 icons/default-theme/Makefile.am | 4 ++--
 icons/gnome-theme/Makefile.am   | 2 +-
 icons/kde-theme/Makefile.am     | 2 +-
 icons/xfce-theme/Makefile.am    | 2 +-
 8 files changed, 13 insertions(+), 11 deletions(-)

diff --git a/Makefile.am b/Makefile.am
index 7977829..da118c2 100644
--- a/Makefile.am
+++ b/Makefile.am
@@ -16,7 +16,8 @@ EXTRA_DIST = autogen.sh buildrun installrun uninstall-xfe iconlinks.sh config.h
              ABOUT-NLS TODO BUGS xferc.in *.desktop.in.in \
 	         $(top_srcdir)/icons/* $(top_srcdir)/debian
 
-desktopdir = $(prefix)/share/applications
+# desktopdir = $(prefix)/share/applications modified by gpt
+desktopdir = $(datadir)/applications
 desktop_in_files = xfe.desktop.in xfa.desktop.in xfi.desktop.in xfp.desktop.in xfw.desktop.in
 desktop_DATA = $(desktop_in_files:.desktop.in=.desktop)
 
@@ -44,8 +45,8 @@ xfw.desktop: xfw.desktop.in Makefile
 org.xfe.root.policy: org.xfe.root.policy.in Makefile
 		$(AM_V_GEN)$(MSGFMT) --xml -d $(top_srcdir)/po --template $< -o $@
 
-org.xfe.root.policy.in: org.xfe.root.policy.in.in Makefile
-	$(do_subst) < org.xfe.root.policy.in.in > org.xfe.root.policy.in
+org.xfe.root.policy.in: $(srcdir)/org.xfe.root.policy.in.in Makefile
+	$(do_subst) < $< > $@
 
 dist-hook:
 	cd po && $(MAKE) update-po
@@ -54,7 +55,7 @@ dist-hook:
 	rm -rf $(distdir)/debian/xfe
 
 install-data-hook:
-	sh iconlinks.sh $(top_srcdir) $(DESTDIR)$(rcdir)
+	sh $(srcdir)/iconlinks.sh $(top_srcdir) $(DESTDIR)$(rcdir)
 if INSTALL_POLKIT_ACTIONS
 	$(MKDIR_P) $(DESTDIR)$(pkdir)
 	cp org.xfe.root.policy $(DESTDIR)$(pkdir)
diff --git a/configure.ac b/configure.ac
index 5a09cf2..5f4cf24 100644
--- a/configure.ac
+++ b/configure.ac
@@ -33,6 +33,7 @@ PKG_PROG_PKG_CONFIG
 
 
 # Internationalization
+AC_CONFIG_MACRO_DIR([m4])
 GETTEXT_PACKAGE=xfe
 AC_SUBST(GETTEXT_PACKAGE)
 AC_DEFINE_UNQUOTED(GETTEXT_PACKAGE,"$GETTEXT_PACKAGE",[The package name, for gettext])
diff --git a/icons/apps-scalable/Makefile.am b/icons/apps-scalable/Makefile.am
index 6721579..92cd2d7 100644
--- a/icons/apps-scalable/Makefile.am
+++ b/icons/apps-scalable/Makefile.am
@@ -1,3 +1,3 @@
 icondir=$(datadir)/icons/hicolor/scalable/apps
-icon_DATA=*.svg
+dist_icon_DATA = $(wildcard $(srcdir)/*.svg)
 	
diff --git a/icons/apps/Makefile.am b/icons/apps/Makefile.am
index 25ae187..6f14328 100644
--- a/icons/apps/Makefile.am
+++ b/icons/apps/Makefile.am
@@ -1,3 +1,3 @@
 icondir=$(datadir)/icons/hicolor/48x48/apps
-icon_DATA=*.png *.xpm
+dist_icon_DATA = $(wildcard $(srcdir)/*.png $(srcdir)/*.xpm)
 	
diff --git a/icons/default-theme/Makefile.am b/icons/default-theme/Makefile.am
index 40fa205..544e627 100644
--- a/icons/default-theme/Makefile.am
+++ b/icons/default-theme/Makefile.am
@@ -1,3 +1,3 @@
 icondir=$(datadir)/xfe/icons/default-theme
-icon_DATA=*.png
-	
+dist_icon_DATA = $(wildcard $(srcdir)/*.png)
+    
diff --git a/icons/gnome-theme/Makefile.am b/icons/gnome-theme/Makefile.am
index 9c28d94..25133d4 100644
--- a/icons/gnome-theme/Makefile.am
+++ b/icons/gnome-theme/Makefile.am
@@ -1,3 +1,3 @@
 icondir=$(datadir)/xfe/icons/gnome-theme
-icon_DATA=*.png
+dist_icon_DATA = $(wildcard $(srcdir)/*.png)
 	
diff --git a/icons/kde-theme/Makefile.am b/icons/kde-theme/Makefile.am
index a890325..212ba17 100644
--- a/icons/kde-theme/Makefile.am
+++ b/icons/kde-theme/Makefile.am
@@ -1,3 +1,3 @@
 icondir=$(datadir)/xfe/icons/kde-theme
-icon_DATA=*.png
+dist_icon_DATA = $(wildcard $(srcdir)/*.png)
 	
diff --git a/icons/xfce-theme/Makefile.am b/icons/xfce-theme/Makefile.am
index 6617142..df7f0e9 100644
--- a/icons/xfce-theme/Makefile.am
+++ b/icons/xfce-theme/Makefile.am
@@ -1,3 +1,3 @@
 icondir=$(datadir)/xfe/icons/xfce-theme
-icon_DATA=*.png
+dist_icon_DATA = $(wildcard $(srcdir)/*.png)
 	
