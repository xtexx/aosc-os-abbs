abinfo "Creating directories..."
install -dvm755 "$PKGDIR"/usr/lib/acme.sh/{deploy,dnsapi,notify}
install -dvm755 "$PKGDIR"/usr/bin

abinfo "Installing acme.sh to /usr/lib/acme.sh/..."
install -vm755 "$SRCDIR"/acme.sh "$PKGDIR"/usr/lib/acme.sh/
install -vm755 "$SRCDIR"/deploy/*.sh "$PKGDIR"/usr/lib/acme.sh/deploy/
install -vm755 "$SRCDIR"/dnsapi/*.sh "$PKGDIR"/usr/lib/acme.sh/dnsapi/
install -vm755 "$SRCDIR"/notify/*.sh "$PKGDIR"/usr/lib/acme.sh/notify/
ln -vsf ../lib/acme.sh/acme.sh "$PKGDIR"/usr/bin/acme.sh
