PKGNAME=imagemagick+7
PKGSEC=utils
PKGDEP="libtool lcms2 fontconfig ghostscript openexr libwmf librsvg libxml2 \
        liblqr openjpeg perl libxml2 libwebp djvulibre fftw libheif"
PKGDES="An image viewing and manipulation program (version 7)"

ABTYPE=autotools
AUTOTOOLS_AFTER=(
	'--with-modules'
	'--program-suffix=-7'
	'--enable-hdri'
	'--with-wmf'
	'--with-openexr'
	'--with-xml'
	'--with-webp'
	'--with-gslib'
	'--with-gs-font-dir=/usr/share/fonts/Type1'
	'--with-lqr'
	'--with-rsvg'
	'--with-openjp2'
	'--without-gvc'
	'--with-djvu'
	'--without-autotrace'
	'--without-jbig'
	'--without-fpx'
	'--without-dps'
	'--with-fftw'
	'LIBS=-ldl'
)

# Required for loadable modules
NOLIBTOOL=0
AB_FLAGS_O3=1
