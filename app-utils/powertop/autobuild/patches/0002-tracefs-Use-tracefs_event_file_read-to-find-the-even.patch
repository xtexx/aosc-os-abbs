+		ev->set_event_name(system_name, event_name);
 		ev->set_cpu(i);
 
 		if ((int)ev->trace_type >= 0) {
-			if (event_names.find(ev->trace_type) == event_names.end()) {
-				event_names[ev->trace_type] = strdup(event_name);
-				parse_event_format(event_name);
-			}
 			events.push_back(ev);
 			event_added = true;
 		} else {
