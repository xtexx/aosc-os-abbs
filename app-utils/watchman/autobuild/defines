PKGNAME=watchman
PKGSEC=utils
PKGDEP="boost edencommon fmt folly gflags glog libevent openssl pcre python-3"
# FIXME: GCC 15 fails to build this package.
BUILDDEP="cpptoml gcc-14 gtest llvm rustc"
PKGDES="File-watching and job-triggering utility based on inotify"

ABTYPE=cmakeninja
CMAKE_AFTER=(
    '-DWATCHMAN_STATE_DIR=/run/watchman'
    '-DINSTALL_WATCHMAN_STATE_DIR=OFF'
    '-DCMAKE_CXX_STANDARD=20'
    "-DWATCHMAN_VERSION_OVERRIDE=$PKGVER"
)

# FIXME: error: call of overloaded ‘find(const std::__cxx11::basic_string<char>&)’ is ambiguous
USECLANG=1
