abinfo "Generating postinst and prerm scripts ..."
sed -e "s|@VER@|$PKGVER|g" \
    -i "$SRCDIR"/autobuild/postinst \
    -i "$SRCDIR"/autobuild/prerm

abinfo "Patching dkms.conf ..."
sed -e "s/DRV_VERSION=.*/DRV_VERSION=$PKGVER/g" -i "$SRCDIR"/corefreq/dkms.conf
sed -e "s/PRE_INSTALL=.*//g" -i "$SRCDIR"/corefreq/dkms.conf
sed -e "s/POST_REMOVE=.*//g" -i "$SRCDIR"/corefreq/dkms.conf

abinfo "Final dkms.conf:"
cat "$SRCDIR"/corefreq/dkms.conf
