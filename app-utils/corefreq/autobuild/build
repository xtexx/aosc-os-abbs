abinfo "Installing DKMS source tree ..."
mkdir -pv "$PKGDIR"/usr/src
cp -av "$SRCDIR"/corefreq \
    "$PKGDIR"/usr/src/corefreqk-$PKGVER

abinfo "Preparing tools build directory ..."
mkdir -vm +t "$SRCDIR"/corefreq/build
mkdir -vm +t "$SRCDIR"/corefreq/build/module
ln -sv ../Makefile "$SRCDIR"/corefreq/build/Makefile

abinfo "Building CoreFreq tools ..."
make corefreqd corefreq-cli \
    -C "$SRCDIR"/corefreq

abinfo "Installing CoreFreq tools ..."
install -Dvm755 \
    "$SRCDIR"/corefreq/build/corefreqd \
    "$SRCDIR"/corefreq/build/corefreq-cli \
    -t "$PKGDIR"/usr/bin/
install -Dvm755 "$SRCDIR"/corefreq/corefreqd.service \
    "$PKGDIR"/usr/lib/systemd/system/corefreqd.service
