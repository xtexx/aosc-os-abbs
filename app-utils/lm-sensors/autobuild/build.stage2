abinfo "Configuring make parameters ..."
MAKE_OPTS=(
    "DESTDIR=$PKGDIR"
    'PREFIX=/usr'
    'SBINDIR=/usr/bin'
    'LIBDIR=/usr/lib'
    'MANDIR=/usr/share/man'
    'BUILD_STATIC_LIB=0'
    'PROG_EXTRA='
)
abinfo "Building lm-sensors ..."
make user \
    ${MAKE_OPTS[@]} \
    CFLAGS="${CPPFLAGS} ${CFLAGS} ${LDFLAGS}" \
    EXLDFLAGS="${LDFLAGS}"

abinfo "Installing lm-sensors ..."
make user_install \
    ${MAKE_OPTS[@]}
