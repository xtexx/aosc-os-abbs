abinfo "Installing man pages ..."
mkdir -pv "$PKGDIR"/usr/share/man/man1
"$PKGDIR"/usr/bin/gum man > "$PKGDIR"/usr/share/man/man1/gum.1

abinfo "Installing shell completions ..."
mkdir -pv "$PKGDIR"/usr/share/bash-completion/completions/
mkdir -pv "$PKGDIR"/usr/share/fish/vendor_completions.d/
mkdir -pv "$PKGDIR"/usr/share/zsh/site-functions/
"$PKGDIR"/usr/bin/gum completion bash > "$PKGDIR"/usr/share/bash-completion/completions/gum
"$PKGDIR"/usr/bin/gum completion zsh > "$PKGDIR"/usr/share/zsh/site-functions/gum
"$PKGDIR"/usr/bin/gum completion fish > "$PKGDIR"/usr/share/fish/vendor_completions.d/gum.fish
