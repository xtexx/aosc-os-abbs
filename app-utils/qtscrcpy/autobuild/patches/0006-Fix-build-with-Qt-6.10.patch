From: Ruikai Liu <rickliu2000@outlook.com>
Date: Tue, 11 Nov 2025 09:56:02 +0800
Subject: [PATCH 6/6] Fix build with Qt 6.10

---
 QtScrcpy/CMakeLists.txt | 4 ++++
 1 file changed, 4 insertions(+)

diff --git a/QtScrcpy/CMakeLists.txt b/QtScrcpy/CMakeLists.txt
index 74887ce..ebef2d8 100755
--- a/QtScrcpy/CMakeLists.txt
+++ b/QtScrcpy/CMakeLists.txt
@@ -122,6 +122,10 @@ endif()
 
 find_package(Qt${QT_DESIRED_VERSION} REQUIRED COMPONENTS ${qt_required_components})
 
+if(Qt6_VERSION VERSION_GREATER_EQUAL 6.10)
+  find_package(Qt6 COMPONENTS CorePrivate GuiPrivate REQUIRED)
+endif()
+
 set(LINK_LIBS
     Qt${QT_DESIRED_VERSION}::Widgets
     Qt${QT_DESIRED_VERSION}::Network
