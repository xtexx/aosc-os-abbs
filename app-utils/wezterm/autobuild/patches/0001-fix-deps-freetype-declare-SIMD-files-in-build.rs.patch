From 3898222a568cc52c7fc5e2633efff3dff4173fd0 Mon Sep 17 00:00:00 2001
From: Mingcong Bai <jeffbai@aosc.io>
Date: Thu, 21 Aug 2025 17:23:02 +0800
Subject: [PATCH] fix(deps/freetype): declare SIMD files in build.rs

Add missing SIMD intrinsics defintion sources to fix build on
LoongArch (+LSX), MIPS, PowerPC, and x86-64.

Signed-off-by: Mingcong Bai <jeffbai@aosc.io>
---
 deps/freetype/build.rs | 17 +++++++++++++++++
 1 file changed, 17 insertions(+)

diff --git a/deps/freetype/build.rs b/deps/freetype/build.rs
index 356ce0323..b3f6b201d 100644
--- a/deps/freetype/build.rs
+++ b/deps/freetype/build.rs
@@ -82,6 +82,23 @@ fn libpng() {
                     .file("libpng/arm/filter_neon_intrinsics.c")
                     .file("libpng/arm/palette_neon_intrinsics.c");
             }
+            "loongarch64" => {
+                cfg.file("libpng/loongarch/filter_lsx_intrinsics.c")
+                    .file("libpng/loongarch/loongarch_lsx_init.c");
+            }
+            "mips64" => {
+                cfg.file("libpng/mips/filter_mmi_inline_assembly.c")
+                    .file("libpng/mips/filter_msa_intrinsics.c")
+                    .file("libpng/mips/mips_init.c");
+            }
+            "powerpc64" => {
+                cfg.file("libpng/powerpc/filter_vsx_intrinsics.c")
+                    .file("libpng/powerpc/powerpc_init.c");
+            }
+            "x86_64" => {
+                cfg.file("libpng/intel/filter_sse2_intrinsics.c")
+                    .file("libpng/intel/intel_init.c");
+            }
             _ => {}
         }
     }
-- 
