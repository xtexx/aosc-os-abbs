abinfo "Building U-Boot tools ..."
make tools-only_defconfig
make tools-all \
    HOSTCC="gcc ${CPPFLAGS} ${CFLAGS} ${LDFLAGS}"

abinfo "Installing U-Boot tools ..."
install -Dvm755 -t "$PKGDIR"/usr/bin/ \
    "$SRCDIR"/tools/{mk{,env}image,env/fw_printenv,img2srec,dumpimage,netconsole,jtagconsole,ncb,mksunxiboot,kwboot,fdtgrep,sunxi-spl-image-builder}
install -Dvm644 "$SRCDIR"/doc/mkimage.1 \
    "$PKGDIR"/usr/share/man/man1/mkimage.1
install -Dvm644 "$SRCDIR"/doc/kwboot.1 \
    "$PKGDIR"/usr/share/man/man1/kwboot.1

abinfo "Creating a symlink fw_setenv => fw_printenv ..."
ln -sv fw_printenv "$PKGDIR"/usr/bin/fw_setenv
