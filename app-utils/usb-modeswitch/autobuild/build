abinfo "Creating installation directories ..."
mkdir -pv "$PKGDIR"/usr/lib/udev
mkdir -pv "$PKGDIR"/etc
mkdir -pv "$PKGDIR"/usr/share/man/man1

USB_MODESWITCH="${SRCDIR}/../usb-modeswitch-${__UPSTREAM_VER}"
USB_MODESWITCH_DATA="${SRCDIR}/../usb-modeswitch-data-${__DATA_VER}"

abinfo "Building and install usb-modeswitch ..."
cd "${USB_MODESWITCH}"
make
make \
    DESTDIR="$PKGDIR" \
    UDEVDIR="$PKGDIR"/usr/lib/udev \
    SBINDIR="$PKGDIR"/usr/bin \
    install
install -Dvm644 "${USB_MODESWITCH}"/COPYING \
    "$PKGDIR"/usr/share/doc/usb-modeswitch/COPYING

abinfo "Installing usb-modeswitch-data ..."
cd "${USB_MODESWITCH_DATA}"
make \
    DESTDIR="$PKGDIR" \
    RULESDIR="$PKGDIR"/usr/lib/udev/rules.d \
    install

abinfo "Installing Systemd service ..."
mkdir -pv "$PKGDIR"/usr/lib/systemd/system
cp -v "${USB_MODESWITCH}"/usb_modeswitch@.service \
      "$PKGDIR"/usr/lib/systemd/system/
