From 478c83ab558c628ac670fbcb00d4d12a68ee7f24 Mon Sep 17 00:00:00 2001
From: Mike Gabriel <mike.gabriel@das-netzwerkteam.de>
Date: Sat, 5 Oct 2024 19:07:44 +0200
Subject: [PATCH] mc-plugin/mcp-account-manager-ofono-on-ring.c: Type cast
 g_object_ref to McpAccountManager*. Fixes FTBFS against GCC-14.

Signed-off-by: Mike Gabriel <mike.gabriel@das-netzwerkteam.de>
---
 mc-plugin/mcp-account-manager-ofono-on-ring.c | 2 +-
 1 file changed, 1 insertion(+), 1 deletion(-)

diff --git a/mc-plugin/mcp-account-manager-ofono-on-ring.c b/mc-plugin/mcp-account-manager-ofono-on-ring.c
index 23f7c03..10d8c28 100644
--- a/mc-plugin/mcp-account-manager-ofono-on-ring.c
+++ b/mc-plugin/mcp-account-manager-ofono-on-ring.c
@@ -375,7 +375,7 @@ account_manager_ofono_ready (const McpAccountStorage *storage,
   g_debug ("%s", G_STRFUNC);
 
   self->priv->ready = TRUE;
-  self->priv->am = g_object_ref (G_OBJECT (am));
+  self->priv->am = (McpAccountManager*) g_object_ref (G_OBJECT (am));
 
   while ((data = g_queue_pop_head (self->priv->pending_signals)) != NULL)
     {
-- 
2.39.5

