PKGNAME=libsoup-3
PKGSEC=libs
PKGDEP="brotli glib glibc glib-networking krb5 libpsl nghttp2 sqlite \
        zlib libpsl libxml2 python-3 samba"
BUILDDEP="gobject-introspection intltool typogrify vala"
PKGDES="HTTP client/server library for GNOME (version 3)"

ABTYPE=meson
MESON_AFTER=(
    "-Dgssapi=enabled"
    "-Dntlm=enabled"
    "-Dbrotli=enabled"
    "-Dtls_check=true"
    "-Dintrospection=enabled"
    "-Dvapi=enabled"
    "-Ddocs=disabled"
    "-Dtests=false"
    "-Dautobahn=disabled"
    "-Dinstalled_tests=false"
    "-Dsysprof=disabled"
    "-Dfuzzing=disabled"
    "-Dpkcs11_tests=disabled"
)
