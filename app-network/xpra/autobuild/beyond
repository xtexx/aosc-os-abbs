abinfo "Moving dbus system configuration to /usr"
mkdir -vp "${PKGDIR}/usr/share/dbus-1/system.d/"
mv -v "${PKGDIR}/usr/etc/dbus-1/system.d/"*.conf "${PKGDIR}/usr/share/dbus-1/system.d"
rm -rv "${PKGDIR}/usr/etc/dbus-1"

abinfo "Moving /usr/etc to /etc ..."
mv -v "${PKGDIR}/usr/etc" "${PKGDIR}/etc"
