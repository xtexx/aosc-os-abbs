From 3380c4585d17ad26c9e024ee5b0b864f82c3a6ed Mon Sep 17 00:00:00 2001
From: Qing Yun <kf@aosc.io>
Date: Wed, 23 Apr 2025 14:13:24 +0800
Subject: [PATCH] optimize easytier-web features

This commit makes --no-default-features in virtual manifest take effect.
---
 easytier-web/Cargo.toml | 2 +-
 1 file changed, 1 insertion(+), 1 deletion(-)

diff --git a/easytier-web/Cargo.toml b/easytier-web/Cargo.toml
index 2a33bb0..0d67ca0 100644
--- a/easytier-web/Cargo.toml
+++ b/easytier-web/Cargo.toml
@@ -5,7 +5,7 @@ edition = "2021"
 description = "Config server for easytier. easytier-core gets config from this and web frontend use it as restful api server."
 
 [dependencies]
-easytier = { path = "../easytier" }
+easytier = { path = "../easytier", default-features = false }
 tracing = { version = "0.1", features = ["log"] }
 anyhow = { version = "1.0" }
 thiserror = "1.0"
-- 
2.49.0

