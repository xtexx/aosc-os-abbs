From 95dee1c9d1fc5413f66a543d37e22d748668b23a Mon Sep 17 00:00:00 2001
From: Qing Yun <kf@aosc.io>
Date: Tue, 22 Apr 2025 15:34:56 +0800
Subject: [PATCH] build: remove linker configuration for
 aarch64-unknown-linux-gnu target

This configuration is intended for cross-compilation on x86_64,
but it causes errors when building natively on aarch64 in AOSC.
"error: linker `aarch64-linux-gnu-gcc` not found"

Signed-off-by: Qing Yun <kf@aosc.io>
---
 .cargo/config.toml | 3 ---
 1 file changed, 3 deletions(-)

diff --git a/.cargo/config.toml b/.cargo/config.toml
index 1728893..f2aa6b0 100644
--- a/.cargo/config.toml
+++ b/.cargo/config.toml
@@ -2,9 +2,6 @@
 linker = "rust-lld"
 rustflags = ["-C", "linker-flavor=ld.lld"]

-[target.aarch64-unknown-linux-gnu]
-linker = "aarch64-linux-gnu-gcc"
-
 [target.aarch64-unknown-linux-ohos]
 ar = "/usr/local/ohos-sdk/linux/native/llvm/bin/llvm-ar"
 linker = "/home/runner/sdk/native/llvm/aarch64-unknown-linux-ohos-clang.sh"
--
2.50.1
