PKGNAME=filezilla
PKGSEC=net
PKGDEP="wxgtk3 dbus xdg-utils libidn sqlite gnutls libfilezilla pugixml"
PKGDES="Graphical FTP, SFTP, and Storj client"

ABTYPE=autotools
AUTOTOOLS_AFTER=(
    '--enable-locales'
    '--disable-localesonly'
    # Note: DO NOT USE. Reserved for use by official maintainer.
    #       TYPE can either be 'official' or 'nightly'.
    #'--enable-buildtype=TYPE'
    '--enable-gui'
    '--disable-mac-sandbox'
    '--disable-precomp'
    '--disable-manualupdatecheck'
    '--disable-autoupdatecheck'
    '--enable-ftp'
    '--enable-sftp'
    '--enable-storj'
    '--with-pugixml=system'
    '--with-dbus'
)
