# Get default DB path and SCHEMA path
HELP_OUTPUT=$(ovsdb-tool --help)
OVS_DB=$(echo "$HELP_OUTPUT" | grep -oP 'The default DB is \K/\S*?conf\.db')
OVS_SCHEMA=$(echo "$HELP_OUTPUT" | grep -oP 'The default SCHEMA is \K/\S*?ovsschema')
echo "The default DB is: $OVS_DB"
echo "The default SCHEMA is: $OVS_SCHEMA"

# Create or convert the DB
if [ -f "$OVS_DB" ]; then
    OVS_RESULT=$(ovsdb-tool needs-conversion "$OVS_DB" "$OVS_SCHEMA")
    if [ "yes" = "$OVS_RESULT" ]; then
        echo "Convert DB: $OVS_DB"
        # Stop ovs service
        systemctl stop ovsdb-server
        systemctl stop ovs-vswitchd
        ovsdb-tool convert "$OVS_DB" "$OVS_SCHEMA"
    else
        echo "Retain DB: $OVS_DB"
    fi
else
    echo "Create DB: $OVS_DB"
    ovsdb-tool create "$OVS_DB" "$OVS_SCHEMA"
fi
