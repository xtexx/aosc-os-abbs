  "core-foundation-sys",
  "libc",
diff --git a/Cargo.toml b/Cargo.toml
index d4c0d5d..db85a1f 100644
--- a/Cargo.toml
+++ b/Cargo.toml
@@ -27,12 +27,11 @@ once_cell = "1.20.3"
 serde_json = "1.0.138"
 parking_lot = "0.12"
 windows-service = "0.7.0"
-tokio = { version = "1.43.0", features = ["full"] }
-serde = { version = "1.0.217", features = ["derive"] }
-sysinfo = "0.33.1"
-nix = "0.25.1"
-libc = "0.2.169"
 which = "7"
+tokio = { version = "1", features = ["full"] }
+serde = { version = "1.0", features = ["derive"] }
+sysinfo = "0.31.4"
+nix = { version = "0.29", features = ["signal"] }
 
 [target.'cfg(target_os = "linux")'.dependencies]
 openssl = { version = "0.10.71", features = ["vendored"] }
diff --git a/src/service/core.rs b/src/service/core.rs
index c5a4a92..3f63f16 100644
--- a/src/service/core.rs
+++ b/src/service/core.rs
@@ -192,6 +192,6 @@ pub fn init_signal_handler() {
 extern "C" fn handle_sigchld(_: i32) {
     unsafe {
         // 循环等待所有已终止的子进程
-        while libc::waitpid(-1, std::ptr::null_mut(), libc::WNOHANG) > 0 {}
+        while nix::libc::waitpid(-1, std::ptr::null_mut(), nix::libc::WNOHANG) > 0 {}
     }
 }
