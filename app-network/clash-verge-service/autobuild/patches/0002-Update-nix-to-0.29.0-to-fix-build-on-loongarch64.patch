@@ -143,10 +149,9 @@ version = "1.0.1"
 dependencies = [
  "anyhow",
  "interfaces",
- "libc",
  "log",
  "log4rs",
- "nix 0.25.1",
+ "nix 0.29.0",
  "once_cell",
  "openssl",
  "parking_lot",
@@ -814,15 +819,6 @@ version = "2.7.4"
