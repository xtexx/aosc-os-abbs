PKGNAME=getdns
PKGSEC=net
PKGDEP="gnutls libev libevent libuv libidn2 openssl unbound gmp"
BUILDDEP="check"
PKGDES="An implementation of a modern asynchronous DNS API"

ABTYPE=cmakeninja
CMAKE_AFTER=(
    "-DBUILD_TESTING=OFF"
    "-DUSE_GNUTLS=ON"
    "-DBUILD_STUBBY=OFF"
    "-DCMAKE_EXE_LINKER_FLAGS=\"-lgmp\""
    "-DCMAKE_SHARED_LINKER_FLAGS=\"-lgmp\""
    )
NOLTO=1
