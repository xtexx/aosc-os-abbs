From 096a67be64d7730f8b188b92fe7afb652925f0da Mon Sep 17 00:00:00 2001
From: Mingcong Bai <jeffbai@aosc.io>
Date: Sat, 4 Apr 2026 15:27:40 +0800
Subject: [PATCH 3/3] FEDORA: do not exit with code 1 when there is no error

Link: https://src.fedoraproject.org/rpms/arpwatch/c/695a40424319da504aba7c5161553ff043beb280
Signed-off-by: Mingcong Bai <jeffbai@aosc.io>
---
 arpwatch.c | 2 +-
 1 file changed, 1 insertion(+), 1 deletion(-)

diff --git a/arpwatch.c b/arpwatch.c
index 124f610..a1de2ba 100644
--- a/arpwatch.c
+++ b/arpwatch.c
@@ -952,7 +952,7 @@ die(int signo)
 {
 	lg(LOG_DEBUG, "exiting");
 	checkpoint(0);
-	exit(1);
+	exit(0);
 }
 
 void
