abinfo "Installing ethercodes.dat ..."
mkdir -pv "$PKGDIR"/var/lib/arpwatch/
# Note: ACBS source caches are symlinks.
zstd -dvvv $(readlink -f "$SRCDIR"/../ethercodes.dat.zst) \
    -o "$PKGDIR"/var/lib/arpwatch/ethercodes.dat

abinfo "Creating an empty arp.dat ..."
touch "$PKGDIR"/var/lib/arpwatch/arp.dat

abinfo "Removing unwanted files ..."
rm -rv "$PKGDIR"/usr/etc
