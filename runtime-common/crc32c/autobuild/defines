PKGNAME=crc32c
PKGDES="CRC32C implementation with support for CPU-specific acceleration instructions"
PKGSEC=libs
PKGDEP="gcc-runtime"

ABTYPE=cmakeninja

CMAKE_AFTER=(
	-DBUILD_GMOCK=OFF
	-DBUILD_SHARED_LIBS=ON
	-DBUILD_TESTING=OFF
	-DCRC32C_BUILD_BENCHMARKS=OFF
	-DCRC32C_BUILD_TESTS=OFF
	-DCRC32C_USE_GLOG=OFF
	-DINSTALL_GTEST=OFF
	-DWITH_GFLAGS=OFF
	-DWITH_GTEST=OFF
)
