PKGNAME=ncurses
PKGDEP="glibc texinfo"
PKGDES="Library to create terminal user interfaces"
PKGSEC=libs

PKGEPOCH=1

ABTYPE=self
AUTOTOOLS_AFTER=(
    '--with-shared'
    # Note: Disable static libraries.
    '--without-normal'
    '--without-debug'
    '--without-ada'
    '--enable-pc-files'
    '--with-cxx-binding'
    '--with-cxx-shared'
    '--without-gpm'
    '--enable-ext-colors'
    '--with-versioned-syms'
    # FIXME: Broken with ABI version 5.
    '--without-tests'
)
