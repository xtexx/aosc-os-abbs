PKGNAME=ncurses
PKGDEP="glibc"
PKGDES="Library to create terminal user interfaces"
PKGSEC=libs

PKGEPOCH=1

# FIXME: Re-configuration fails.
#
# configure.in:2671: error: possibly undefined macro: AC_SETUP_DEFS
#       If this token and others are legitimate, please use m4_pattern_allow.
#       See the Autoconf documentation.
RECONF=0

AUTOTOOLS_AFTER=(
    '--with-shared'
    # Note: Disable static libraries.
    '--without-normal'
    '--without-debug'
    '--without-ada'
    '--enable-pc-files'
    '--with-cxx-binding'
    '--with-cxx-shared'
    '--without-gpm'
    '--enable-ext-colors'
    '--with-versioned-syms'
    # FIXME: Broken with ABI version 5.
    '--without-tests'
)
