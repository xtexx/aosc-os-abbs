PKGNAME=libffi
PKGDES="Portable foreign function interface library"
PKGDEP="glibc"
PKGSEC=libs

AUTOTOOLS_AFTER="--enable-pax_emutramp \
                 --enable-static"

NOSTATIC=0
NOSTATIC__RETRO=1

# FIXME: LLVM offload runtime requires libffi.a compiled with -fPIC.
# Otherwise, linking fails due to undefined ffi symbols.
NOLTO=1
