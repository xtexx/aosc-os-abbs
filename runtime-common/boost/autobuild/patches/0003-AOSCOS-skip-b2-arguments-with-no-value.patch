From d92c6eb3b0ae2e27bc0e89e838464ae832fef632 Mon Sep 17 00:00:00 2001
From: Ruikai Liu <rickliu2000@foxmail.com>
Date: Thu, 4 Jun 2026 18:47:35 +0800
Subject: [PATCH] AOSCOS: skip b2 arguments with no value

---
 tools/build/src/engine/variable.cpp | 12 ++++++++++--
 1 file changed, 10 insertions(+), 2 deletions(-)

diff --git a/tools/build/src/engine/variable.cpp b/tools/build/src/engine/variable.cpp
index 77bf47301..44bb1ed28 100644
--- a/tools/build/src/engine/variable.cpp
+++ b/tools/build/src/engine/variable.cpp
@@ -78,8 +78,16 @@ void var_defines(struct module_t * module, const char * const * e, int preproces
 	for (; *e; ++e)
 	{
 		::b2::string_view def(*e);
-		::b2::string_view var(def.begin(), def.find('='));
-		::b2::string_view val(def.begin() + var.size() + 1);
+		
+		//If equal sign not found, skip this entry.
+		auto eq_pos = def.find('=');
+		if (eq_pos == ::b2::string_view::npos) {
+			continue;
+		}
+		
+		::b2::string_view var(def.begin(), eq_pos);
+		::b2::string_view val(def.begin() + eq_pos + 1);
+
 		b2::jam::variable jam_var { module,
 			std::string { var.begin(), var.end() }.c_str() };
 		// std::printf(">> var_defines: *e = %s\n", *e);
-- 
2.52.0

