PKGNAME=rocm-llvm
PKGDES="LLVM customized for ROCm"
PKGSEC=devel
PKGDEP="gcc-runtime libxml2 libedit zlib rocm-core"
BUILDDEP="cmake llvm"

# FIXME: Compiler Error
#
# CMake Error at llvm-project/libunwind/src/CMakeLists.txt:102 (message):
#     Compiler doesn't support generation of unwind tables if exception support
#     is disabled.  Building libunwind DSO with runtime dependency on C++ ABI
#     library is not supported.
NOLTO=1

USECLANG=1

# Note: Keep libclang_rt.builtins.a, Compiling for GPU environment
NOSTATIC=0

LLVM_BASE_SET="clang;lld;compiler-rt;clang-tools-extra;mlir;openmp;flang"
_LLVM_BASE_RUNTIME_SET="libcxx;libcxxabi;libunwind"

ABTYPE=cmakeninja
CMAKE_AFTER=(
    '-DCMAKE_INSTALL_PREFIX=/usr/lib/rocm/lib/llvm'
    '-DCMAKE_INSTALL_RPATH=/usr/lib/rocm/lib/llvm/lib;/usr/lib/rocm/lib'
    '-DBUILD_SHARED_LIBS=ON'
    '-DLLVM_ENABLE_LIBCXX=ON'
    '-DLIBCXX_ENABLE_SHARED=OFF'
    '-DLIBCXX_ENABLE_STATIC=ON'
    '-DLIBCXXABI_ENABLE_SHARED=OFF'
    '-DLIBCXXABI_ENABLE_STATIC=ON'
    '-DLIBCXX_ENABLE_STATIC_ABI_LIBRARY=ON'
    '-DLIBCXXABI_USE_LLVM_UNWINDER=ON'
    '-DLIBCXX_USE_COMPILER_RT=ON'
    '-DLLVM_ENABLE_PIC=ON'
    '-DLLVM_ENABLE_ASSERTIONS=1'
    '-DLLVM_TARGETS_TO_BUILD=Native;AMDGPU'
    '-DLLVM_EXPERIMENTAL_TARGETS_TO_BUILD=SPIRV'
    '-DCMAKE_SKIP_INSTALL_RPATH=OFF'
    '-DCMAKE_SKIP_RPATH=OFF'
    '-DLLVM_INCLUDE_TESTS=OFF'
    "-DLLVM_ENABLE_PROJECTS=${LLVM_BASE_SET}"
    "-DLLVM_ENABLE_RUNTIMES=${_LLVM_BASE_RUNTIME_SET}"
)
CMAKE_AFTER__LOONGARCH64=(
    ${CMAKE_AFTER[@]}
    '-DCMAKE_C_FLAGS=-mcmodel=extreme'
    '-DCMAKE_CXX_FLAGS=-mcmodel=extreme'
)

FAIL_ARCH="!(amd64|arm64|loongarch64|riscv64)"
