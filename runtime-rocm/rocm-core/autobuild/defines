PKGNAME=rocm-core
PKGDES=""
PKGSEC=devel
BUILDDEP="cmake"

ABTYPE=cmakeninja
CMAKE_AFTER=(
    '-DCMAKE_INSTALL_PREFIX=/usr/lib/rocm'
    '-DCMAKE_PREFIX_PATH=/usr/lib/rocm'
    '-DCMAKE_SKIP_RPATH=OFF'
    '-DCMAKE_INSTALL_RPATH=/usr/lib/rocm/lib'
    '-DCMAKE_SKIP_INSTALL_RPATH=OFF'
    "-DROCM_VERSION=$PKGVER"
)

FAIL_ARCH="!(amd64|loongarch64)"
