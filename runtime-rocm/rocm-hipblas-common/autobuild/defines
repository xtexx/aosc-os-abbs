PKGNAME=rocm-hipblas-common
PKGDES="Common files for hipBLAS libraries"
PKGSEC=devel
PKGDEP="rocm-llvm rocm-clr rocm-cmake rocm-rocprofiler-register rocminfo"
BUILDDEP="cmake"

# Note: Depends on architecture-specific runtime. Treat as ELF-less.
ABSPLITDBG=0

ABTYPE=cmakeninja
CMAKE_AFTER=(
    '-DCMAKE_INSTALL_PREFIX=/usr/lib/rocm'
    '-DCMAKE_SKIP_INSTALL_RPATH=OFF'
    '-DCMAKE_PREFIX_PATH=/usr/lib/rocm'
)

FAIL_ARCH="!(amd64|arm64|loongarch64)"
