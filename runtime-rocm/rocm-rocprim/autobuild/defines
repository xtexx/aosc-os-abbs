PKGNAME=rocm-rocprim
PKGDES="ROCm Parallel Primitives"
PKGSEC=devel
PKGDEP="cmake rocm-llvm rocm-core rocm-clr rocm-cmake rocminfo"

USECLANG=1

# Note: Depends on architecture-specific runtime. Treat as ELF-less.
ABSPLITDBG=0

ABTYPE=cmakeninja
CMAKE_AFTER=(
    '-DCMAKE_INSTALL_PREFIX=/usr/lib/rocm'
    '-DCMAKE_PREFIX_PATH=/usr/lib/rocm'
    '-DAMDDeviceLibs_DIR=/usr/lib/rocm/lib/llvm/lib/cmake/AMDDeviceLibs/'
    '-Damd_comgr_DIR=/usr/lib/rocm/lib/llvm/lib/cmake/amd_comgr/'
    '-DCMAKE_CXX_COMPILER=/usr/lib/rocm/lib/llvm/bin/clang++'
    '-DCMAKE_LINKER_TYPE=LLD'
)

FAIL_ARCH="!(amd64|arm64|loongarch64)"
