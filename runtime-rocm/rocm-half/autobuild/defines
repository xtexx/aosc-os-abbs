PKGNAME=rocm-half
PKGDES="HALF-PRECISION FLOATING POINT LIBRARY"
PKGSEC=devel
PKGDEP="cmake rocm-core rocm-cmake"

# Note: Depends on architecture-specific runtime. Treat as ELF-less.
ABSPLITDBG=0

ABTYPE=cmakeninja
CMAKE_AFTER=(
    '-DCMAKE_INSTALL_PREFIX=/usr/lib/rocm'
)

FAIL_ARCH="!(amd64|arm64|loongarch64|riscv64)"
