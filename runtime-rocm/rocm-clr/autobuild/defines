PKGNAME=rocm-clr
PKGDES="Common language runtimes (HIP/OpenCL) for ROCm"
PKGSEC=devel
PKGDEP="rocr-runtime libglvnd glew rocm-llvm"
BUILDDEP="cmake rocm-cmake cppheaderparser"

PKGREP="rocm-opencl-runtime rocm-hipcc"
PKGBREAK="rocm-hipcc"
PKGPROV="rocm-opencl-runtime"
PKGCONFL="rocm-opencl-runtime"

USECLANG=1

ABTYPE=cmakeninja
CMAKE_AFTER=(
    '-DCMAKE_INSTALL_PREFIX=/usr/lib/rocm'
    '-DCMAKE_C_COMPILER=/usr/lib/rocm/lib/llvm/bin/clang'
    '-DCMAKE_CXX_COMPILER=/usr/lib/rocm/lib/llvm/bin/clang++'
    '-DCMAKE_PREFIX_PATH=/usr/lib/rocm/lib/llvm;/usr/lib/rocm'
    '-DCMAKE_SKIP_RPATH=OFF'
    '-DCMAKE_INSTALL_RPATH=/usr/lib/rocm/lib/llvm/lib;/usr/lib/rocm/lib'
    '-DCLR_BUILD_OCL=ON'
    '-DCLR_BUILD_HIP=ON'
    '-DHIP_PLATFORM=amd'
    '-DCMAKE_SKIP_INSTALL_RPATH=OFF'
    '-DCMAKE_LINKER_TYPE=LLD'
    "-DHIPCC_BIN_DIR=$SRCDIR/../hipcc-build/"
    "-DHIP_COMMON_DIR=$SRCDIR/../HIP"
)

FAIL_ARCH="!(amd64|loongarch64)"
