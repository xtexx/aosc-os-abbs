PKGNAME=rocm-rocmlir
PKGDES="MLIR-based convolution and GEMM kernel generator for ROCm"
PKGSEC=devel
PKGDEP="gcc-runtime libxml2 libedit zlib rocm-core rocm-llvm rocm-clr rocm-cmake"
BUILDDEP="cmake"

USECLANG=1
# Note: Need to keep the static libraries
NOSTATIC=0
# Note: Do not install the executable file. Only static libraries are installed.
ABSPLITDBG=0

ABTYPE=cmakeninja
CMAKE_AFTER=(
    '-DCMAKE_C_COMPILER=/usr/lib/rocm/lib/llvm/bin/clang'
    '-DCMAKE_CXX_COMPILER=/usr/lib/rocm/lib/llvm/bin/clang++'
    '-DCMAKE_INSTALL_RPATH=/usr/lib/rocm/lib/llvm/lib;/usr/lib/rocm/lib'
    '-DCMAKE_SKIP_INSTALL_RPATH=OFF'
    '-DCMAKE_INSTALL_PREFIX=/usr/lib/rocm/'
    '-DBUILD_FAT_LIBROCKCOMPILER=ON'
    '-DCMAKE_FIND_ROOT_PATH=/usr/lib/rocm/;/usr/lib/rocm/lib/llvm/'
    '-DCMAKE_LINKER_TYPE=LLD'
    '-DMLIR_INCLUDE_TESTS=OFF'
    '-DCMAKE_C_FLAGS=-fPIC'
    '-DCMAKE_CXX_FLAGS=-fPIC'
    '-DLLVM_TARGETS_TO_BUILD=AMDGPU'
)

FAIL_ARCH="!(amd64|arm64|loongarch64)"
