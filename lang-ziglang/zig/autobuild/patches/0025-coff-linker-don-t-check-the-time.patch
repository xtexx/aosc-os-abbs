 h=from:subject; bh=GRCjrcikEuQOPMRSUDowKgAvkMEI28Q1Ztl2rBElFXg=;
 b=owGbwMvMwCW2U4Ij7wZL9ETG02pJDJkmdtabTlrYLCqcdllRLnPBq+vL73Mm3Qr/KfTDbzJ3x
 Lz5mVUZHaUsDGJcDLJiiixFhg3erDrp/KLLymVh5rAygQxh4OIUgIn8M2L4X3WtM9POPWF7zbUf
 3NN1H1wvvfhpiZD9tWhp+9dT/mn3ZzIyvFHdwMEb8kpeOz7YM9dnVXHG/E3nDrO+Zbi+y81/2SZ
 uRgA=
X-Developer-Key: i=xtexchooser@duck.com; a=openpgp;
 fpr=7231804B052C670F15A6771DB918086ED8045B91

compiler toolchains have no business knowing what time it is

(cherry picked from commit 79a59c516531650664511ac539ee6d7c6402169f)
Change-Id: If9c7b187f46191367063cbbbb71254eebea0443f
Signed-off-by: xtex <xtexchooser@duck.com>
---
 src/link/Coff.zig | 4 ++--
 1 file changed, 2 insertions(+), 2 deletions(-)

diff --git a/src/link/Coff.zig b/src/link/Coff.zig
index 62430f6c08e6..e1d91a6c3aec 100644
--- a/src/link/Coff.zig
+++ b/src/link/Coff.zig
@@ -2200,12 +2200,12 @@ fn writeHeader(coff: *Coff) !void {
         flags.DLL = 1;
     }
 
-    const timestamp = if (coff.repro) 0 else std.time.timestamp();
+    const timestamp: u32 = 0;
     const size_of_optional_header = @as(u16, @intCast(coff.getOptionalHeaderSize() + coff.getDataDirectoryHeadersSize()));
     var coff_header = coff_util.CoffHeader{
         .machine = target.toCoffMachine(),
         .number_of_sections = @as(u16, @intCast(coff.sections.slice().len)), // TODO what if we prune a section
-        .time_date_stamp = @as(u32, @truncate(@as(u64, @bitCast(timestamp)))),
+        .time_date_stamp = @as(u32, @truncate(@as(u32, @bitCast(timestamp)))),
         .pointer_to_symbol_table = coff.strtab_offset orelse 0,
         .number_of_symbols = 0,
         .size_of_optional_header = size_of_optional_header,
-- 
