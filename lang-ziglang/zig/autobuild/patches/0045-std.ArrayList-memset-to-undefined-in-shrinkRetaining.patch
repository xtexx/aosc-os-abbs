 fpr=7231804B052C670F15A6771DB918086ED8045B91

Fixes #25796

(cherry picked from commit 416bf1de47154ba781082163f8a3509fa3916482)
---
 lib/std/array_list.zig | 3 +++
 1 file changed, 3 insertions(+)

diff --git a/lib/std/array_list.zig b/lib/std/array_list.zig
index 6ccb3c54e3e3..ab5985685c14 100644
--- a/lib/std/array_list.zig
+++ b/lib/std/array_list.zig
@@ -414,11 +414,14 @@ pub fn AlignedManaged(comptime T: type, comptime alignment: ?mem.Alignment) type
         pub fn shrinkRetainingCapacity(self: *Self, new_len: usize) void {
             assert(new_len <= self.items.len);
             self.items.len = new_len;
+            @memset(self.items[new_len..], undefined);
         }
 
+        /// Reduce length to 0.
         /// Invalidates all element pointers.
         pub fn clearRetainingCapacity(self: *Self) void {
             self.items.len = 0;
+            @memset(self.items, undefined);
         }
 
         /// Invalidates all element pointers.
