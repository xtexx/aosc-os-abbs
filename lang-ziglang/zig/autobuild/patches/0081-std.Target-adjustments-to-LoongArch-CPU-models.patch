Subject: [PATCH 81/87] std.Target: adjustments to LoongArch CPU models
X-Developer-Signature: v=1; a=openpgp-sha256; l=4457; i=xtexchooser@duck.com;
 h=from:subject; bh=0z0HzisiUBy/jyqqAoYlxacRMFBhOXCaE4Hp9nrqlss=;
 b=owGbwMvMwCW2U4Ij7wZL9ETG02pJDJkmdi63WqUZlgZYmRmkPeFdPsl99gX3qnat5dfOOoT8l
 1DaLS7YUcrCIMbFICumyFJk2ODNqpPOL7qsXBZmDisTyBAGLk4BmIhgCCNDq6/hkRfXwxRqufQO
 FyzSZ388fUFJZe/n7lUhZeoTzKIFGBkO1EVk8B07L1qS6XYh4NCe11VsZ69OkDd4bT/54IGNFhG
 cAA==
X-Developer-Key: i=xtexchooser@duck.com; a=openpgp;
 fpr=7231804B052C670F15A6771DB918086ED8045B91

* Remove the generic model; we already have generic_la32 and generic_la64 and
  pick appropriately based on bitness.
* Remove the loongarch64 model. We used this as our baseline for 64-bit, but it's
  actually pretty misleading and useless; it doesn't represent any real CPU and
  has less features than generic_la64.
* Add la64v1_0 and la64v1_1 models.
* Change our baseline CPU model for 64-bit to be la64v1_0, thus adding LSX to
  the baseline feature set.

(cherry picked from commit 5e9e1fb0c85eacd412cb6cf4df14adc39f4c008a)
---
 lib/std/Target.zig            |  2 +-
 lib/std/Target/loongarch.zig  | 38 ++++++++++++++++++++++-------------
 tools/update_cpu_features.zig | 30 +++++++++++++++++++++++++++
 3 files changed, 55 insertions(+), 15 deletions(-)

diff --git a/lib/std/Target.zig b/lib/std/Target.zig
index 99e2a3af6125..72ab18cd0ca4 100644
--- a/lib/std/Target.zig
+++ b/lib/std/Target.zig
@@ -1849,7 +1849,7 @@ pub const Cpu = struct {
                 .csky => &csky.cpu.ck810, // gcc/clang do not have a generic csky model.
                 .hexagon => &hexagon.cpu.hexagonv68, // gcc/clang do not have a generic hexagon model.
                 .lanai => &lanai.cpu.v11, // clang does not have a generic lanai model.
-                .loongarch64 => &loongarch.cpu.loongarch64,
+                .loongarch64 => &loongarch.cpu.la64v1_0,
                 .m68k => &m68k.cpu.M68000,
                 .mips, .mipsel => &mips.cpu.mips32r2,
                 .mips64, .mips64el => &mips.cpu.mips64r2,
diff --git a/lib/std/Target/loongarch.zig b/lib/std/Target/loongarch.zig
index e70d5a7d03b9..cc49c1cd0063 100644
--- a/lib/std/Target/loongarch.zig
+++ b/lib/std/Target/loongarch.zig
@@ -151,11 +151,6 @@ pub const all_features = blk: {
 };
 
 pub const cpu = struct {
-    pub const generic: CpuModel = .{
-        .name = "generic",
-        .llvm_name = "generic",
-        .features = featureSet(&[_]Feature{}),
-    };
     pub const generic_la32: CpuModel = .{
         .name = "generic_la32",
         .llvm_name = "generic-la32",
@@ -183,6 +178,30 @@ pub const cpu = struct {
             .ual,
         }),
     };
+    pub const la64v1_0: CpuModel = .{
+        .name = "la64v1_0",
+        .llvm_name = null,
+        .features = featureSet(&[_]Feature{
+            .@"64bit",
+            .lsx,
+            .ual,
+        }),
+    };
+    pub const la64v1_1: CpuModel = .{
+        .name = "la64v1_1",
+        .llvm_name = null,
+        .features = featureSet(&[_]Feature{
+            .@"64bit",
+            .div32,
+            .frecipe,
+            .lam_bh,
+            .lamcas,
+            .ld_seq_sa,
+            .lsx,
+            .scq,
+            .ual,
+        }),
+    };
     pub const la664: CpuModel = .{
         .name = "la664",
         .llvm_name = "la664",
@@ -200,13 +219,4 @@ pub const cpu = struct {
             .ual,
         }),
     };
-    pub const loongarch64: CpuModel = .{
-        .name = "loongarch64",
-        .llvm_name = "loongarch64",
-        .features = featureSet(&[_]Feature{
-            .@"64bit",
-            .d,
-            .ual,
-        }),
-    };
 };
diff --git a/tools/update_cpu_features.zig b/tools/update_cpu_features.zig
index f9bbe857f1e9..18746bb0dda1 100644
--- a/tools/update_cpu_features.zig
+++ b/tools/update_cpu_features.zig
@@ -985,6 +985,36 @@ const targets = [_]ArchTarget{
             .name = "LoongArch",
             .td_name = "LoongArch",
         },
+        .extra_cpus = &.{
+            .{
+                .llvm_name = null,
+                .zig_name = "la64v1_0",
+                .features = &.{
+                    "64bit",
+                    "lsx",
+                    "ual",
+                },
+            },
+            .{
+                .llvm_name = null,
+                .zig_name = "la64v1_1",
+                .features = &.{
+                    "64bit",
+                    "div32",
+                    "frecipe",
+                    "lam_bh",
+                    "lamcas",
+                    "ld_seq_sa",
+                    "lsx",
+                    "scq",
+                    "ual",
+                },
+            },
+        },
+        .omit_cpus = &.{
+            "generic",
+            "loongarch64",
+        },
     },
     .{
         .zig_name = "m68k",
-- 
