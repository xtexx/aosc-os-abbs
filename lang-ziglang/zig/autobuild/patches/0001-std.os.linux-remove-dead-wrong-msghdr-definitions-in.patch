diff --git a/lib/std/os/linux/hexagon.zig b/lib/std/os/linux/hexagon.zig
index a3acbee50b2a..27015982a757 100644
--- a/lib/std/os/linux/hexagon.zig
+++ b/lib/std/os/linux/hexagon.zig
@@ -176,29 +176,11 @@ pub const Flock = extern struct {
     __unused: [4]u8,
 };
 
-pub const msghdr = extern struct {
-    name: ?*sockaddr,
-    namelen: socklen_t,
-    iov: [*]iovec,
-    iovlen: i32,
-    __pad1: i32 = 0,
-    control: ?*anyopaque,
-    controllen: socklen_t,
-    __pad2: socklen_t = 0,
-    flags: i32,
-};
+/// See c8efebcf53b2 (std.os.linux: remove dead/wrong msghdr definitions in some arch bits, 2025-10-09)
+pub const msghdr = @compileError("incorrect implementation removed");
 
-pub const msghdr_const = extern struct {
-    name: ?*const sockaddr,
-    namelen: socklen_t,
-    iov: [*]const iovec_const,
-    iovlen: i32,
-    __pad1: i32 = 0,
-    control: ?*const anyopaque,
-    controllen: socklen_t,
-    __pad2: socklen_t = 0,
-    flags: i32,
-};
+/// See c8efebcf53b2 (std.os.linux: remove dead/wrong msghdr definitions in some arch bits, 2025-10-09)
+pub const msghdr_const = @compileError("incorrect implementation removed");
 
 pub const blksize_t = i32;
 pub const nlink_t = u32;
