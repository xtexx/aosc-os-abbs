 h=from:subject; bh=EbFMZd9bDVGoEvPDfuuA28mxuRpkf6LalJiUSeEW68Q=;
 b=owGbwMvMwCW2U4Ij7wZL9ETG02pJDJkmdk4bd8/Vzk9evSw3Umnpt9XOCzb9u3Q+QfPw8fNOt
 8TbTNYnd5SyMIhxMciKKbIUGTZ4s+qk84suK5eFmcPKBDKEgYtTACbis4Dhv+vKmxPW759qLKZ5
 eoHxX4UZjlFlFzbPkDm6RyVwxuboBbUM/4PXmOV9LnbkLTmYutpbdcbCWTevvfmgYfBTn63vU/y
 u/0wA
X-Developer-Key: i=xtexchooser@duck.com; a=openpgp;
