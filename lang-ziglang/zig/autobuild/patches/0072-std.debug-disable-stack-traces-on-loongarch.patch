Observed to ~randomly crash during FP-based unwinding.

The path forward here will be DWARF-based unwinding.

(cherry picked from commit d8d0a3e5c77ccce33699d6c11a850d383a83c40d)
---
 lib/std/debug.zig | 2 ++
 1 file changed, 2 insertions(+)

diff --git a/lib/std/debug.zig b/lib/std/debug.zig
index 26ea76a9d5eb..797735d4b9a4 100644
--- a/lib/std/debug.zig
+++ b/lib/std/debug.zig
@@ -171,6 +171,8 @@ pub const runtime_safety = switch (builtin.mode) {
 pub const sys_can_stack_trace = switch (builtin.cpu.arch) {
     // Observed to go into an infinite loop.
     // TODO: Make this work.
+    .loongarch32,
+    .loongarch64,
     .mips,
     .mipsel,
     .mips64,
