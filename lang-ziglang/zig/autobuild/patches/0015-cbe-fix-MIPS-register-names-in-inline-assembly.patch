 fpr=7231804B052C670F15A6771DB918086ED8045B91

Zig uses "rN" for MIPS register clobbers which are more
ergonomic and easier to write (.rN vs. .@"$N").
However, GCC and Clang uses "$N".

Bug: #25613
Signed-off-by: Bingwu Zhang <xtex@xtexx.eu.org>
(cherry picked from commit 6de339d5d3deb4c7a1585288888f8e788e489eb6)
---
 crt.c             |  0
 src/codegen/c.zig | 14 ++++++++++++++
 2 files changed, 14 insertions(+)
 create mode 100644 crt.c

diff --git a/crt.c b/crt.c
new file mode 100644
index 000000000000..e69de29bb2d1
diff --git a/src/codegen/c.zig b/src/codegen/c.zig
index b67171835123..a33a2faf7c26 100644
--- a/src/codegen/c.zig
+++ b/src/codegen/c.zig
@@ -5770,6 +5770,20 @@ fn airAsm(f: *Function, inst: Air.Inst.Index) !CValue {
                 .bool_true => {
                     const name = struct_type.structFieldName(i, zcu).toSlice(ip).?;
                     assert(name.len != 0);
+
+                    const target = &f.object.dg.mod.resolved_target.result;
+                    if (target.cpu.arch.isMIPS() and name[0] == 'r') {
+                        // GCC uses "$N" for register names instead of "rN" used by Zig.
+                        var c_name_buf: [4]u8 = undefined;
+                        const c_name = (&c_name_buf)[0..name.len];
+                        @memcpy(c_name, name);
+                        c_name_buf[0] = '$';
+
+                        try w.print(" {f}", .{fmtStringLiteral(c_name, null)});
+                        (try w.writableArray(1))[0] = ',';
+                        continue;
+                    }
+
                     try w.print(" {f}", .{fmtStringLiteral(name, null)});
                     (try w.writableArray(1))[0] = ',';
                 },
