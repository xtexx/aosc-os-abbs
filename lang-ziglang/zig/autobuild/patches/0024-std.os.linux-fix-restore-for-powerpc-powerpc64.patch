sigreturn and rt_sigreturn are distinct syscalls on PowerPC.

(cherry picked from commit b2bc44e0d5e5edde083ec281aa0575b16478d881)
---
 lib/std/os/linux/powerpc.zig   | 16 +++++++++++++++-
 lib/std/os/linux/powerpc64.zig | 16 +++++++++++++++-
 2 files changed, 30 insertions(+), 2 deletions(-)

diff --git a/lib/std/os/linux/powerpc.zig b/lib/std/os/linux/powerpc.zig
index 94d7a7b8347c..87763b6515e1 100644
--- a/lib/std/os/linux/powerpc.zig
+++ b/lib/std/os/linux/powerpc.zig
@@ -244,7 +244,21 @@ pub fn clone() callconv(.naked) usize {
     );
 }
 
-pub const restore = restore_rt;
+pub fn restore() callconv(.naked) noreturn {
+    switch (builtin.zig_backend) {
+        .stage2_c => asm volatile (
+            \\ li 0, %[number]
+            \\ sc
+            :
+            : [number] "i" (@intFromEnum(SYS.sigreturn)),
+        ),
+        else => asm volatile (
+            \\ sc
+            :
+            : [number] "{r0}" (@intFromEnum(SYS.sigreturn)),
+        ),
+    }
+}
 
 pub fn restore_rt() callconv(.naked) noreturn {
     switch (@import("builtin").zig_backend) {
diff --git a/lib/std/os/linux/powerpc64.zig b/lib/std/os/linux/powerpc64.zig
index ed648a3a0aa7..cd2d927de1a5 100644
--- a/lib/std/os/linux/powerpc64.zig
+++ b/lib/std/os/linux/powerpc64.zig
@@ -229,7 +229,21 @@ pub fn clone() callconv(.naked) usize {
     );
 }
 
-pub const restore = restore_rt;
+pub fn restore() callconv(.naked) noreturn {
+    switch (builtin.zig_backend) {
+        .stage2_c => asm volatile (
+            \\ li 0, %[number]
+            \\ sc
+            :
+            : [number] "i" (@intFromEnum(SYS.sigreturn)),
+        ),
+        else => asm volatile (
+            \\ sc
+            :
+            : [number] "{r0}" (@intFromEnum(SYS.sigreturn)),
+        ),
+    }
+}
 
 pub fn restore_rt() callconv(.naked) noreturn {
     switch (@import("builtin").zig_backend) {
