From 666aee5e47c6c13cf85a6df820c163ee6c936c83 Mon Sep 17 00:00:00 2001
From: Mingcong Bai <jeffbai@aosc.io>
Date: Tue, 11 Nov 2025 19:05:19 +0800
Subject: [PATCH 346/346] AOSCOS: x86/cpu: centaur: disable AVX on
 KX-6000/6000G

The AVX implementation on at least Zhaoxin KaiXian KX-6000/6000G series of
processors is known to be underperforming and buggy (when it comes to
cryptographic operations).

Zhaoxin KaiXian KX-6000/6000G identifies as CentaurHauls.

Signed-off-by: Mingcong Bai <jeffbai@aosc.io>
---
 arch/x86/kernel/cpu/centaur.c | 8 ++++++++
 1 file changed, 8 insertions(+)

diff --git a/arch/x86/kernel/cpu/centaur.c b/arch/x86/kernel/cpu/centaur.c
index a3b55db35c961..6bab4bfe76926 100644
--- a/arch/x86/kernel/cpu/centaur.c
+++ b/arch/x86/kernel/cpu/centaur.c
@@ -109,6 +109,14 @@ static void early_init_centaur(struct cpuinfo_x86 *c)
 		set_cpu_cap(c, X86_FEATURE_CONSTANT_TSC);
 		set_cpu_cap(c, X86_FEATURE_NONSTOP_TSC);
 	}
+
+	/* The AVX implementation on at least Zhaoxin KaiXian KX-6000/6000G
+	 * series of processors is known to be underperforming and buggy (when
+	 * it comes to cryptographic operations).
+	 *
+	 * Zhaoxin KX-6000/6000G identifies as CentaurHauls. */
+	if (c->x86 == 0x7 && c->x86_model == 0x59)
+		setup_clear_cpu_cap(X86_FEATURE_AVX);
 }
 
 static void init_centaur(struct cpuinfo_x86 *c)
-- 
2.51.1

