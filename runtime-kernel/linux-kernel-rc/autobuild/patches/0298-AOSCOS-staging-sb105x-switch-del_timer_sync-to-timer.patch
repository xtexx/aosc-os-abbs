From 6738f29d80958a9ecf47b1df569865157dd82cfb Mon Sep 17 00:00:00 2001
From: Kexy Biscuit <kexybiscuit@aosc.io>
Date: Tue, 22 Apr 2025 04:12:05 +0800
Subject: [PATCH 298/299] AOSCOS: staging: sb105x: switch del_timer_sync to
 timer_delete_sync

Following upstream name changes.

Fixes: 8fa7292fee5c ("treewide: Switch/rename to timer_delete[_sync]()")
Fixes: "AOSCOS: Revert "staging: sb105x: delete the driver""
Signed-off-by: Kexy Biscuit <kexybiscuit@aosc.io>
---
 drivers/staging/sb105x/sb_pci_mp.c | 2 +-
 1 file changed, 1 insertion(+), 1 deletion(-)

diff --git a/drivers/staging/sb105x/sb_pci_mp.c b/drivers/staging/sb105x/sb_pci_mp.c
index 19098bbfa113..fbc0af14128d 100644
--- a/drivers/staging/sb105x/sb_pci_mp.c
+++ b/drivers/staging/sb105x/sb_pci_mp.c
@@ -2481,7 +2481,7 @@ static void multi_shutdown(struct sb_uart_port *port)
 
 	if ((!is_real_interrupt(mtpt->port.irq))||(mtpt->poll_type==TYPE_POLL))
 	{
-		del_timer_sync(&mtpt->timer);
+		timer_delete_sync(&mtpt->timer);
 	}
 	else
 	{
