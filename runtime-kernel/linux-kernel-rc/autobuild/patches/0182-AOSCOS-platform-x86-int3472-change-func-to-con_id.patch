From f58a0fa42a363a93c56f6b46ea6dfced79f48940 Mon Sep 17 00:00:00 2001
From: Kexy Biscuit <kexybiscuit@aosc.io>
Date: Tue, 22 Apr 2025 04:19:18 +0800
Subject: [PATCH 182/305] AOSCOS: platform/x86: int3472: change func to con_id

Following upstream name changes.

Fixes: 81b251c66bdf ("platform/x86: int3472: Call "func" "con_id" instead")
Fixes: "SURFACE: platform/x86: int3472: Remap reset GPIO for INT347E"
Signed-off-by: Kexy Biscuit <kexybiscuit@aosc.io>
---
 drivers/platform/x86/intel/int3472/discrete.c | 4 ++--
 1 file changed, 2 insertions(+), 2 deletions(-)

diff --git a/drivers/platform/x86/intel/int3472/discrete.c b/drivers/platform/x86/intel/int3472/discrete.c
index 18baf1bf79b99..8485067f4c0ab 100644
--- a/drivers/platform/x86/intel/int3472/discrete.c
+++ b/drivers/platform/x86/intel/int3472/discrete.c
@@ -97,8 +97,8 @@ static int skl_int3472_map_gpio_to_sensor(struct int3472_discrete_device *int347
 	 * expects its only GPIO pin to be called "enable" (and to have the
 	 * opposite polarity).
 	 */
-	if (!strcmp(func, "reset") && !acpi_match_device_ids(int3472->sensor, ov7251_ids)) {
-		func = "enable";
+	if (!strcmp(con_id, "reset") && !acpi_match_device_ids(int3472->sensor, ov7251_ids)) {
+		con_id = "enable";
 		gpio_flags ^= GPIO_ACTIVE_LOW;
 	}
 
-- 
2.49.0

