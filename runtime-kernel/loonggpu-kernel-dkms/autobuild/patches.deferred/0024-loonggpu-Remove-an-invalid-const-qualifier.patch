From 5baab7ea58b175c8f12487572769765e34b299f5 Mon Sep 17 00:00:00 2001
From: Xi Ruoyao <xry111@xry111.site>
Date: Tue, 24 Jun 2025 14:24:23 +0800
Subject: [PATCH 24/49] loonggpu: Remove an invalid "const" qualifier

You obviously cannot sprintf things into a const char array!

Signed-off-by: Xi Ruoyao <xry111@xry111.site>
Signed-off-by: Mingcong Bai <jeffbai@aosc.io>
---
 loonggpu/loonggpu_backlight.c | 2 +-
 1 file changed, 1 insertion(+), 1 deletion(-)

diff --git a/loonggpu/loonggpu_backlight.c b/loonggpu/loonggpu_backlight.c
index ad2f2cd..a55a591 100644
--- a/loonggpu/loonggpu_backlight.c
+++ b/loonggpu/loonggpu_backlight.c
@@ -258,7 +258,7 @@ static int loonggpu_backlight_hw_request_init(struct loonggpu_backlight *ls_bl)
 	bool pwm_enable_default;
 	struct pwm_state state;
 	struct loonggpu_device *adev = ls_bl->driver_private;
-	char pwm_name[10];
+	char pwm_name[16];
 
 	sprintf(pwm_name, "pwm%d", ls_bl->pwm_id);
 	ls_bl->pwm = lg_pwm_request(adev->ddev->dev, pwm_name, ls_bl->pwm_id, "Loongson_bl");
-- 
2.52.0

