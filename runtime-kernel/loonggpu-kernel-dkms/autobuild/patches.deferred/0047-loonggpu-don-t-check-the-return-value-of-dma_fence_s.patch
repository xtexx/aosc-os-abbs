From d777546bdc6f51f00e8cd71b12b4cfa58c83d713 Mon Sep 17 00:00:00 2001
From: Xi Ruoyao <xry111@xry111.site>
Date: Sat, 28 Feb 2026 23:43:21 +0800
Subject: [PATCH 47/49] loonggpu: don't check the return value of
 dma_fence_signal

Linux 7.0-rc1 has changed the function to return void.  If we really
need to check the return value, we'd use dma_fence_check_and_signal
instead.  But as we'll BUG() if the call fails, it seems we don't
really need the return value.

Link: https://git.kernel.org/torvalds/c/88e721ab978a
Signed-off-by: Xi Ruoyao <xry111@xry111.site>
Signed-off-by: Mingcong Bai <jeffbai@aosc.io>
---
 loonggpu/loonggpu_fence.c | 10 +---------
 1 file changed, 1 insertion(+), 9 deletions(-)

diff --git a/loonggpu/loonggpu_fence.c b/loonggpu/loonggpu_fence.c
index ba33884..c063a42 100644
--- a/loonggpu/loonggpu_fence.c
+++ b/loonggpu/loonggpu_fence.c
@@ -203,7 +203,6 @@ void loonggpu_fence_process(struct loonggpu_ring *ring)
 {
 	struct loonggpu_fence_driver *drv = &ring->fence_drv;
 	uint32_t seq, last_seq;
-	int r;
 
 	do {
 		last_seq = atomic_read(&ring->fence_drv.last_seq);
@@ -234,14 +233,7 @@ void loonggpu_fence_process(struct loonggpu_ring *ring)
 		if (!fence)
 			continue;
 
-		r = dma_fence_signal(fence);
-		if (!r) {
-		#if defined(DMA_FENCE_TRACE)
-			DMA_FENCE_TRACE(fence, "signaled from irq context\n");
-		#endif
-		} else
-			BUG();
-
+		dma_fence_signal(fence);
 		dma_fence_put(fence);
 	} while (last_seq != seq);
 }
-- 
