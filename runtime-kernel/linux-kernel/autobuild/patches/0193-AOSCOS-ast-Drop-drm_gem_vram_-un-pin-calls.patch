From 9e082a29455a7afed6ae44f6f6596195c27455df Mon Sep 17 00:00:00 2001
From: Xi Ruoyao <xry111@xry111.site>
Date: Tue, 26 Aug 2025 19:01:09 +0800
Subject: [PATCH 193/466] AOSCOS: ast: Drop drm_gem_vram_{,un}pin calls

If I read the upstream commit 62e1e11a4916
("drm/client: Do not pin in drm_client_buffer_vmap()") correctly, we
don't need to call those two removed functions.

Fixes: "LOONGSON: drm/ast: Support both SHMEM helper and VRAM helper"
Signed-off-by: Xi Ruoyao <xry111@xry111.site>
Signed-off-by: Mingcong Bai <jeffbai@aosc.io>
---
 drivers/gpu/drm/ast/ast_cursor.c | 2 --
 1 file changed, 2 deletions(-)

diff --git a/drivers/gpu/drm/ast/ast_cursor.c b/drivers/gpu/drm/ast/ast_cursor.c
index 54c0d4e3ed81f..9921bd6c0d28b 100644
--- a/drivers/gpu/drm/ast/ast_cursor.c
+++ b/drivers/gpu/drm/ast/ast_cursor.c
@@ -285,7 +285,6 @@ static void ast_cursor_plane_destroy(struct drm_plane *plane)
 	struct iosys_map map = ast_plane->map;
 
 	drm_gem_vram_vunmap(gbo, &map);
-	drm_gem_vram_unpin(gbo);
 	drm_gem_vram_put(gbo);
 
 	drm_plane_cleanup(plane);
@@ -325,7 +324,6 @@ int ast_cursor_plane_init(struct ast_device *ast)
 		if (IS_ERR(gbo))
 			return PTR_ERR(gbo);
 
-		drm_gem_vram_pin(gbo, DRM_GEM_VRAM_PL_FLAG_VRAM | DRM_GEM_VRAM_PL_FLAG_TOPDOWN);
 		drm_gem_vram_vmap(gbo, &map);
 		offset = drm_gem_vram_offset(gbo);
 		ast_cursor_plane->base.gbo = gbo;
-- 
2.52.0

