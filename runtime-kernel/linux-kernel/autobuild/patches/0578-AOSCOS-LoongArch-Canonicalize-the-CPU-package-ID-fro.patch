From 946a55cff724f886941dcfe0e07403e81cf8329e Mon Sep 17 00:00:00 2001
From: Xi Ruoyao <xry111@xry111.site>
Date: Wed, 27 May 2026 14:16:36 +0800
Subject: [PATCH 578/586] AOSCOS: LoongArch: Canonicalize the CPU package ID
 from PPTT

The return value of find_acpi_cpu_topology_package() is the index of the
node describing the package in the PPTT.  But some code paths retrieving
package ID from cpu_data[], for example, loongson3_cpufreq, expects an
integer in [0, MAX_PACKAGES).

Make parse_acpi_topology() canonicalize the package ID filled into
cpu_data[] to match the expectation.

Signed-off-by: Xi Ruoyao <xry111@xry111.site>
---
 arch/loongarch/kernel/acpi.c | 19 ++++++++++++++++++-
 1 file changed, 18 insertions(+), 1 deletion(-)

diff --git a/arch/loongarch/kernel/acpi.c b/arch/loongarch/kernel/acpi.c
index 82c7ffd4f1ac6..23a3c88e3da4e 100644
--- a/arch/loongarch/kernel/acpi.c
+++ b/arch/loongarch/kernel/acpi.c
@@ -176,7 +176,8 @@ int pptt_enabled;
 
 int __init parse_acpi_topology(void)
 {
-	int cpu, topology_id, package_id;
+	int cpu, topology_id, package_id, i;
+	int package_acpi_ids[MAX_PACKAGES], nr_packages = 0;
 
 	for_each_possible_cpu(cpu) {
 		topology_id = find_acpi_cpu_topology(cpu, 0);
@@ -200,9 +201,25 @@ int __init parse_acpi_topology(void)
 			pr_warn("Invalid BIOS PPTT\n");
 			return -ENOENT;
 		}
+
+		for (i = 0; i < nr_packages; i++)
+			if (package_acpi_ids[i] == package_id)
+				break;
+
+		if (i == nr_packages)
+			package_acpi_ids[nr_packages++] = package_id;
+
 		cpu_data[cpu].package = package_id;
 	}
 
+	for_each_possible_cpu(cpu) {
+		for (int i = 0; i < nr_packages; i++)
+			if (cpu_data[cpu].package == package_acpi_ids[i]) {
+				cpu_data[cpu].package = i;
+				break;
+			}
+	}
+
 	pptt_enabled = 1;
 
 	return 0;
-- 
