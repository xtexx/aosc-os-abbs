From: Ayufan <ayufan@ayufan.eu>
Date: Sun, 30 Dec 2018 13:32:47 +0100
Subject: [PATCH 178/373] ARMBIAN: ayufan: dts: rockpro64: change rx_delay for
 gmac

Change-Id: Ib3899f684188aa1ed1545717af004bba53fe0e07

Signed-off-by: Ayufan <ayufan@ayufan.eu>
Link: https://github.com/armbian/build/blob/dda6950c34f51e167811aee6d0ec220a492aac1a/patch/kernel/archive/rockchip64-6.16/board-rockpro64-change-rx_delay-for-gmac.patch
Signed-off-by: Kexy Biscuit <kexybiscuit@aosc.io>
---
 arch/arm64/boot/dts/rockchip/rk3399-rockpro64.dtsi | 2 +-
 1 file changed, 1 insertion(+), 1 deletion(-)

diff --git a/arch/arm64/boot/dts/rockchip/rk3399-rockpro64.dtsi b/arch/arm64/boot/dts/rockchip/rk3399-rockpro64.dtsi
index a7e4adf87e7a..3bbe2367e686 100644
--- a/arch/arm64/boot/dts/rockchip/rk3399-rockpro64.dtsi
+++ b/arch/arm64/boot/dts/rockchip/rk3399-rockpro64.dtsi
@@ -317,7 +317,7 @@ &gmac {
 	snps,reset-active-low;
 	snps,reset-delays-us = <0 10000 50000>;
 	tx_delay = <0x28>;
-	rx_delay = <0x11>;
+	rx_delay = <0x20>;
 	status = "okay";
 };
 
