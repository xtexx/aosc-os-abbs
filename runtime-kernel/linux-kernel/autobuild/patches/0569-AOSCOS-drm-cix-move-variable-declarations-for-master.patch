From 0810b44aa32c76373f50449182c4ab9b03677baa Mon Sep 17 00:00:00 2001
From: Mingcong Bai <jeffbai@aosc.io>
Date: Fri, 15 May 2026 16:30:40 +0800
Subject: [PATCH 569/586] AOSCOS: drm: cix: move variable declarations for
 {master,slave}_valid_w inside SBS_NO_OVERLAP_SCALING
MIME-Version: 1.0
Content-Type: text/plain; charset=UTF-8
Content-Transfer-Encoding: 8bit

Whilst building with CONFIG_WERROR enabled, the following error occurs:

  drivers/gpu/drm/cix/linlon-dp/linlondp_pipeline_state.c: In function ‘linlondp_split_sbs_master_data_flow’:
  drivers/gpu/drm/cix/linlon-dp/linlondp_pipeline_state.c:1246:37: error: variable ‘slave_valid_w’ set but not used [-Werror=unused-but-set-variable]
   1246 |                 u32 master_valid_w, slave_valid_w;
        |
  drivers/gpu/drm/cix/linlon-dp/linlondp_pipeline_state.c:1246:21: error: variable ‘master_valid_w’ set but not used [-Werror=unused-but-set-variable]
   1246 |                 u32 master_valid_w, slave_valid_w;
        |

Move declarations for these variables inside the ifdef-guard for
SBS_NO_OVERLAP_SCALING.

Fixes: "CIXTECH: drm: add cix linlon dp driver"
Link: https://github.com/cixtech/cix-linux-main/issues/26
Signed-off-by: Mingcong Bai <jeffbai@aosc.io>
---
 drivers/gpu/drm/cix/linlon-dp/linlondp_pipeline_state.c | 7 +++----
 1 file changed, 3 insertions(+), 4 deletions(-)

diff --git a/drivers/gpu/drm/cix/linlon-dp/linlondp_pipeline_state.c b/drivers/gpu/drm/cix/linlon-dp/linlondp_pipeline_state.c
index e0e3547116d69..ccbdc4606df0f 100644
--- a/drivers/gpu/drm/cix/linlon-dp/linlondp_pipeline_state.c
+++ b/drivers/gpu/drm/cix/linlon-dp/linlondp_pipeline_state.c
@@ -1243,7 +1243,6 @@ linlondp_split_sbs_master_data_flow(struct linlondp_crtc_state *kcrtc_st,
 		u32 src_y = master->in_y;
 		u32 src_w = master->in_w;
 		u32 src_h = master->in_h;
-		u32 master_valid_w, slave_valid_w;
 		u32 h_scaling_ratio = 0;
 
 #ifdef SBS_NO_OVERLAP_SCALING
@@ -1272,13 +1271,13 @@ linlondp_split_sbs_master_data_flow(struct linlondp_crtc_state *kcrtc_st,
 		slave->out_w = disp_end - boundary;
 		slave->out_x = 0;
 
+#ifdef SBS_NO_OVERLAP_SCALING
 		/* When overlap is needed, ensure we don't fetch outside of the
 		 * layer when adding the overlap
 		 */
-		master_valid_w = master->out_w;
-		slave_valid_w = slave->out_w;
+		u32 master_valid_w = master->out_w;
+		u32 slave_valid_w = slave->out_w;
 
-#ifdef SBS_NO_OVERLAP_SCALING
 		master->out_w += min(kcrtc->sbs_overlap, slave_valid_w);
 		slave->out_w += min(kcrtc->sbs_overlap, master_valid_w);
 #endif
-- 
2.52.0

