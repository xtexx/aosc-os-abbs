From 4931cdba2e1f940b4ea74a7c44acdfd4ce3e4927 Mon Sep 17 00:00:00 2001
From: Mingcong Bai <jeffbai@aosc.io>
Date: Sat, 16 May 2026 17:38:34 +0800
Subject: [PATCH 573/587] AOSCOS: drm: cix: drop unused linlondp_gop_set
MIME-Version: 1.0
Content-Type: text/plain; charset=UTF-8
Content-Transfer-Encoding: 8bit

When building with CONFIG_WERROR, the following error occurs:

  drivers/gpu/drm/cix/linlon-dp/linlondp_dev.c:623:13: error: ‘linlondp_gop_set’ defined but not used [-Werror=unused-function]
  623 | static void linlondp_gop_set(void)
      |             ^~~~~~~~~~~~~~~~

Remove this function to fix build.

Fixes: "CIXTECH: drm: add cix linlon dp driver"
Link: https://github.com/cixtech/cix-linux-main/issues/26
Signed-off-by: Mingcong Bai <jeffbai@aosc.io>
---
 drivers/gpu/drm/cix/linlon-dp/linlondp_dev.c | 9 ---------
 1 file changed, 9 deletions(-)

diff --git a/drivers/gpu/drm/cix/linlon-dp/linlondp_dev.c b/drivers/gpu/drm/cix/linlon-dp/linlondp_dev.c
index 8abc6c98c1573..1104a912e4de6 100644
--- a/drivers/gpu/drm/cix/linlon-dp/linlondp_dev.c
+++ b/drivers/gpu/drm/cix/linlon-dp/linlondp_dev.c
@@ -620,15 +620,6 @@ static int linlondp_gop_get(void)
 	return enabled_by_gop;
 }
 
-static void linlondp_gop_set(void)
-{
-	struct arm_smccc_res res;
-	int dpu_gop_bit = 1;
-
-	arm_smccc_smc(CIX_SIP_DP_GOP_CTRL, SKY1_SIP_DP_GOP_SET,
-		      dpu_gop_bit << DPU_GOP_SHIFT, 0, 0, 0, 0, 0, &res);
-}
-
 struct linlondp_dev *linlondp_dev_create(struct device *dev)
 {
 	struct platform_device *pdev = to_platform_device(dev);
-- 
2.52.0

