From b55bead11c16b24c3357c80551c9662038735d16 Mon Sep 17 00:00:00 2001
From: Mingcong Bai <jeffbai@aosc.io>
Date: Thu, 30 Apr 2026 10:38:11 +0800
Subject: [PATCH 465/466] AOSCOS: stmmac: stmmac-phytium: fix build against
 post-6.18.16 changes to `struct stmmac_resources'

Struct member `lpi_irq' was removed by commit d8a286503553 ("net: stmmac:
remove support for lpi_intr_o"). Remove reference to this struct member to
fix build.

Signed-off-by: Mingcong Bai <jeffbai@aosc.io>
---
 drivers/net/ethernet/stmicro/stmmac/dwmac-phytium.c | 1 -
 1 file changed, 1 deletion(-)

diff --git a/drivers/net/ethernet/stmicro/stmmac/dwmac-phytium.c b/drivers/net/ethernet/stmicro/stmmac/dwmac-phytium.c
index 36ef7b535983b..18950063f3720 100644
--- a/drivers/net/ethernet/stmicro/stmmac/dwmac-phytium.c
+++ b/drivers/net/ethernet/stmicro/stmmac/dwmac-phytium.c
@@ -193,7 +193,6 @@ static int phytium_dwmac_probe(struct platform_device *pdev)
 		return -ENXIO;
 	}
 	stmmac_res.wol_irq = stmmac_res.irq;
-	stmmac_res.lpi_irq = -1;
 
 	return  stmmac_dvr_probe(&pdev->dev, plat, &stmmac_res);
 }
-- 
2.52.0

