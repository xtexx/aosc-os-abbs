--- a/drivers/phy/Makefile
+++ b/drivers/phy/Makefile
@@ -46,5 +46,6 @@ obj-$(CONFIG_GENERIC_PHY)		+= allwinner/	\
 					   starfive/	\
 					   sunplus/	\
