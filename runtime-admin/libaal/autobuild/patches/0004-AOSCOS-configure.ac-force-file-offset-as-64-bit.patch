From 503ff74f89b4867c384faf0fa4764b7872dfbcaa Mon Sep 17 00:00:00 2001
From: Mingcong Bai <jeffbai@aosc.io>
Date: Mon, 12 May 2025 10:45:29 +0800
Subject: [PATCH 4/4] AOSCOS: configure.ac: force file offset as 64-bit

The original check fails when file offset is already at 64-bit. Set it to
64-bit unconditionally as this is what we do anyway.

Signed-off-by: Mingcong Bai <jeffbai@aosc.io>
---
 configure.ac | 8 +-------
 1 file changed, 1 insertion(+), 7 deletions(-)

diff --git a/configure.ac b/configure.ac
index 705b5db..a68bdef 100644
--- a/configure.ac
+++ b/configure.ac
@@ -137,13 +137,7 @@ GENERIC_CFLAGS=""
 
 GENERIC_CFLAGS="$GENERIC_CFLAGS -D_REENTRANT"
 
-AC_SYS_LARGEFILE
-if test x${ac_cv_sys_file_offset_bits} = xno; then
-	AC_MSG_WARN(Can't detect right _FILE_OFFSET_BITS. Will be forced to 64bit.)
-	ac_cv_sys_file_offset_bits=64
-fi
-
-GENERIC_CFLAGS="$GENERIC_CFLAGS -D_FILE_OFFSET_BITS=${ac_cv_sys_file_offset_bits}"
+GENERIC_CFLAGS="$GENERIC_CFLAGS -D_FILE_OFFSET_BITS=64"
 
 AC_CHECK_SIZEOF(off_t, 64, [
 	#include <stdio.h>
-- 
2.49.0

