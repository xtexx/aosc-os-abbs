CABAL="qemu-x86_64-static ""$SRCDIR""/../cabal-3.16.1.0"
chmod +x "$SRCDIR"/../cabal-3.16.1.0

abinfo "Building Cabal using prebuilt Cabal ..."
$CABAL update
$CABAL v2-build -j \
	--prefix=/usr \
	--project-file=cabal.release.project \
	--allow-newer \
	cabal-install

abinfo "Installing Cabal ..."
$CABAL v2-install -j \
	--install-method=copy \
	--installdir="$PKGDIR"/usr/bin \
	--project-file=cabal.release.project \
	--allow-newer \
	cabal-install
