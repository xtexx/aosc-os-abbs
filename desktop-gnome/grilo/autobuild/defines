PKGNAME=grilo
PKGSEC=gnome
PKGDEP="gtk-3 libxml2 libsoup-3 liboauth totem-pl-parser lua-5.4"
PKGSUG="grilo-plugins"
BUILDDEP="gobject-introspection vala"
PKGDES="Framework to provide access to various sources of multimedia content"

MESON_AFTER=(
    '-Denable-grl-net=true'
    '-Denable-grl-pls=true'
    '-Denable-gtk-doc=false'
    '-Denable-introspection=true'
    '-Denable-test-ui=false'
    '-Denable-vala=true'
    '-Dsoup3=true'
)
