PKGNAME=gnome-keyring
PKGSEC=gnome
PKGDEP="gcc-runtime gcr glib glibc libcap-ng libgcrypt linux-pam systemd"
BUILDDEP="gtk-doc meson"
PKGDES="GNOME password management daemon"

ABTYPE=meson
MESON_AFTER=(
	'-Dssh-agent=true'
	'-Dselinux=disabled'
	'-Dsystemd=enabled'
	'-Dpam=true'
	'-Dpkcs11-config=/usr/share/p11-kit/modules'
	'-Ddebug-mode=false'
	'-Dmanpage=true'
)
