PKGNAME=sysprof
PKGSEC=gnome
PKGDEP="cairo elfutils desktop-file-utils gcc-runtime glib glibc graphene \
        gtk-4 gtk-update-icon-cache json-glib libadwaita libdex libpanel \
        libunwind pango polkit systemd"
BUILDDEP="itstool meson ninja yelp-tools"
PKGDES="A statistical and system-wide profiler"

MESON_AFTER=(
    '-Dgtk=true'
    '-Dinstall-static=true'
    '-Dpolkit-agent=enabled'
    '-Dlibsysprof=true'
    '-Dhelp=true'
    '-Dtools=true'
    '-Dtests=true'
    '-Dexamples=true'
    '-Ddebuginfod=enabled'
    '-Dintrospection=enabled'
)

NOSTATIC=0
NOLTO=1
