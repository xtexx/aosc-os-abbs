PKGNAME=gtk-2
PKGSEC=x11
PKGDEP="at-spi2-core cairo gdk-pixbuf pango shared-mime-info"
PKGSUG="python-3"
# Note: gtk-doc is needed for reconfiguration.
BUILDDEP="gobject-introspection gtk-doc"
PKGDES="GIMP toolkit version 2"

ABTYPE=autotools
AUTOTOOLS_AFTER=(
    '--with-xinput=yes'
    '--disable-gtk-doc'
)
AUTOTOOLS_AFTER__RETRO=(
    "${AUTOTOOLS_AFTER[@]}"
    '--disable-introspection'
)

# Note: Extra Provides for Spiral (Debian compatibility).
PKGPROV="libgtk2.0-0_spiral libgtk2.0-dev_spiral"
