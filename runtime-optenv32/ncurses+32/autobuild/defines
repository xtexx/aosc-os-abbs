PKGNAME=ncurses+32
PKGSEC=libs
PKGDEP="aosc-aaa+32 glibc+32"
BUILDDEP="devel-base+32"
PKGDES="Library to create terminal user interfaces (32-bit x86 runtime)"

ABTYPE=autotools
# FIXME: Re-configuration fails.
#
# configure.in:2671: error: possibly undefined macro: AC_SETUP_DEFS
#       If this token and others are legitimate, please use m4_pattern_allow.
#       See the Autoconf documentation.
RECONF=0

AUTOTOOLS_AFTER=(
    '--with-pkg-config-libdir=/opt/32/lib/pkgconfig'
    '--with-shared'
    # Note: Disable static libraries.
    '--without-normal'
    '--without-debug'
    '--without-ada'
    '--enable-widec'
    '--enable-pc-files'
    '--with-cxx-binding'
    '--with-cxx-shared'
    '--without-gpm'
    '--enable-ext-colors'
    '--with-versioned-syms'
)

ABHOST=optenv32
