abinfo "Configuring FFmpeg ..."
CONFIGURE_OPTIONS=(
    '--prefix=/opt/32'
    '--disable-debug'
    '--disable-static'
    '--disable-stripping'
    '--disable-doc'
    '--disable-avisynth'
    '--enable-bsfs'
    '--enable-fontconfig'
    '--enable-gnutls'
    '--enable-gpl'
    '--enable-libass'
    '--enable-libbluray'
    '--enable-libfreetype'
    '--enable-libharfbuzz'
    '--enable-libfribidi'
    '--enable-libgsm'
    '--enable-libmodplug'
    '--enable-libmp3lame'
    '--enable-libopencore_amrnb'
    '--enable-libopencore_amrwb'
    '--enable-libopus'
    '--enable-libpulse'
    '--enable-libsoxr'
    '--enable-libspeex'
    '--enable-libssh'
    '--enable-libtheora'
    '--enable-libv4l2'
    '--enable-libvorbis'
    '--enable-libvpx'
    '--enable-libx264'
    '--enable-libx265'
    '--enable-libxml2'
    '--enable-libxvid'
    '--enable-runtime-cpudetect'
    '--enable-shared'
    '--enable-swresample'
    '--enable-vdpau'
    '--enable-version3'
    '--enable-vaapi'
    '--disable-libaom'
    '--enable-libwebp'
)

"$SRCDIR"/configure \
    "${CONFIGURE_OPTIONS[@]}"

abinfo "Building FFmpeg ..."
make

abinfo "Install FFmpeg ..."
make install \
    DESTDIR="$PKGDIR"
