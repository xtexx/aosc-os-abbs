abinfo Installing desktop files...
desktop-file-install \
  --dir "$PKGDIR"/usr/share/applications \
  "$SRCDIR"/syncplay/resources/*.desktop

abinfo Installing icons...
for size in 256 128 96 64 48 32 24 16; do
  install -Dvm 0644 \
    "$SRCDIR"/syncplay/resources/hicolor/${size}x${size}/apps/syncplay.png \
    "$PKGDIR"/usr/share/icons/hicolor/${size}x${size}/apps/syncplay.png
done

abinfo Installing man pages
install -Dvm 0644 "$SRCDIR"/docs/syncplay.1 "$PKGDIR"/usr/share/man/man1/syncplay.1
install -Dvm 0644 "$SRCDIR"/docs/syncplay-server.1 $PKGDIR/usr/share/man/man1/syncplay-server.1
