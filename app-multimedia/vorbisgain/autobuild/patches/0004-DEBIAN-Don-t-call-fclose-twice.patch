Subject: [PATCH 04/10] DEBIAN: Don't call fclose() twice

Link: http://bugs.debian.org/cgi-bin/bugreport.cgi?bug=632947
Signed-off-by: Mingcong Bai <jeffbai@aosc.io>
---
 vorbis.c | 5 -----
 1 file changed, 5 deletions(-)

diff --git a/vorbis.c b/vorbis.c
index 3e1d4a4..9ef445a 100644
--- a/vorbis.c
+++ b/vorbis.c
@@ -811,11 +811,6 @@ exit:
         fclose(infile);
     }
 
-    if (infile != NULL)
-    {
-        fclose(infile);
-    }
-
     if (delete_temp)
     {
         if (remove(TEMP_NAME) != 0)
