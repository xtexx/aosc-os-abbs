From 3be2c6c22aab9cbc62e0bc4ad5bd603b6228febc Mon Sep 17 00:00:00 2001
From: =?UTF-8?q?Daniel=20Mart=C3=AD?= <danielmarti.debian@gmail.com>
Date: Sun, 7 Jun 2026 01:25:38 +0800
Subject: [PATCH 07/10] DEBIAN: The manpage shows methods that don't work

They have been replaced.

Link: http://bugs.debian.org/cgi-bin/bugreport.cgi?bug=447402
Signed-off-by: Mingcong Bai <jeffbai@aosc.io>
---
 vorbisgain.1 | 4 ++--
 1 file changed, 2 insertions(+), 2 deletions(-)

diff --git a/vorbisgain.1 b/vorbisgain.1
index bd7033a..094f271 100644
--- a/vorbisgain.1
+++ b/vorbisgain.1
@@ -110,7 +110,7 @@ have ReplayGain tags are not re-calculated. Note the quotes, as they cause the
 shell to not do any filename globbing:
 .PP
 .RS
-vorbisgain \-a \-f \-r "music/*.ogg"
+vorbisgain \-s \-a \-f \-r music/
 .RE
 .PP
 Calculate the album gain. The files specified before the directory "album"
@@ -124,7 +124,7 @@ vorbisgain \-a \-r a.ogg b.ogg c.ogg album d.ogg e.ogg f.ogg
 Remove all replaygain tags from a collection of oggs:
 .PP
 .RS
-vorbisgain \-c \-r "music/*.ogg"
+vorbisgain \-c \-r music/
 .RE
 .SH TAG FORMAT
 .B vorbisgain
-- 
2.52.0

