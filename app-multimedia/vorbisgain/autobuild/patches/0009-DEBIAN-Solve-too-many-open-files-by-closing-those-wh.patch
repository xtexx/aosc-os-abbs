From c245ceec322d144a270a6a64e593ca00669fdece Mon Sep 17 00:00:00 2001
From: =?UTF-8?q?Daniel=20Mart=C3=AD?= <mvdan@mvdan.cc>
Date: Sun, 7 Jun 2026 01:27:14 +0800
Subject: [PATCH 09/10] DEBIAN: Solve "too many open files" by closing those
 which are not compatible with vorbisgain

Thanks to Marcel Rehberg for the patch.

Signed-off-by: Mingcong Bai <jeffbai@aosc.io>
---
 vorbis.c | 3 ++-
 1 file changed, 2 insertions(+), 1 deletion(-)

diff --git a/vorbis.c b/vorbis.c
index 9ef445a..b420939 100644
--- a/vorbis.c
+++ b/vorbis.c
@@ -357,7 +357,8 @@ int get_gain(const char* filename, float* track_peak, float* track_gain,
         {
 	        vorbis_error(result, _("Couldn't process '%s': "), filename);
         }
-
+        // make sure file is closed, since ov_open failed we are still responsible
+        fclose(file);
         return -1;
     }
 
