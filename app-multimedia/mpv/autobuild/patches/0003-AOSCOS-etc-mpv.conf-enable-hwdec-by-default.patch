Date: Fri, 19 Jun 2026 17:38:58 +0800
Subject: [PATCH 3/3] AOSCOS: etc/mpv.conf: enable hwdec by default

---
 etc/mpv.conf | 2 +-
 1 file changed, 1 insertion(+), 1 deletion(-)

diff --git a/etc/mpv.conf b/etc/mpv.conf
index 15aad5f985..86b95d4401 100644
--- a/etc/mpv.conf
+++ b/etc/mpv.conf
@@ -70,7 +70,7 @@
 # video outputs, but should work well with default settings on most systems.
 # If performance or energy usage is an issue, forcing the vdpau or vaapi VOs
 # may or may not help.
-#hwdec=auto
+hwdec=auto
 
 ##################
 # audio settings #
