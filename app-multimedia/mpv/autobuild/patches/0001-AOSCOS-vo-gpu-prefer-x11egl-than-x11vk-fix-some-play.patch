From d018c0090bc7c7cfebdda581022605863cfa4173 Mon Sep 17 00:00:00 2001
From: "Lain \"Fearyncess\" Yang" <i@lain.vg>
Date: Fri, 19 Jun 2026 17:31:31 +0800
Subject: [PATCH 1/3] AOSCOS: vo/gpu: prefer x11egl than x11vk, fix some
 playing problem on X11 platform

---
 video/out/gpu/context.c | 8 ++++----
 1 file changed, 4 insertions(+), 4 deletions(-)

diff --git a/video/out/gpu/context.c b/video/out/gpu/context.c
index 60c0641a70..a628afc2b1 100644
--- a/video/out/gpu/context.c
+++ b/video/out/gpu/context.c
@@ -82,7 +82,7 @@ static const struct ra_ctx_fns *const contexts[] = {
     &ra_ctx_d3d11,
 #endif
 
-// Vulkan contexts:
+// Vulkan contexts :
 #if HAVE_VULKAN
 #if HAVE_WIN32_DESKTOP
     &ra_ctx_vulkan_win,
@@ -90,9 +90,6 @@ static const struct ra_ctx_fns *const contexts[] = {
 #if HAVE_WAYLAND
     &ra_ctx_vulkan_wayland,
 #endif
-#if HAVE_X11
-    &ra_ctx_vulkan_xlib,
-#endif
 #if HAVE_COCOA && HAVE_SWIFT
     &ra_ctx_vulkan_mac,
 #endif
@@ -126,6 +123,9 @@ static const struct ra_ctx_fns *const contexts[] = {
 
 // Vulkan contexts (fallbacks):
 #if HAVE_VULKAN
+#if HAVE_X11
+    &ra_ctx_vulkan_xlib,
+#endif
 #if HAVE_ANDROID
     &ra_ctx_vulkan_android,
 #endif
