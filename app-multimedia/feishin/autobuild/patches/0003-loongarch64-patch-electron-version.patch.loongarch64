From d3ca3f4363c09050b0d322fb776d56e8b744d723 Mon Sep 17 00:00:00 2001
From: SkyBird233 <52884766+SkyBird233@users.noreply.github.com>
Date: Fri, 23 Jan 2026 15:30:03 +0800
Subject: [PATCH 3/3] loongarch64: patch electron version

Signed-off-by: Kaiyang Wu <wukaiyang@loongfans.cn>
---
 electron-builder.yml | 2 +-
 pnpm-workspace.yaml  | 5 +++++
 2 files changed, 6 insertions(+), 1 deletion(-)
 create mode 100644 pnpm-workspace.yaml

diff --git a/electron-builder.yml b/electron-builder.yml
index c3024c5c..5e586197 100644
--- a/electron-builder.yml
+++ b/electron-builder.yml
@@ -1,7 +1,7 @@
 appId: org.jeffvli.feishin
 productName: Feishin
 artifactName: ${productName}-${version}-${os}-${arch}.${ext}
-electronVersion: 41.7.0
+electronVersion: 39.2.7
 directories:
     buildResources: assets
 files:
diff --git a/pnpm-workspace.yaml b/pnpm-workspace.yaml
new file mode 100644
index 00000000..f091c8bc
--- /dev/null
+++ b/pnpm-workspace.yaml
@@ -0,0 +1,5 @@
+overrides:
+  "electron": "39.2.7"
+  "electron-builder": "npm:@loongdotjs/electron-builder"
+  "app-builder-lib": "npm:@loongdotjs/app-builder-lib"
+  "builder-util": "npm:@loongdotjs/builder-util"
-- 
2.52.0

