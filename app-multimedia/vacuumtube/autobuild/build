abinfo "Fetching dependencies ..."
npm install --verbose

abinfo "Packaging ..."
npx electron-builder --dir
BUILDDIR=$(ls "$SRCDIR"/dist/ | grep unpacked)
abinfo "Set BUILDDIR to $BUILDDIR ."

abinfo "Installing ..."
mkdir -vp "$PKGDIR"/usr/lib/vacuumtube/
cp -vr "$SRCDIR"/dist/"$BUILDDIR"/* "$PKGDIR"/usr/lib/vacuumtube/
chmod -vR 755 "$PKGDIR"/usr/lib/vacuumtube/
mkdir -vp "$PKGDIR"/usr/bin/
ln -s ../lib/vacuumtube/vacuumtube "$PKGDIR"/usr/bin/vacuumtube

abinfo "Installing icon .."
install -Dvm644 "$SRCDIR"/assets/icon.svg "$PKGDIR"/usr/share/pixmaps/vacuumtube.svg
