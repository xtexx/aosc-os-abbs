PKGNAME=qmidiarp
PKGDES="An arpeggiator for ALSA/JACK, as dedicated UI or LV2 plugins"
PKGSEC=sound
PKGDEP="alsa-lib cairo gcc-runtime glib glibc glu jack libglvnd liblo lv2 \
        pango qt-5 x11-lib"

ABTYPE=cmakeninja
CMAKE_AFTER=(
    '-DCONFIG_FORCE_QT5=ON'
    '-DCONFIG_APPBUILD=ON'
    '-DCONFIG_JACK_MIDI=ON'
    '-DCONFIG_ALSA_MIDI=ON'
    '-DCONFIG_LV2=ON'
    '-DCONFIG_LV2_UI=ON'
    '-DCONFIG_LV2_UI_RTK=ON'
    '-DCONFIG_NSM=ON'
    '-DCONFIG_TRANSLATIONS=ON'
)
