From c851b5cfe6746a479fbbd942917e1b06474e8454 Mon Sep 17 00:00:00 2001
From: Mingcong Bai <jeffbai@aosc.io>
Date: Wed, 14 May 2025 21:58:04 +0800
Subject: [PATCH 1/2] DEBIAN: fix: put HAVE_VISIBILITY inside AM_CONDITIONAL

Fix errors during automake:

  mpcgain/Makefile.am:7: error: HAVE_VISIBILITY does not appear in AM_CONDITIONAL
  wavcmp/Makefile.am:3: error: HAVE_VISIBILITY does not appear in AM_CONDITIONAL

05_visibility.patch

Signed-off-by: Mingcong Bai <jeffbai@aosc.io>
---
 configure.in | 2 +-
 1 file changed, 1 insertion(+), 1 deletion(-)

diff --git a/configure.in b/configure.in
index cda7d7f..add5c94 100644
--- a/configure.in
+++ b/configure.in
@@ -30,7 +30,7 @@ AC_ARG_ENABLE([mpcchap], [AS_HELP_STRING([--enable-mpcchap], [enable building mp
 AM_CONDITIONAL([MPC_CHAP], [test "x$enable_mpcchap" = xyes])
 
 
-CHECK_VISIBILITY
+AM_CONDITIONAL([HAVE_VISIBILITY], [true])
 
 AC_CONFIG_FILES([
 Makefile
