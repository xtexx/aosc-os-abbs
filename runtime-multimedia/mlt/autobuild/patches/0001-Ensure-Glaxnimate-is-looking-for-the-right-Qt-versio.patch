Subject: [PATCH] Ensure Glaxnimate is looking for the right Qt version (#1233)

Fixes #1230
---
 src/modules/glaxnimate/CMakeLists.txt | 4 ++++
 1 file changed, 4 insertions(+)

diff --git a/src/modules/glaxnimate/CMakeLists.txt b/src/modules/glaxnimate/CMakeLists.txt
index 83f961a0..247a5f33 100644
--- a/src/modules/glaxnimate/CMakeLists.txt
+++ b/src/modules/glaxnimate/CMakeLists.txt
@@ -26,6 +26,10 @@ function(mlt_add_glaxnimate_module ARG_TARGET)
 
 
     set(CMAKE_POSITION_INDEPENDENT_CODE ON)
+
+    set(QT_MAJOR_VERSION ${ARG_QT_VERSION})
+    set(QT_VERSION_MAJOR ${ARG_QT_VERSION})
+
     add_subdirectory(glaxnimate/src/core/)
 
     add_library(${ARG_TARGET} MODULE producer_glaxnimate.cpp)
