    "${CMAKE_AFTER[@]}"
    '-DSDL_ARMNEON=ON'
    '-DSDL_RPI=ON'
    '-DSDL_ROCKCHIP=ON'
)
CMAKE_AFTER__LOONGARCH64=(
    "${CMAKE_AFTER[@]}"
    '-DSDL_LSX=ON'
    '-DSDL_LASX=OFF'
)
CMAKE_AFTER__LOONGARCH64_NOSIMD=(
    "${CMAKE_AFTER__LOONGARCH64[@]}"
    '-DSDL_LSX=OFF'
)
