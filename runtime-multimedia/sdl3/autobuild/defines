    '-DSDL_SHARED=ON'
    '-DSDL_STATIC=OFF'
    '-DSDL_TEST_LIBRARY=OFF'
    '-DSDL_TESTS=OFF'
    '-DSDL_INSTALL_TESTS=OFF'
    '-DSDL_EXAMPLES=OFF'
)
CMAKE_AFTER__AMD64=(
    "${CMAKE_AFTER[@]}"
    '-DSDL_AVX=OFF'
    '-DSDL_AVX2=OFF'
    '-DSDL_AVX512F=OFF'
    '-DSDL_SSE=ON'
    '-DSDL_SSE2=ON'
    '-DSDL_SSE3=OFF'
    '-DSDL_SSE4_1=OFF'
    '-DSDL_SSE4_2=OFF'
    '-DSDL_MMX=OFF'
)
