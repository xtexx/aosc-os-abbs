PKGNAME=sdl2-compat
PKGSEC=libs
PKGDEP="glu sdl3"
PKGDES="SDL2 compatibility layer based on SDL3"

CMAKE_AFTER=(
    '-DSDL2COMPAT_TESTS=OFF'
    '-DSDL2COMPAT_INSTALL_TESTS=OFF'
    '-DSDL2COMPAT_ASAN=OFF'
    '-DSDL2COMPAT_STATIC=OFF'
    '-DSDL2COMPAT_X11=ON'
    '-DSDL2COMPAT_VENDOR_INFO=AOSC'
)

# FIXME: libSDL2main and libSDL2_test are not available as shared objects.
NOSTATIC=0

PKGBREAK="sdl2<=2.30.4-2"
PKGREP="sdl2<=2.30.4-2"
