abinfo "Building nim ..."
sh "$SRCDIR"/build.sh
abinfo "Building koch ..."
"$SRCDIR"/bin/nim c -d:release koch
"$SRCDIR"/koch boot -d:release -d:nativeStacktrace -d:useGnuReadline
abinfo "Building tools ..."
"$SRCDIR"/koch tools
abinfo "Building niminst ..."
"$SRCDIR"/bin/nim compile "$SRCDIR"/tools/niminst/niminst.nim

abinfo "Installing nim ..."
"$SRCDIR"/koch install "$PKGDIR"/usr/lib
mkdir -pv "$PKGDIR/usr/bin"
ln -sv ../lib/nim/bin/nim "$PKGDIR"/usr/bin/nim
abinfo "Installing nim tools ..."
install -Dvm755 "$SRCDIR"/bin/!(nim) \
    -t "$PKGDIR"/usr/bin/

abinfo "Installing nim bash completion ..."
install -Dvm644 "$SRCDIR"/tools/nim.bash-completion \
    "$PKGDIR"/usr/share/bash-completion/nim
install -Dvm644 "$SRCDIR"/dist/nimble/nimble.bash-completion \
    "$PKGDIR"/usr/share/bash-completion/nimble
abinfo "Installing nim zsh completion ..."
install -Dvm644 "$SRCDIR"/tools/nim.zsh-completion \
    "$PKGDIR"/usr/share/zsh/site-functions/_nim
install -Dvm644 "$SRCDIR"/dist/nimble/nimble.zsh-completion \
    "$PKGDIR"/usr/share/zsh/site-functions/_nimble

abinfo "Installing LICENSE ..."
install -Dvm644 "$SRCDIR"/copying.txt \
    "$PKGDIR"/usr/share/doc/nim/LICENSE
