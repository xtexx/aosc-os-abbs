PKGNAME=wolfssl
PKGSEC=libs
PKGDEP="glibc"
PKGDES="TLS/SSL library for embedded and cloud environments"

AUTOTOOLS_AFTER=(
    "--enable-all"
    "--enable-dtls13"
    "--enable-dtls-mtu"
    "--disable-examples"
    "--disable-static"
    "--disable-armasm" # Error: selected processor does not support `sha256h2 q1,q25,v24.4s' 
)
