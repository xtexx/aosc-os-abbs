PKGNAME=libgpg-error
PKGSEC=libs
PKGDEP="glibc"
PKGDES="Support library for GnuPG components"
PKGPROV="libgpg-error-static"

ABTYPE=autotools
AUTOTOOLS_AFTER=(
    '--enable-static'
    '--enable-install-gpg-error-config'
)

NOSTATIC=0

PKGBREAK="libgpg-error-static<=1.48"
PKgREP="libgpg-error-static<=1.48"
