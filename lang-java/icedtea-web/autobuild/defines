PKGNAME=icedtea-web
PKGSEC=java
PKGDEP="openjdk-8"
BUILDDEP="npapi-sdk rustc llvm"
PKGDES="An open source implementation of JSR-56 aka Java Web Start"

PKGPROV="icedtea"
PKGBREAK="openjdk<=3:8u232+ga"

ABTYPE=autotools
AUTOTOOLS_AFTER=(
    '--with-jdk-home=/usr/lib/java-8'
    '--with-jre-home=/usr/lib/java-8'
    "--with-modularjdk-file=/etc/java/$PKGNAME"
    '--with-itw-libs=DISTRIBUTION'
    '--enable-shell-launchers'
    '--disable-docs'
)

