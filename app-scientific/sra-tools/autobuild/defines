PKGNAME=sra-tools
PKGSEC=science
PKGDEP="fuse hdf5 ncbi-vdb openjdk python-3"
PKGDES="Utilities for the NCBI Sequence Read Archive (SRA)"

NOLTO=1
NOSTATIC=0

ABTYPE=cmakeninja
CMAKE_AFTER=(
    "-DCMAKE_INSTALL_PREFIX=/usr"
    "-DCMAKE_INSTALL_LIBDIR=li"
    "-DVDB_INCDIR=/usr/include"
    "-DVDB_LIBDIR=/usr/lib"
    "-DBUILD_TESTING=OFF"
)

FAIL_ARCH="!(amd64|arm64)"

PKGBREAK="ngs<=2.10.8-2"
PKGREP="ngs<=2.10.8-2"
