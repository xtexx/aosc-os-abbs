abinfo "Configure BLIS ..."
BLIS_CONFIG=generic
# Note: see https://github.com/flame/blis/blob/master/docs/ConfigurationHowTo.md
if ab_match_arch arm64; then
# Note: ARMv8-A
    BLIS_CONFIG=cortexa57
elif ab_match_arch riscv64; then
# Note: RVA20
    BLIS_CONFIG=rv64i
fi
"$SRCDIR"/configure -p /usr/ $BLIS_CONFIG

abinfo "Building BLIS ..."
make V=1 VERBOSE=1

abinfo "Installing BLIS binaries ..."
make install V=1 VERBOSE=1 DESTDIR="$PKGDIR"
