From d743e4c89f7452eb3fecabb6061633057f7ce5c1 Mon Sep 17 00:00:00 2001
From: Nathan Mills <38995150+Quipyowert2@users.noreply.github.com>
Date: Sun, 26 Oct 2025 22:48:54 -0700
Subject: [PATCH] Fix signal handler prototypes.

---
 pTk/mTk/unix/tkUnixEvent.c  | 4 ++--
 pTk/mTk/unix/tkUnixSelect.c | 6 +++---
 2 files changed, 5 insertions(+), 5 deletions(-)

diff --git a/pTk/mTk/unix/tkUnixEvent.c b/pTk/mTk/unix/tkUnixEvent.c
index ed62e29b..feb8c8c4 100644
--- a/pTk/mTk/unix/tkUnixEvent.c
+++ b/pTk/mTk/unix/tkUnixEvent.c
@@ -416,9 +416,9 @@ DisplayFileProc(clientData, flags)
 	 * message.
 	 */
 
-	void (*oldHandler)();
+	void (*oldHandler)(int);
 
-	oldHandler = (void (*)()) signal(SIGPIPE, SIG_IGN);
+	oldHandler = (void (*)(int)) signal(SIGPIPE, SIG_IGN);
 	XNoOp(display);
 	XFlush(display);
 	(void) signal(SIGPIPE, oldHandler);
diff --git a/pTk/mTk/unix/tkUnixSelect.c b/pTk/mTk/unix/tkUnixSelect.c
index bd50f062..ce66f304 100644
--- a/pTk/mTk/unix/tkUnixSelect.c
+++ b/pTk/mTk/unix/tkUnixSelect.c
@@ -367,7 +367,7 @@ TkSelPropProc(eventPtr)
 	    ((char *) buffer)[numItems] = 0;
 
 	    errorHandler = Tk_CreateErrorHandler(eventPtr->xproperty.display,
-		    -1, -1, -1, (int (*)()) NULL, (ClientData) NULL);
+		    -1, -1, -1, (int (*)(void*, XErrorEvent*)) NULL, (ClientData) NULL);
 	    /*
 	     * Encode the data using the proper format for each type.
 	     */
@@ -872,7 +872,7 @@ ConvertSelection(winPtr, eventPtr)
 	    Tcl_GetThreadData(&dataKey, sizeof(ThreadSpecificData));
 
     errorHandler = Tk_CreateErrorHandler(eventPtr->display, -1, -1,-1,
-	    (int (*)()) NULL, (ClientData) NULL);
+	    (int (*)(void*, XErrorEvent*)) NULL, (ClientData) NULL);
 
     /*
      * Initialize the reply event.
@@ -1149,7 +1149,7 @@ ConvertSelection(winPtr, eventPtr)
 	Tcl_DeleteTimerHandler(incr.timeout);
 	/* winPtr may have been destroyed now */
 	errorHandler = Tk_CreateErrorHandler(reply.display,
-		-1, -1,-1, (int (*)()) NULL, (ClientData) NULL);
+		-1, -1,-1, (int (*)(void*, XErrorEvent*)) NULL, (ClientData) NULL);
 	XSelectInput(reply.display, reply.requestor, 0L);
 	Tk_DeleteErrorHandler(errorHandler);
 	if (tsdPtr->pendingIncrs == &incr) {
