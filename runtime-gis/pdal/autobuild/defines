PKGNAME=pdal
PKGSEC=science
PKGDES="C++ library for translating and manipulating point cloud data"
PKGDEP="curl gcc-runtime gdal glibc hdf5 libgeotiff libunwind libxml2 \
        openscenegraph openssl pcl postgresql proj vtk xerces-c zlib \
        zstd draco tiledb teaserpp pdal-nitro ceres apache-arrow libcpd"
BUILDDEP="nlohmann-json gtest"

# NOTE: See options.cmake.
CMAKE_AFTER=(
    -DWITH_COMPLETION=TRUE
    -DWITH_BACKTRACE=ON
    -DWITH_GCS=TRUE
    -DBUILD_PLUGIN_DRACO=TRUE
    -DBUILD_PLUGIN_PGPOINTCLOUD=TRUE
    -DBUILD_PLUGIN_OPENSCENEGRAPH=TRUE
    -DBUILD_PLUGIN_MBIO=TRUE
    -DBUILD_PLUGIN_FBX=TRUE
    -DBUILD_PLUGIN_E57=TRUE
    -DBUILD_PLUGIN_HDF=TRUE
    -DBUILD_PLUGIN_TILEDB=TRUE
    -DBUILD_PLUGIN_ICEBRIDGE=TRUE
    -DBUILD_PLUGIN_TEASER=TRUE
    -DBUILD_PLUGIN_NITF=TRUE
    -DBUILD_TOOLS_NITFWRAP=FALSE        # FIXME: Many errors.
    -DBUILD_PLUGIN_TRAJECTORY=TRUE
    -DBUILD_PLUGIN_ARROW=TRUE
    -DBUILD_PLUGIN_CPD=TRUE
    -DBUILD_PLUGIN_MATLAB=FALSE         # FIXME: Needs MATLAB.
    -DBUILD_PLUGIN_RIVLIB=FALSE         # FIXME: Needs rivlib and rdblib, both are proprietary.
    -DBUILD_PLUGIN_RDBLIB=FALSE

    -DWITH_TESTS=FALSE
    -DENABLE_CTEST=FALSE
    -DWITH_ABSEIL=FALSE
)

ABTYPE=cmakeninja
