cd "$SRCDIR"

abinfo "Building cni-plugins..."
./build_linux.sh

abinfo "Installing cni-plugins..."
install -Dvm755 ./bin/* -t "$PKGDIR"/opt/cni/bin
strip "$PKGDIR"/opt/cni/bin/*
install -dvm755 "$PKGDIR"/etc/cni/net.d/
install -Dvm644 LICENSE -t "$PKGDIR"/usr/share/licenses/cni-plugins/
install -Dvm644 plugins/ipam/dhcp/systemd/* -t "$PKGDIR"/usr/lib/systemd/system/
