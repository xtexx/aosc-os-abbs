From 43857b6d7244b1c538942ee37717fb46ca84cb4c Mon Sep 17 00:00:00 2001
From: Ruikai Liu <rickliu2000@outlook.com>
Date: Mon, 10 Nov 2025 16:00:38 +0800
Subject: [PATCH] ARCHLINUX: Fix build with Qt 6.10

Link: https://gitlab.archlinux.org/archlinux/packaging/packages/fcitx-qt5/-/blob/57b76846d99c078fdf4f6a26552573bbffef2f00/qt-6.10.patch
---
 qt6/CMakeLists.txt                      | 6 +++++-
 qt6/platforminputcontext/CMakeLists.txt | 8 ++++++--
 2 files changed, 11 insertions(+), 3 deletions(-)

diff --git a/qt6/CMakeLists.txt b/qt6/CMakeLists.txt
index 9b8f6c2..16c7ebc 100644
--- a/qt6/CMakeLists.txt
+++ b/qt6/CMakeLists.txt
@@ -1,5 +1,9 @@
 find_package(Qt6 ${REQUIRED_QT6_VERSION} CONFIG REQUIRED Core DBus)
-find_package(Qt6Gui ${REQUIRED_QT6_VERSION} REQUIRED Private)
+if(Qt6_VERSION VERSION_GREATER_EQUAL 6.10)
+  find_package(Qt6 COMPONENTS GuiPrivate REQUIRED)
+else()
+  find_package(Qt6Gui ${REQUIRED_QT6_VERSION} REQUIRED Private)
+endif()
 
 add_definitions(-DQT_NO_KEYWORDS)
 
diff --git a/qt6/platforminputcontext/CMakeLists.txt b/qt6/platforminputcontext/CMakeLists.txt
index a6b3741..aa17213 100644
--- a/qt6/platforminputcontext/CMakeLists.txt
+++ b/qt6/platforminputcontext/CMakeLists.txt
@@ -1,5 +1,8 @@
-include_directories(${Qt6Gui_PRIVATE_INCLUDE_DIRS})
-
+if(Qt6_VERSION VERSION_GREATER_EQUAL 6.10)
+  include_directories(${Qt6GuiPrivate_INCLUDE_DIRS})
+else()
+  include_directories(${Qt6Gui_PRIVATE_INCLUDE_DIRS})
+endif()
 
 set(plugin_SRCS
     fcitxinputcontextproxy.cpp
@@ -36,6 +39,7 @@ target_include_directories(fcitxplatforminputcontextplugin-qt6
 target_link_libraries(fcitxplatforminputcontextplugin-qt6
                           Qt6::Core
                           Qt6::Gui
+                          Qt6::GuiPrivate
                           Qt6::DBus
                           XKBCommon::XKBCommon
                          )
-- 
2.51.1

