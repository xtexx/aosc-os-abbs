From dd2394dad5a88771de155bc46f384f9d9901f6a1 Mon Sep 17 00:00:00 2001
From: Henry Chen <henry.chen@oss.cipunited.com>
Date: Tue, 16 Sep 2025 15:06:18 +0800
Subject: [PATCH 4/4] compel/arch/mips: support alternative EI_ABIVERSION

Executables using the GNU hash style have e_ident[EI_ABIVERSION] set
to 0x05.
---
 compel/arch/mips/src/lib/handle-elf.c | 22 +++++++++++++++++++++-
 1 file changed, 21 insertions(+), 1 deletion(-)

diff --git a/compel/arch/mips/src/lib/handle-elf.c b/compel/arch/mips/src/lib/handle-elf.c
index a605a5a45..e14961291 100644
--- a/compel/arch/mips/src/lib/handle-elf.c
+++ b/compel/arch/mips/src/lib/handle-elf.c
@@ -10,11 +10,31 @@ static const unsigned char __maybe_unused elf_ident_64_le[EI_NIDENT] = {
 	0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00,
 };
 
+static const unsigned char __maybe_unused elf_ident_64_le_xhash[EI_NIDENT] = {
+	0x7f,
+	0x45,
+	0x4c,
+	0x46,
+	0x02,
+	0x01,
+	0x01,
+	0x00, /* clang-format */
+	0x05,
+	0x00,
+	0x00,
+	0x00,
+	0x00,
+	0x00,
+	0x00,
+	0x00,
+};
+
 extern int __handle_elf(void *mem, size_t size);
 
 int handle_binary(void *mem, size_t size)
 {
-	if (memcmp(mem, elf_ident_64_le, sizeof(elf_ident_64_le)) == 0)
+	if (memcmp(mem, elf_ident_64_le, sizeof(elf_ident_64_le)) == 0 ||
+	    memcmp(mem, elf_ident_64_le_xhash, sizeof(elf_ident_64_le_xhash)) == 0)
 		return __handle_elf(mem, size);
 
 	pr_err("Unsupported Elf format detected\n");
-- 
