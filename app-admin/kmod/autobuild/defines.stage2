PKGNAME=kmod
PKGSEC=admin
PKGDEP="glibc openssl xz zlib zstd"
BUILDDEP=""
PKGDES="Tools for managing kernel modules"

ABTYPE=meson
MESON_AFTER=(
    '-Dtools=true'
    '-Dmanpages=false'
    '-Dlogging=true'
    '-Ddebug=false'
    '-Dzstd=enabled'
    '-Dxz=enabled'
    '-Dzlib=enabled'
    '-Dopenssl=enabled'
    '-Ddocs=false'
)

# Note: Saves gtk-doc.
RECONF=0

PKGESS=1

PKGBREAK="bash-completion<=1:2.14.0"
