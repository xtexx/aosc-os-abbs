PKGNAME=appstream
PKGSEC=admin
PKGDEP="libxml2 polkit protobuf snowball libfyaml libxmlb librsvg"
BUILDDEP="docbook-xsl gobject-introspection gperf intltool qt-5 qt-6 xmlto vala"
PKGDES="Provides a standard for creating app stores across distributions"

ABTYPE=meson
MESON_AFTER=(
    "-Dstemming=true"
    "-Dsystemd=true"
    "-Dvapi=true"
    "-Dqt=true"
    "-Dqt-versions=['5', '6']"
    "-Dcompose=true"
    "-Dapt-support=true"
    "-Dgir=true"
    "-Dsvg-support=true"
    "-Ddocs=false"
    "-Dapidocs=false"
    "-Dinstall-docs=false"
    "-Dmaintainer=false"
    "-Dstatic-analysis=false"
)

PKGBREAK="flatpak<=1.14.10 gnome-software<=42.4-1 \
          libadwaita<=1.6.1 limba<=0.5.6-5 packagekit<=1.2.8"
