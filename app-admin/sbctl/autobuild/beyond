abinfo "Installing sbctl assets.."

# Generate completion files
"$PKGDIR/usr/bin/sbctl" completion bash | install -Dvm644 /dev/stdin "$PKGDIR/usr/share/bash-completion/completions/sbctl"
"$PKGDIR/usr/bin/sbctl" completion zsh | install -Dvm644 /dev/stdin "$PKGDIR/usr/share/zsh/site-functions/_sbctl"
"$PKGDIR/usr/bin/sbctl" completion fish | install -Dvm644 /dev/stdin "$PKGDIR/usr/share/fish/vendor_completions.d/sbctl.fish"
install -Dvm755 contrib/kernel-install/91-sbctl.install "$PKGDIR/usr/lib/kernel/install.d/91-sbctl.install"
install -Dvm755 contrib/installkernel/91-sbctl.install "$PKGDIR/usr/lib/kernel/postinst.d/91-sbctl.install"
install -Dvm644 LICENSE -t "$PKGDIR/usr/share/licenses/sbctl"

# manfiles
for file in "docs"/sbctl.*.txt; do
	[ -f "$file" ] || continue
	a2x --no-xmllint --asciidoc-opts="-f docs/asciidoc.conf" \
	    -d manpage -f manpage -D docs "$file"

	manpage="docs/$(basename "${file%.txt}")"
	section="${manpage##*.}"

	install -Dvm644 "$manpage" \
	    "$PKGDIR/usr/share/man/man$section/$(basename "$manpage")"
done 	
