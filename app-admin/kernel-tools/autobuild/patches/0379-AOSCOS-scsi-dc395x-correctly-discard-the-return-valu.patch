From b65debe5d33e4dd4d71bb6e0d00d67e4ffd7d6ca Mon Sep 17 00:00:00 2001
From: Xinhui Yang <cyan@cyano.uk>
Date: Wed, 10 Sep 2025 23:21:26 +0800
Subject: [PATCH 379/379] AOSCOS: scsi: dc395x: correctly discard the return
 value in certain reads
MIME-Version: 1.0
Content-Type: text/plain; charset=UTF-8
Content-Transfer-Encoding: 8bit

With CONFIG_WERROR on, these warnings get converted into errors:

drivers/scsi/dc395x.c: In function ‘__dc395x_eh_bus_reset’:
drivers/scsi/dc395x.c:97:49: error: value computed is not used [-Werror=unused-value]
   97 | #define DC395x_read8(acb,address)               (u8)(inb(acb->io_port_base + (address)))
      |                                                 ^~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
drivers/scsi/dc395x.c:1003:9: note: in expansion of macro ‘DC395x_read8’
 1003 |         DC395x_read8(acb, TRM_S1040_SCSI_INTSTATUS);
      |         ^~~~~~~~~~~~
drivers/scsi/dc395x.c: In function ‘data_io_transfer’:
drivers/scsi/dc395x.c:97:49: error: value computed is not used [-Werror=unused-value]
   97 | #define DC395x_read8(acb,address)               (u8)(inb(acb->io_port_base + (address)))
      |                                                 ^~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
drivers/scsi/dc395x.c:2032:33: note: in expansion of macro ‘DC395x_read8’
 2032 |                                 DC395x_read8(acb, TRM_S1040_SCSI_FIFO);

Create a value with unused attribute to suppress them.
---
 drivers/scsi/dc395x.c | 29 +++++++++++++++++++++--------
 1 file changed, 21 insertions(+), 8 deletions(-)

diff --git a/drivers/scsi/dc395x.c b/drivers/scsi/dc395x.c
index 386c8359e1cc8..230f5e8856312 100644
--- a/drivers/scsi/dc395x.c
+++ b/drivers/scsi/dc395x.c
@@ -971,6 +971,8 @@ static void reset_dev_param(struct AdapterCtlBlk *acb)
  */
 static int __dc395x_eh_bus_reset(struct scsi_cmnd *cmd)
 {
+	/* discard the returned value if it is a dry read */
+	u8 read_ignored __attribute ((unused));
 	struct AdapterCtlBlk *acb =
 		(struct AdapterCtlBlk *)cmd->device->host->hostdata;
 
@@ -1000,7 +1002,7 @@ static int __dc395x_eh_bus_reset(struct scsi_cmnd *cmd)
 	DC395x_write8(acb, TRM_S1040_DMA_CONTROL, CLRXFIFO);
 	clear_fifo(acb, "eh_bus_reset");
 	/* Delete pending IRQ */
-	DC395x_read8(acb, TRM_S1040_SCSI_INTSTATUS);
+	read_ignored = DC395x_read8(acb, TRM_S1040_SCSI_INTSTATUS);
 	set_basic_config(acb);
 
 	reset_dev_param(acb);
@@ -1901,6 +1903,9 @@ static void data_in_phase1(struct AdapterCtlBlk *acb, struct ScsiReqBlk *srb,
 static void data_io_transfer(struct AdapterCtlBlk *acb, 
 		struct ScsiReqBlk *srb, u16 io_dir)
 {
+	/* consume the returned value if it is a dry read */
+	u8 read_ignored_8 __attribute ((unused));
+	u32 read_ignored_32 __attribute ((unused));
 	struct DeviceCtlBlk *dcb = srb->dcb;
 	u8 bval;
 
@@ -2026,11 +2031,12 @@ static void data_io_transfer(struct AdapterCtlBlk *acb,
 		 */
 		if (dcb->sync_period & WIDE_SYNC) {
 			DC395x_write32(acb, TRM_S1040_SCSI_COUNTER, 2);
-			DC395x_write8(acb, TRM_S1040_SCSI_CONFIG2,
-				      CFG2_WIDEFIFO);
+			DC395x_write8(acb, TRM_S1040_SCSI_CONFIG2, CFG2_WIDEFIFO);
 			if (io_dir & DMACMD_DIR) {
-				DC395x_read8(acb, TRM_S1040_SCSI_FIFO);
-				DC395x_read8(acb, TRM_S1040_SCSI_FIFO);
+				read_ignored_8 =
+					DC395x_read8(acb, TRM_S1040_SCSI_FIFO);
+				read_ignored_8 =
+					DC395x_read8(acb, TRM_S1040_SCSI_FIFO);
 			} else {
 				/* Danger, Robinson: If you find KGs
 				 * scattered over the wide disk, the driver
@@ -2044,7 +2050,8 @@ static void data_io_transfer(struct AdapterCtlBlk *acb,
 			/* Danger, Robinson: If you find a collection of Ks on your disk
 			 * something broke :-( */
 			if (io_dir & DMACMD_DIR)
-				DC395x_read8(acb, TRM_S1040_SCSI_FIFO);
+				read_ignored_8 =
+					DC395x_read8(acb, TRM_S1040_SCSI_FIFO);
 			else
 				DC395x_write8(acb, TRM_S1040_SCSI_FIFO, 'K');
 		}
@@ -2867,6 +2874,9 @@ static void reset_scsi_bus(struct AdapterCtlBlk *acb)
 
 static void set_basic_config(struct AdapterCtlBlk *acb)
 {
+	/* discard the returned value if it is a dry read */
+	u8 read_ignored __attribute ((unused));
+
 	u8 bval;
 	u16 wval;
 	DC395x_write8(acb, TRM_S1040_SCSI_TIMEOUT, acb->sel_timeout);
@@ -2892,7 +2902,7 @@ static void set_basic_config(struct AdapterCtlBlk *acb)
 	    DMA_FIFO_HALF_HALF | DMA_ENHANCE /*| DMA_MEM_MULTI_READ */ ;
 	DC395x_write16(acb, TRM_S1040_DMA_CONFIG, wval);
 	/* Clear pending interrupt status */
-	DC395x_read8(acb, TRM_S1040_SCSI_INTSTATUS);
+	read_ignored = DC395x_read8(acb, TRM_S1040_SCSI_INTSTATUS);
 	/* Enable SCSI interrupt    */
 	DC395x_write8(acb, TRM_S1040_SCSI_INTEN, 0x7F);
 	DC395x_write8(acb, TRM_S1040_DMA_INTEN, EN_SCSIINTR | EN_DMAXFERERROR
@@ -3790,6 +3800,9 @@ static int adapter_init(struct AdapterCtlBlk *acb, unsigned long io_port,
  **/
 static void adapter_uninit_chip(struct AdapterCtlBlk *acb)
 {
+	/* discard the returned value if it is a dry read */
+	u8 read_ignored __attribute ((unused));
+
 	/* disable interrupts */
 	DC395x_write8(acb, TRM_S1040_DMA_INTEN, 0);
 	DC395x_write8(acb, TRM_S1040_SCSI_INTEN, 0);
@@ -3799,7 +3812,7 @@ static void adapter_uninit_chip(struct AdapterCtlBlk *acb)
 		reset_scsi_bus(acb);
 
 	/* clear any pending interrupt state */
-	DC395x_read8(acb, TRM_S1040_SCSI_INTSTATUS);
+	read_ignored = DC395x_read8(acb, TRM_S1040_SCSI_INTSTATUS);
 }
 
 
-- 
