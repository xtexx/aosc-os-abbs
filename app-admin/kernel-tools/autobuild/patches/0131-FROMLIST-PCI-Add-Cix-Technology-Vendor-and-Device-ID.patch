From 03f0de14a6adf083b54a17ecd383059d0db9b5f8 Mon Sep 17 00:00:00 2001
From: Hans Zhang <hans.zhang@cixtech.com>
Date: Mon, 20 Oct 2025 12:28:53 +0800
Subject: [PATCH 131/437] FROMLIST: PCI: Add Cix Technology Vendor and Device
 ID

Add CIX P1 (internal name sky1) as a vendor and device ID for PCI
devices. This ID will be used by the CIX Sky1 PCIe host controller driver.

Signed-off-by: Hans Zhang <hans.zhang@cixtech.com>
Acked-by: Manivannan Sadhasivam <mani@kernel.org>

Link: https://lore.kernel.org/linux-pci/20251020042857.706786-1-hans.zhang@cixtech.com/
Signed-off-by: Mingcong Bai <jeffbai@aosc.io>
---
 include/linux/pci_ids.h | 3 +++
 1 file changed, 3 insertions(+)

diff --git a/include/linux/pci_ids.h b/include/linux/pci_ids.h
index 92ffc4373f6de..24b04d0859203 100644
--- a/include/linux/pci_ids.h
+++ b/include/linux/pci_ids.h
@@ -2631,6 +2631,9 @@
 
 #define PCI_VENDOR_ID_CXL		0x1e98
 
+#define PCI_VENDOR_ID_CIX		0x1f6c
+#define PCI_DEVICE_ID_CIX_SKY1		0x0001
+
 #define PCI_VENDOR_ID_TEHUTI		0x1fc9
 #define PCI_DEVICE_ID_TEHUTI_3009	0x3009
 #define PCI_DEVICE_ID_TEHUTI_3010	0x3010
-- 
2.52.0

