From d5f491b12c32aa8f3cb857ef97aa8e065dc9da86 Mon Sep 17 00:00:00 2001
From: Mingcong Bai <jeffbai@aosc.io>
Date: Tue, 23 Dec 2025 23:18:27 +0800
Subject: [PATCH 437/437] AOSCOS: PCI: Add ASUS ROG Strix G15 (G513R, 2022) to
 pci=nocrs blacklist

The MediaTek MT7921 card frequently disappears, especially on cold boots,
reboots, and on S3 wakeup. Adding pci=nocrs resolves this issue.

Also reported elsewhere before and confirming that pci=nocrs was indeed a
working workaround. See link below.

Cc: stable@vger.kernel.org
Reported-by: Yu Chen <zerominute@163.com>
Link: https://bbs.archlinux.org/viewtopic.php?id=291793
Signed-off-by: Mingcong Bai <jeffbai@aosc.io>
---
 arch/x86/pci/acpi.c | 9 +++++++++
 1 file changed, 9 insertions(+)

diff --git a/arch/x86/pci/acpi.c b/arch/x86/pci/acpi.c
index 0c316bae1726e..78578019f1eef 100644
--- a/arch/x86/pci/acpi.c
+++ b/arch/x86/pci/acpi.c
@@ -137,6 +137,15 @@ static const struct dmi_system_id pci_crs_quirks[] __initconst = {
 			DMI_MATCH(DMI_BIOS_VERSION, "2.0a"),
 		},
 	},
+	/* REPORT PENDING */
+	{
+		.callback = set_nouse_crs,
+		.ident = "ASUS ROG Strix G15 (G513R)",
+		.matches = {
+			DMI_MATCH(DMI_SYS_VENDOR, "ASUSTeK COMPUTER INC."),
+			DMI_MATCH(DMI_BOARD_NAME, "G513RM"),
+		},
+	},
 
 	/* https://bugzilla.kernel.org/show_bug.cgi?id=15362 */
 	{
-- 
2.52.0

