From b64b7e0a816b2163263b90ff85ae8daa8022fcbc Mon Sep 17 00:00:00 2001
From: Mingcong Bai <jeffbai@aosc.xyz>
Date: Thu, 28 Dec 2023 22:12:01 -0800
Subject: [PATCH 13/75] util: add GRUB_COLOR_* variables

---
 util/grub-mkconfig.in    | 2 ++
 util/grub.d/00_header.in | 8 ++++++++
 2 files changed, 10 insertions(+)

diff --git a/util/grub-mkconfig.in b/util/grub-mkconfig.in
index 9ac9de218..41354ba43 100644
--- a/util/grub-mkconfig.in
+++ b/util/grub-mkconfig.in
@@ -246,6 +246,8 @@ export GRUB_DEFAULT \
   GRUB_BACKGROUND \
   GRUB_THEME \
   GRUB_GFXPAYLOAD_LINUX \
+  GRUB_COLOR_NORMAL \
+  GRUB_COLOR_HIGHLIGHT \
   GRUB_DISABLE_OS_PROBER \
   GRUB_INIT_TUNE \
   GRUB_SAVEDEFAULT \
diff --git a/util/grub.d/00_header.in b/util/grub.d/00_header.in
index 77834cfaf..48253206f 100644
--- a/util/grub.d/00_header.in
+++ b/util/grub.d/00_header.in
@@ -159,6 +159,14 @@ cat <<EOF
 
 EOF
 
+if [ x$GRUB_COLOR_NORMAL != x ] && [ x$GRUB_COLOR_HIGHLIGHT != x ] ; then
+    cat << EOF
+set menu_color_normal=$GRUB_COLOR_NORMAL
+set menu_color_highlight=$GRUB_COLOR_HIGHLIGHT
+
+EOF
+fi
+
 serial=0;
 gfxterm=0;
 for x in ${GRUB_TERMINAL_INPUT} ${GRUB_TERMINAL_OUTPUT}; do
-- 
2.52.0

