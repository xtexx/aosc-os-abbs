From 43bfd901e87d8ea182dbc9bc684882ba708570a3 Mon Sep 17 00:00:00 2001
From: "Lain \"Fearyncess\" Yang" <fsf@live.com>
Date: Tue, 17 Feb 2026 23:39:20 +0800
Subject: [PATCH 72/75] Revert "configure: Print a more helpful error if
 autoconf-archive is not installed"

This reverts commit ac042f3f58d33ce9cd5ff61750f06da1a1d7b0eb.

Let autoreconf not to complain meanless
---
 configure.ac | 5 -----
 1 file changed, 5 deletions(-)

diff --git a/configure.ac b/configure.ac
index a84e088a2..a48c8b908 100644
--- a/configure.ac
+++ b/configure.ac
@@ -1805,11 +1805,6 @@ LIBS=""
 # Defined in acinclude.m4.
 grub_ASM_USCORE
 grub_PROG_TARGET_CC
-
-# The error message produced by autoconf if autoconf-archive is not installed is
-# quite misleading and not very helpful. So, try point people in the right direction.
-m4_ifndef([AX_CHECK_LINK_FLAG], [m4_fatal([autoconf-archive is missing. You must install it to generate the configure script.])])
-
 if test "x$TARGET_APPLE_LINKER" != x1 ; then
 grub_PROG_OBJCOPY_ABSOLUTE
 fi
-- 
2.52.0

