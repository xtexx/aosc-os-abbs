From 878d1f621f06276482fefcf3161ac56fb3b45000 Mon Sep 17 00:00:00 2001
From: Xinhui Yang <cyan@cyano.uk>
Date: Thu, 2 Oct 2025 23:56:42 +0800
Subject: [PATCH 62/75] 10_linux: rework prioritization logic

Previously the kernel with default configuration (e.g. -16k for
LoongArch) will always be on top regardless of its variant, i.e. a 16k
RC kernel will be given higher priority in the menu. This should not
happen.
---
 util/grub.d/10_linux.in | 43 ++++++++++++++++++++++++++---------------
 1 file changed, 27 insertions(+), 16 deletions(-)

diff --git a/util/grub.d/10_linux.in b/util/grub.d/10_linux.in
index 86feda685..29edc26e1 100644
--- a/util/grub.d/10_linux.in
+++ b/util/grub.d/10_linux.in
@@ -265,26 +265,37 @@ find_rootdev() {
 # The kernel with the default size will be always on top. If it does
 # not exist, then the kernel without page size suffix will be on top.
 prioritize() {
-	local kernels newkernels default_configuration flag
+	local kernels newkernels default_configuration flag \
+		variant cfg k k1
 	kernels=("$@")
 	newkernels=()
-	default_configuration="$(default_configuration)"
+	default_cfg="$(default_configuration)"
 	for k in "${kernels[@]}" ; do
-		# This system probably don't have other page sizes.
-		if [ "${k%%-[0-9]*k}" = "$k" ] ; then
-			if [ "${k%%-rc}" != "$k" ] || \
-				[ "${k%%-lts}" != "$k" ] ; then
+		k1="${k#@(kernel-|vmlinu?-)}"
+		IFS='-'
+		components=($k1)
+		unset IFS
+		variant="${components[2]}"
+		cfg="${components[3]}"
+		# NOTE: This code can NOT insert an element in the middle
+		# of the array, because it does not know where to put it.
+		# If this ever results in the default configuration entry
+		# showing up later than other configurations, please do
+		# not attempt to fix this.
+		case "${variant,,}" in
+			main)
+				# This is the default configration.
+				# Put it on top.
+				if [ -z "$cfg" ] || [ "$cfg" = "$default_cfg" ] ; then
+					newkernels=("$k" "${newkernels[@]}")
+				else
+					newkernels+=("$k")
+				fi
+				;;
+			*)
 				newkernels+=("$k")
-			else
-				newkernels=("$k" "${newkernels[@]}")
-			fi
-			continue
-		fi
-		if [ "${k%%-$default_configuration}" != "$k" ] ; then
-			newkernels=("$k" "${newkernels[@]}")
-			continue
-		fi
-		newkernels+=("$k")
+				;;
+		esac
 	done
 	OLDIFS="$IFS"
 	IFS=$'\n'
-- 
