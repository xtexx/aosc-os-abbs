From 540bacdb1012366052d7f7c9297bccec0b02ba82 Mon Sep 17 00:00:00 2001
From: Xinhui Yang <cyan@cyano.uk>
Date: Fri, 3 Oct 2025 00:07:52 +0800
Subject: [PATCH 63/73] 10_linux.in: read /etc/os-release to specify OS class

Some theme uses OS classes to determine OS type. We missed that in the
initial rewrite.

Also add some extra OS classes such as 'gnu-linux'.
---
 util/grub.d/10_linux.in | 16 +++++++++++++++-
 1 file changed, 15 insertions(+), 1 deletion(-)

diff --git a/util/grub.d/10_linux.in b/util/grub.d/10_linux.in
index 29edc26e1..560098f2a 100644
--- a/util/grub.d/10_linux.in
+++ b/util/grub.d/10_linux.in
@@ -203,8 +203,12 @@ linux_entry() {
 	local initrd="$3"
 	local args="$4"
 	local _id="$5"
+	local os_class="$(get_os_id)"
+	if [ ! -z "$os_class" ];  then
+		os_class="--class $(echo $os_class | grub_quote)"
+	fi
 
-	printf "${indent}menuentry '%s' --class linux \$menuentry_id_option '%s' {\n" "$title" "$_id"
+	printf "${indent}menuentry '%s' $os_class --class gnu --class gnu-linux --class linux \$menuentry_id_option '%s' {\n" "$title" "$_id"
 	printf "$(echo "$MENUENTRY_PREP" | sed "s|^|\t${indent}|g")\n"
 	printf "${indent}\t$_GFXPAYLOAD_LINUX\n"
 	printf "${indent}\t$SAVEDEFAULT\n"
@@ -303,6 +307,16 @@ prioritize() {
 	IFS="$OLDIFS"
 }
 
+get_os_id() {
+(
+	if [ ! -e /etc/os-release ] ; then
+		return
+	fi
+	source "/etc/os-release"
+	echo "$ID"
+)
+}
+
 scan_for_kernels() {
 	local scanned
 	IFS=$'\n'
-- 
