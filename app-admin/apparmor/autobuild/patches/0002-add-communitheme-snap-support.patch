From 15f5c7a03655a4ac6643562c61694c62cdbc0683 Mon Sep 17 00:00:00 2001
From: Didier Roche <didier.roche@canonical.com>
Date: Wed, 11 Apr 2018 10:25:10 +0000
Subject: [PATCH 2/5] add communitheme snap support

Forwarded: no
---
 profiles/apparmor.d/abstractions/freedesktop.org | 4 ++++
 profiles/apparmor.d/abstractions/gnome           | 4 ++++
 2 files changed, 8 insertions(+)

diff --git a/profiles/apparmor.d/abstractions/freedesktop.org b/profiles/apparmor.d/abstractions/freedesktop.org
index cb5e1ecfb..0020de91d 100644
--- a/profiles/apparmor.d/abstractions/freedesktop.org
+++ b/profiles/apparmor.d/abstractions/freedesktop.org
@@ -19,6 +19,10 @@
   @{system_share_dirs}/icons/{**,}        r,
   @{system_share_dirs}/pixmaps/{**,}      r,
 
+  # communitheme snap
+  /snap/communitheme/*/share/icons/   r,
+  /snap/communitheme/*/share/icons/** r,
+
   # this should probably go elsewhere
   @{system_share_dirs}/mime/** r,
 
diff --git a/profiles/apparmor.d/abstractions/gnome b/profiles/apparmor.d/abstractions/gnome
index ca2eb394f..8907a9beb 100644
--- a/profiles/apparmor.d/abstractions/gnome
+++ b/profiles/apparmor.d/abstractions/gnome
@@ -31,6 +31,10 @@
   /usr/share/themes/**            r,
   /usr/share/gtk-3.0/settings.ini r,
 
+  # communitheme snap
+  /snap/communitheme/*/share/themes/   r,
+  /snap/communitheme/*/share/themes/** r,
+
   # for gnome 1 applications
   /etc/orbitrc                    r,
 
-- 
2.50.1

