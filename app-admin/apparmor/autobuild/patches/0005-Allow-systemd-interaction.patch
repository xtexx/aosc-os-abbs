From acaee978375c06db5297403c4539a3a94c662e03 Mon Sep 17 00:00:00 2001
From: Ryan Lee <ryan.lee@canonical.com>
Date: Fri, 13 Jun 2025 11:34:04 -0700
Subject: [PATCH 5/5] Allow systemd interaction

Gbp-Pq: ubuntu/samba-systemd-interaction.patch.
---
 profiles/apparmor.d/usr.sbin.smbd | 12 ++++++++++++
 1 file changed, 12 insertions(+)

diff --git a/profiles/apparmor.d/usr.sbin.smbd b/profiles/apparmor.d/usr.sbin.smbd
index 149743eed..f7aae7564 100644
--- a/profiles/apparmor.d/usr.sbin.smbd
+++ b/profiles/apparmor.d/usr.sbin.smbd
@@ -27,12 +27,22 @@ profile smbd /usr/{bin,sbin}/smbd {
 
   signal send set=term peer=samba-bgqd,
 
+  # when started by systemd
+  ptrace read peer=unconfined,
+
   /etc/mtab r,
   /etc/netgroup r,
   /etc/printcap r,
   /etc/samba/* rwk,
   @{PROC}/@{pid}/mounts r,
   @{PROC}/sys/kernel/core_pattern r,
+
+  # https://gitlab.com/apparmor/apparmor/-/issues/203
+  # needed when smbd is started by systemd
+  @{PROC}/1/environ r,
+  @{PROC}/cmdline r,
+  @{PROC}/sys/kernel/osrelease r,
+
   /usr/lib*/samba/vfs/*.so mr,
   /usr/lib*/samba/auth/*.so mr,
   /usr/lib*/samba/charset/*.so mr,
@@ -57,6 +67,8 @@ profile smbd /usr/{bin,sbin}/smbd {
   @{run}/samba/** rk,
   @{run}/samba/ncalrpc/ rw,
   @{run}/samba/ncalrpc/** rw,
+  # when started by systemd
+  @{run}/systemd/notify w,
   /var/spool/samba/** rw,
 
   @{HOMEDIRS}/** lrwk,
-- 
