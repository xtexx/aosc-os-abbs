PKGNAME=runc
PKGSEC=admin
PKGDEP="criu libseccomp"
BUILDDEP="go go-md2man"
PKGDES="CLI tool for spawning and running containers according to the OCI specification"

# FIXME: Missing criu support
FAIL_ARCH="riscv64"

# Note: -tags seccomp enables libseccomp support.
#
# Note: -mod=mod, we updated libseccomp-golang in go.mod to add support
# for LoongArch, specifying this option ensures that we are using freshly
# pulled dependencies instead of vendored ones.
GO_BUILD_AFTER="-tags seccomp -mod=mod"

ABTYPE=gomod
