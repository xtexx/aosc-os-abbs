PKGNAME=fcron
PKGSEC=admin
PKGDEP="linux-pam debianutils"
PKGSUG="mta"
BUILDDEP="postfix"
PKGDES="Periodical command scheduler"

PKGPROV="cron"

ABTYPE=autotools
# FIXME: Many "missing template" errors.
RECONF=0
# Note: sysconfdir set to /etc/fcron to remain consistent with previous
# versions.
AUTOTOOLS_AFTER=(
    '--sysconfdir=/etc/fcron'
    '--with-sendmail=/usr/bin/sendmail'
    '--with-shell=/usr/bin/bash'
    '--with-editor=/usr/bin/editor'
    '--with-piddir=/run'
    '--with-spooldir=/var/spool/fcron'
    '--with-proc=/proc'
    '--with-docdir=/usr/share/doc/fcron'
    '--with-systemdsystemunitdir=/usr/lib/systemd/system'
    '--with-run-non-privileged=no'
    '--with-fcrondyn=yes'
    '--with-rootname=root'
    '--with-rootgroup=wheel'
    '--with-username=fcron'
    '--with-groupname=fcron'
    '--with-sysfcrontab=yes'
    '--with-boot-install=no'
    '--with-answer-all=no'
    '--with-audit=no'
    '--with-pam=yes'
    '--with-selinux=no'
)
