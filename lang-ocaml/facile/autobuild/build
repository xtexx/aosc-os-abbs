abinfo "Building Facile ..."
cd "$SRCDIR"/lib
make

abinfo "Installing Facile ..."
install -dv "$PKGDIR"/usr/lib/ocaml/facile
if ab_match_archgroup ocaml_native; then
    install -Dvm644 "$SRCDIR"/lib/facile.a "$SRCDIR"/lib/facile.cmi \
        "$SRCDIR"/lib/facile.cma "$SRCDIR"/lib/facile.cmxa \
        "$PKGDIR"/usr/lib/ocaml/facile
else
    install -Dvm644 "$SRCDIR"/lib/facile.cmi "$SRCDIR"/lib/facile.cma \
        "$PKGDIR"/usr/lib/ocaml/facile
fi
