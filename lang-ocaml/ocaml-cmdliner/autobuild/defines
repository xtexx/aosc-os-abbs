PKGNAME=ocaml-cmdliner
PKGSEC=utils
PKGDEP="ocaml"
PKGDES="Declarative definition of command line interfaces for OCaml"
BUILDDEP="dune"

ABTYPE=dune
ABSTRIP=0

# FIXME: OCaml based softwares use static libraries to link
NOSTATIC=0

# FIXME: ocamlopt doesn't generate seperated debug symbol
ABSPLITDBG=0

# FIXME: Enabling LTO makes ocamlc to invoke gcc with LTO enabled, resulting in
# build-time failures.
NOLTO=1
