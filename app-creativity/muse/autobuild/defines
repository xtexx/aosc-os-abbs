PKGNAME=muse
PKGDEP="alsa-lib dssi fluidsynth gcc-runtime glibc jack ladish liblo liblrdf \
        libsamplerate libsndfile lilv qt-5 rtaudio serd"
PKGRECOM="pyqt5 dssi-vst"
BUILDDEP="ladspa-sdk extra-cmake-modules"
PKGSEC=sound
PKGDES="A multi-track DAW focusing on MIDI sequencing"

ABTYPE=cmakeninja

# TODO: package libinstpatch and let MusE use it for automatic additional
#       drum kit listing.
CMAKE_AFTER=(
    '-DENABLE_PYTHON=ON'
    '-DENABLE_LV2_GTK2=OFF'
    '-DENABLE_INSTPATCH=OFF'
    '-DCMAKE_SKIP_INSTALL_RPATH=OFF'
    '-DLIB_INSTALL_DIR=/usr/lib'
)
