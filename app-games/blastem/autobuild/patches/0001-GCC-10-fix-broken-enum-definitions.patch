From d49535e316a6e731fee03e00dfa4013501243ffc Mon Sep 17 00:00:00 2001
From: CyberNeko-AI <cyberneko.ai@aosc.io>
Date: Sun, 8 Mar 2026 11:34:39 +0800
Subject: [PATCH 1/5] Fix broken enum definitions that cause multiple
 definition errors when building with -fno-common which is now the 
 default in GCC 10.

This patch was originally introduced in the upstream BlastEm Mercurial
repository.

GCC 10 and newer default to `-fno-common`, which causes linker errors
if the same global variable is defined in multiple translation units.
(e.g., in `vdp.h`, an enum declaration mistakenly included `vdp_regs`
at the end, creating a global variable in every file that included
the header.)

Removing the unused `vdp_regs`, `x86_regs` and `x86_regs_enc` variable
identifier leaves a standard anonymous enum. This satisfies the 
linker checks.

This commit regenerates the previously existing diff into a standard
Git patch format. This is done to ensure structural consistency across
patch series.

Original Author: Mike Pavone <pavone@retrodev.com>
Origin: https://www.retrodev.com/repos/blastem/rev/e45a317802bd
Upstream-Status: Backport

[Mingcong Bai: extracted the upstream patch]
Signed-off-by: Mingcong Bai <jeffbai@aosc.io>
[CyberNeko-AI: regenerated patch from raw diff]
Signed-off-by: CyberNeko-AI <cyberneko.ai@aosc.io>

---
 gen_x86.c | 2 +-
 gen_x86.h | 8 ++++----
 vdp.h     | 2 +-
 3 files changed, 6 insertions(+), 6 deletions(-)

diff --git a/gen_x86.c b/gen_x86.c
index 33a9a0e..3901917 100644
--- a/gen_x86.c
+++ b/gen_x86.c
@@ -130,7 +130,7 @@ enum {
 	X86_R13,
 	X86_R14,
 	X86_R15
-} x86_regs_enc;
+};
 
 char * x86_reg_names[] = {
 #ifdef X86_64
diff --git a/gen_x86.h b/gen_x86.h
index d384107..3e80930 100644
--- a/gen_x86.h
+++ b/gen_x86.h
@@ -30,7 +30,7 @@ enum {
 	R13,
 	R14,
 	R15
-} x86_regs;
+};
 
 enum {
 	CC_O = 0,
@@ -51,14 +51,14 @@ enum {
 	CC_GE,
 	CC_LE,
 	CC_G
-} x86_cc;
+};
 
 enum {
 	SZ_B = 0,
 	SZ_W,
 	SZ_D,
 	SZ_Q
-} x86_size;
+};
 
 #ifdef X86_64
 #define SZ_PTR SZ_Q
@@ -78,7 +78,7 @@ enum {
 	MODE_REG_DIRECT = 0xC0,
 //"phony" mode
 	MODE_IMMED = 0xFF
-} x86_modes;
+};
 
 void rol_ir(code_info *code, uint8_t val, uint8_t dst, uint8_t size);
 void ror_ir(code_info *code, uint8_t val, uint8_t dst, uint8_t size);
diff --git a/vdp.h b/vdp.h
index a11c0a4..ff0d36d 100644
--- a/vdp.h
+++ b/vdp.h
@@ -93,7 +93,7 @@ enum {
 	REG_DMASRC_L,
 	REG_DMASRC_M,
 	REG_DMASRC_H
-} vdp_regs;
+};
 
 //Mode reg 1
 #define BIT_VSCRL_LOCK 0x80
-- 
