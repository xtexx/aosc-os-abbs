PKGNAME=vba-m
PKGSEC=games
PKGDEP="bzip2 ffmpeg gcc-runtime glib glibc gtk-3 openal-soft sdl2 wxbase \
        wxgtk3 x11-lib xz zlib"
BUILDDEP="cmake ninja"
PKGDES="A Nintendo GameBoy Advance emulator"

ABTYPE=cmakeninja
CMAKE_AFTER=(
    '-DENABLE_WX=TRUE'
    '-DENABLE_DEBUGGER=TRUE'
    '-DENABLE_SDL=FALSE'
    '-DENABLE_LINK=TRUE'
    '-DENABLE_FFMPEG=TRUE'
    '-DBUILD_TESTING=OFF'
)

PKGPROV="visualboyadvance-m"
