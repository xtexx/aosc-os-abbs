From 1c1b47e3b44254a4e7e85356a0c15a59754bd09d Mon Sep 17 00:00:00 2001
From: Mingcong Bai <jeffbai@aosc.io>
Date: Mon, 12 Aug 2024 01:14:50 +0800
Subject: [PATCH] fix: use Vulkan as the default (and recommended) backend

As of at least June of 2023, the upstream code introduced a change that causes
games to lose input after losing focus for the first time (until the next time
the user launches dolphin-emu) in OpenGL render mode. The upstream is yet to
identify the root cause of this issue (citing the lack of Linux hardware on
hand) - so until we find a solution on our own, demote OpenGL as the default
rendering backend to avoid confusion.

Promote Vulkan as the preferred rendering backend since it is probably readily
available on hardware that supports OpenGL 3.0 (which the emulator requires).

Fingers crossed for that being the case.

See:

https://bugs.dolphin-emu.org/issues/13354
dolphin-emu@c63f0f3#diff-4758964fe112db861ede53e23f9660201a2799dcad3428f3fcfdc137504e4b39
---
 Source/Core/VideoCommon/VideoBackendBase.cpp | 4 +---
 1 file changed, 1 insertion(+), 3 deletions(-)

diff --git a/Source/Core/VideoCommon/VideoBackendBase.cpp b/Source/Core/VideoCommon/VideoBackendBase.cpp
index e8f9f91b..e61097da 100644
--- a/Source/Core/VideoCommon/VideoBackendBase.cpp
+++ b/Source/Core/VideoCommon/VideoBackendBase.cpp
@@ -243,9 +243,6 @@ const std::vector<std::unique_ptr<VideoBackendBase>>& VideoBackendBase::GetAvail
     backends.push_back(std::make_unique<DX11::VideoBackend>());
     backends.push_back(std::make_unique<DX12::VideoBackend>());
 #endif
-#ifdef HAS_OPENGL
-    backends.push_back(std::make_unique<OGL::VideoBackend>());
-#endif
 #ifdef HAS_VULKAN
 #ifdef __APPLE__
     // Emplace the Vulkan backend at the beginning so it takes precedence over OpenGL.
@@ -259,6 +256,7 @@ const std::vector<std::unique_ptr<VideoBackendBase>>& VideoBackendBase::GetAvail
     backends.emplace(backends.begin(), std::make_unique<Metal::VideoBackend>());
 #endif
 #ifdef HAS_OPENGL
+    backends.push_back(std::make_unique<OGL::VideoBackend>());
     backends.push_back(std::make_unique<SW::VideoSoftware>());
 #endif
     backends.push_back(std::make_unique<Null::VideoBackend>());
-- 
2.49.0

