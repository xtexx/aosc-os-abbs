abinfo "Configuring scummvm ..."
"$SRCDIR"/configure \
    "${AUTOTOOLS_DEF[@]}" \
    "--enable-all-engines" \
    "--enable-release" \
    "--enable-debug" \
    "--with-manual-version=${PKGVER}"

abinfo "Building scummvm ..."
make V=1 VERBOSE=1

abinfo "Installing scummvm ..."
make install V=1 VERBOSE=1 \
    DESTDIR="$PKGDIR"
