VER=20.1.8
REL=5

# Use tarball-based source when possible
SRCS="tbl::https://github.com/llvm/llvm-project/releases/download/llvmorg-$VER/llvm-project-$VER.src.tar.xz"
SUBDIR="llvm-project-$VER.src/llvm"
# Use git-based source when the upstream hasn't uploaded their own tarball yet
#SRCS="git::commit=tags/llvmorg-${VER}::https://github.com/llvm/llvm-project.git"
#SUBDIR="llvm-20/llvm"

CHKSUMS="sha256::6898f963c8e938981e6c4a302e83ec5beb4630147c7311183cf61069af16333d"
CHKUPDATE="anitya::id=1830"
# Note: Prefer larger RAM.
ENVREQ__ARM64="total_mem=60"
# Note: Prefer 3C5000 (or faster) build hosts.
ENVREQ__LOONGARCH64="core=16"
ENVREQ__LOONGARCH64_NOSIMD="${ENVREQ__LOONGARCH64}"
# Note: No RISC-V buildbots can provide 3 GiB memory per core
ENVREQ__RISCV64="total_mem_per_core=1"
