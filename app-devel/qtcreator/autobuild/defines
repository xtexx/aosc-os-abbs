PKGNAME=qtcreator
PKGSEC=devel
PKGDEP="cmake gdb git go litehtml llvm qt-6 rustc-demangle \
        syntax-highlighting valgrind"
# FIXME: Valgrind is not yet available.
PKGDEP__LOONGARCH64="${PKGDEP/valgrind/}"
PKGDEP__RISCV64="${PKGDEP/valgrind/}"
PKGSUG="breezy mercurial"
BUILDDEP="${PKGSUG}"
PKGDES="Integrated development environment for Qt/C++"
PKGPROV="qt-creator"

CMAKE_AFTER=(
    "-DBUILD_PLUGIN_CLANGREFACTORING=ON"
    "-DBUILD_PLUGIN_CLANGPCHMANAGER=ON"
    "-DCLANGTOOLING_LINK_CLANG_DYLIB=ON"
    "-DWITH_DOCS=ON"
    "-Djournald=ON"
    "-DBUILD_DEVELOPER_DOCS=ON"
    "-DBUILD_WITH_PCH=OFF"
    "-DCMAKE_INSTALL_LIBDIR=lib"
    "-DCMAKE_SKIP_INSTALL_RPATH=OFF"
)
USECLANG=1
# FIXME: clang++: error: clang frontend command failed with exit code 132 (use -v to see invocation)
USECLANG__RISCV64=0
