From 096d2d6381d054a3090b95640b90e2c66e12bf6e Mon Sep 17 00:00:00 2001
From: Xinhui Yang <cyan@cyano.uk>
Date: Tue, 11 Mar 2025 09:54:14 +0800
Subject: [PATCH 86/88] AOSC: gcc/Makefile.in: do not run fixinc.sh

This came from one of the sed commands in GCC's autobuild/prepare
script.
---
 gcc/Makefile.in | 2 +-
 1 file changed, 1 insertion(+), 1 deletion(-)

diff --git a/gcc/Makefile.in b/gcc/Makefile.in
index 775aaa1b3c4..b998a89ac22 100644
--- a/gcc/Makefile.in
+++ b/gcc/Makefile.in
@@ -3289,7 +3289,7 @@ stmp-fixinc: gsyslimits.h macro_list fixinc_list \
 	      gcc_dir=`${PWD_COMMAND}` ; \
 	      export TARGET_MACHINE srcdir SHELL MACRO_LIST && \
 	      cd $(build_objdir)/fixincludes && \
-	      $(SHELL) ./fixinc.sh "$${gcc_dir}/$${fix_dir}" \
+	      $(SHELL) -c true "$${gcc_dir}/$${fix_dir}" \
 	        $(BUILD_SYSTEM_HEADER_DIR) $(OTHER_FIXINCLUDES_DIRS) ); \
 	  done; \
 	fi
-- 
2.48.1

