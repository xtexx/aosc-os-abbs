From 0e9cbc1bd1fce687b44431c00751868d040f98bf Mon Sep 17 00:00:00 2001
From: Xinhui Yang <cyan@cyano.uk>
Date: Tue, 11 Mar 2025 09:58:16 +0800
Subject: [PATCH 88/88] AOSC: go: fix runtime library path for Go to
 $GCC_PREFIX/lib

- This came from one of the sed commands in GCC's autobuild/prepare
  script.
- We really don't need to separate /lib and /lib64.
---
 gcc/go/lang-specs.h | 2 +-
 1 file changed, 1 insertion(+), 1 deletion(-)

diff --git a/gcc/go/lang-specs.h b/gcc/go/lang-specs.h
index 4fce64b42a9..a7f02fe1d76 100644
--- a/gcc/go/lang-specs.h
+++ b/gcc/go/lang-specs.h
@@ -21,5 +21,5 @@ along with GCC; see the file COPYING3.  If not see
    for the Go language.  */
 
 {".go",  "@go", 0, 1, 0},
-{"@go",  "go1 %i %(cc1_options) %{I*} %{L*} %D %{!fsyntax-only:%(invoke_as)}",
+{"@go",  "go1 %i %(cc1_options) %{I*} %{L*} -L/usr/lib %{!fsyntax-only:%(invoke_as)}",
     0, 1, 0},
-- 
2.48.1

