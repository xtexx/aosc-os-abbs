abinfo "Unpack and Apply patch for bazel platforms ..."
mkdir -pv "$SRCDIR"/override_module/platforms/
cd "$SRCDIR"/override_module/platforms/
tar pxvf "$SRCDIR"/platforms.tar.gz
ab_apply_patches "$SRCDIR"/autobuild/patches/0001-bazel-platforms-support.patch

abinfo "Unpack and Apply patch for bazel rules_go ..."
mkdir -pv "$SRCDIR"/override_module/rules_go/
cd "$SRCDIR"/override_module/rules_go/
unzip "$SRCDIR"/rules_go.zip
ab_apply_patches "$SRCDIR"/autobuild/patches/0002-bazel-rules_go-support.patch

abinfo "Unpack and Apply patch for bazel rules_java ..."
mkdir -pv "$SRCDIR"/override_module/rules_java/
cd "$SRCDIR"/override_module/rules_java/
tar pxvf  "$SRCDIR"/rules_java.tar.gz
ab_apply_patches "$SRCDIR"/autobuild/patches/0003-bazel-rules_java-support.patch

abinfo "Start Compile bazel Task ..."
cd "$SRCDIR"
source scripts/bootstrap/buildenv.sh
source scripts/bootstrap/compile.sh
source scripts/bootstrap/bootstrap.sh

bazel_build "src:bazel_nojdk" \
  --action_env=PATH \
  --host_platform=@platforms//host \
  --platforms=@platforms//host \
  --tool_java_runtime_version=local_jdk \
  --verbose_failures \
  --override_module=platforms=$SRCDIR/override_module/platforms/ \
  --override_module=rules_go=$SRCDIR/override_module/rules_go \
  --override_module=rules_java=$SRCDIR/override_module/rules_java

abinfo "Task complete. Install bazel ..."
install -Dvm0755 "$SRCDIR"/bazel-bin/src/bazel_nojdk \
    "$PKGDIR"/usr/bin/bazel

mkdir -pv "$PKGDIR"/usr/lib/bazel/
for i in third_party tools; do
    cp -av "$SRCDIR"/$i "$PKGDIR"/usr/lib/bazel/
done
