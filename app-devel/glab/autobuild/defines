PKGNAME=glab
PKGSEC=vcs
PKGDES="Command-line tool to work with GitLab servers"
PKGDEP="glibc git"
BUILDDEP="go"

ABTYPE=gomod
GO_LDFLAGS=(
    "-X main.debugMode=false"
    "-X main.commit=AOSC"
    "-X main.version='v${PKGVER}'"
)
GO_PACKAGES=("cmd/glab")

# FIXME: Autobuild does not yet support splitting debug symbols out of Go
# executables.
ABSPLITDBG=0
