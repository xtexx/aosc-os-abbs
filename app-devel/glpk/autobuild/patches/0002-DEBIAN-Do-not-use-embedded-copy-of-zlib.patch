From bb8e62702dcd3cdc7b2839f4c145d6859201441c Mon Sep 17 00:00:00 2001
From: =?UTF-8?q?S=C3=A9bastien=20Villemot?= <sebastien@debian.org>
Date: Tue, 25 Jun 2013 00:00:00 +0000
Subject: [PATCH 2/3] DEBIAN: Do not use embedded copy of zlib

This patch header follows DEP-3: http://dep.debian.net/deps/dep3/

Signed-off-by: Mingcong Bai <jeffbai@aosc.io>
---
 configure.ac    |  2 ++
 src/Makefile.am | 20 ++------------------
 2 files changed, 4 insertions(+), 18 deletions(-)

diff --git a/configure.ac b/configure.ac
index a5679f1..6be3a70 100644
--- a/configure.ac
+++ b/configure.ac
@@ -196,6 +196,8 @@ AC_CHECK_LIB([colamd], [colamd])
 CPPFLAGS="$CPPFLAGS -I/usr/include/suitesparse"
 AC_CHECK_HEADER([amd.h])
 
+AC_CHECK_LIB([z], [gzopen])
+
 AC_CONFIG_FILES(
    [src/Makefile examples/Makefile Makefile])
 AC_OUTPUT
diff --git a/src/Makefile.am b/src/Makefile.am
index d837563..3d51b64 100644
--- a/src/Makefile.am
+++ b/src/Makefile.am
@@ -16,8 +16,7 @@ libglpk_la_CPPFLAGS = \
 -I$(srcdir)/mpl \
 -I$(srcdir)/npp \
 -I$(srcdir)/proxy \
--I$(srcdir)/simplex \
--I$(srcdir)/zlib
+-I$(srcdir)/simplex
 
 libglpk_la_LDFLAGS = \
 -version-info 43:1:3 \
@@ -187,21 +186,6 @@ simplex/spxprim.c \
 simplex/spxprob.c \
 simplex/spychuzc.c \
 simplex/spychuzr.c \
-simplex/spydual.c \
-zlib/adler32.c \
-zlib/compress.c \
-zlib/crc32.c \
-zlib/deflate.c \
-zlib/gzclose.c \
-zlib/gzlib.c \
-zlib/gzread.c \
-zlib/gzwrite.c \
-zlib/inffast.c \
-zlib/inflate.c \
-zlib/inftrees.c \
-zlib/trees.c \
-zlib/uncompr.c \
-zlib/zio.c \
-zlib/zutil.c
+simplex/spydual.c
 
 ## eof ##
-- 
2.52.0

