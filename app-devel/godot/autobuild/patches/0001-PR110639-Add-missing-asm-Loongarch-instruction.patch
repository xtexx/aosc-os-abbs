From 3506e5fdbfc8ec0d25f347d1bdda39a292a10b90 Mon Sep 17 00:00:00 2001
From: MBCX <github.small792@passinbox.com>
Date: Wed, 17 Sep 2025 20:49:06 -0400
Subject: [PATCH] Add missing asm Loongarch instruction for `_cpu_pause` and
 add memory clobbers for the rest.

---
 core/os/spin_lock.h | 10 +++++++---
 1 file changed, 7 insertions(+), 3 deletions(-)

diff --git a/core/os/spin_lock.h b/core/os/spin_lock.h
index 7a5051035373..968d2cdcdfd0 100644
--- a/core/os/spin_lock.h
+++ b/core/os/spin_lock.h
@@ -80,11 +80,15 @@ _ALWAYS_INLINE_ static void _cpu_pause() {
 #if defined(__i386__) || defined(__x86_64__) // x86.
 	__builtin_ia32_pause();
 #elif defined(__arm__) || defined(__aarch64__) // ARM.
-	asm volatile("yield");
+	// Use memory clobber to prevent
+	// reorder/optimization by the compiler.
+	asm volatile("yield" ::: "memory");
 #elif defined(__powerpc__) // PowerPC.
-	asm volatile("or 27,27,27");
+	asm volatile("or 27,27,27" ::: "memory");
 #elif defined(__riscv) // RISC-V.
-	asm volatile(".insn i 0x0F, 0, x0, x0, 0x010");
+	asm volatile(".insn i 0x0F, 0, x0, x0, 0x010" ::: "memory");
+#elif defined(__loongarch64) // Loongarch64.
+	asm volatile("nop" ::: "memory");
 #endif
 #endif
 }
