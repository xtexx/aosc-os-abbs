From accbeabfbb56eafbf476fcda2bedff4a5046ea80 Mon Sep 17 00:00:00 2001
From: Mingcong Bai <jeffbai@aosc.io>
Date: Sun, 2 Feb 2025 23:52:54 +0800
Subject: [PATCH] AOSCOS: libiberty: append -O2 to cpp invocations

In the current autobuild version, CPPFLAGS contains -D_FORTIFY_SOURCE=3
without -O.  Thus the preprocessor will emit a warning, causing the
configure script to believe some system headers, notably limits.h, are
not usable.  Then the code will attempt to avoid using limits.h and the
build will fail due to missing LONG_MIN.

This is technically an autobuild issue and it may affect more packages
in more subtle ways.  Thus this is just a workaround and it should be
removed once autobuild is fixed.

Signed-off-by: Mingcong Bai <jeffbai@aosc.io>
Signed-off-by: Xi Ruoyao <xry111@xry111.site> # reword
---
 libiberty/configure | 18 +++++++++---------
 1 file changed, 9 insertions(+), 9 deletions(-)

diff --git a/libiberty/configure b/libiberty/configure
index 4c72b5a9283..d84ef723a20 100755
--- a/libiberty/configure
+++ b/libiberty/configure
@@ -2460,7 +2460,7 @@ fi
 ## -------------------- ##
 
 ac_ext=c
-ac_cpp='$CPP $CPPFLAGS'
+ac_cpp='$CPP $CPPFLAGS -O2'
 ac_compile='$CC -c $CFLAGS $CPPFLAGS conftest.$ac_ext >&5'
 ac_link='$CC -o conftest$ac_exeext $CFLAGS $CPPFLAGS $LDFLAGS conftest.$ac_ext $LIBS >&5'
 ac_compiler_gnu=$ac_cv_c_compiler_gnu
@@ -3000,7 +3000,7 @@ $as_echo "$as_me: target_header_dir = $target_header_dir" >&6;}
 
 
 ac_ext=c
-ac_cpp='$CPP $CPPFLAGS'
+ac_cpp='$CPP $CPPFLAGS -O2'
