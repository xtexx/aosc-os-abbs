From 0a3ef331ee38682136fd5bbac8e358d32971b1e7 Mon Sep 17 00:00:00 2001
From: Xi Ruoyao <xry111@xry111.site>
Date: Tue, 31 Mar 2026 21:11:34 +0800
Subject: [PATCH 1/3] AOSCOS: build as C++ 14

Some gpgme headers require C++ 14 features.

Signed-off-by: Xi Ruoyao <xry111@xry111.site>
---
 CMakeLists.txt | 1 +
 1 file changed, 1 insertion(+)

diff --git a/CMakeLists.txt b/CMakeLists.txt
index 291ce87d..d731b4dd 100644
--- a/CMakeLists.txt
+++ b/CMakeLists.txt
@@ -11,6 +11,7 @@ project(kget VERSION ${RELEASE_SERVICE_VERSION})
 set(REQUIRED_QT_VERSION "5.15.0")
 set(KF5_VERSION "5.91.0")
 set(KDE_COMPILERSETTINGS_LEVEL "5.82")
+set(CMAKE_CXX_STANDARD "14")
 
 find_package(ECM ${KF5_VERSION} REQUIRED NO_MODULE)
 
