From a0843bd1b7a2e5554f11fc2d3e9c6f7d554d2ed1 Mon Sep 17 00:00:00 2001
From: Casian Andrei <casian@candrei.ro>
Date: Wed, 3 Jan 2024 15:56:13 +0200
Subject: [PATCH 3/5] BACKPORT: Use FindPython3 instead of FindPythonInterp and
 FindPythonLibs

Fixes CMake warning regarding CMP0148 - deprecation of FindPythonInterp
and FindPythonLibs.

Require CMake 3.19 because of the usage of the version range.

(cherry picked from commit 39a057cab8a73a38ac485962f3fa475c05b4b796)
---
 CMakeLists.txt            | 27 ++++-----------------------
 kdevpythonversion.h.cmake | 14 +++++++-------
 parser/CMakeLists.txt     |  4 ++--
 3 files changed, 13 insertions(+), 32 deletions(-)

diff --git a/CMakeLists.txt b/CMakeLists.txt
index 5077e63ffe4e..d73f03b69275 100644
--- a/CMakeLists.txt
+++ b/CMakeLists.txt
@@ -1,4 +1,4 @@
-cmake_minimum_required(VERSION 3.16)
+cmake_minimum_required(VERSION 3.19)
 
 # KDE Gear version, managed by release service script
 set(RELEASE_SERVICE_VERSION_MAJOR "23")
@@ -41,28 +41,9 @@ endif()
 
 add_definitions( -DTRANSLATION_DOMAIN=\"kdevpython\" )
 
-# CMake looks for exactly the specified version first and ignores newer versions.
-# To avoid that, start looking for the newest supported version and work down.
-set(Python_ADDITIONAL_VERSIONS 3.13 3.12 3.11 3.10 3.9 3.8 3.7 3.6 3.5 3.4)
-foreach(_PYTHON_V ${Python_ADDITIONAL_VERSIONS})
-    find_package(PythonInterp ${_PYTHON_V})
-    if ( PYTHONINTERP_FOUND )
-        break()
-    endif()
-endforeach()
-# Must unset before searching for libs, otherwise these are checked before the required version...
-unset(Python_ADDITIONAL_VERSIONS)
-
-if ( PYTHONINTERP_FOUND AND PYTHON_VERSION_STRING VERSION_GREATER "3.4" )
-    # Find libraries that match the found interpreter (mismatched versions not supported).
-    # This assumes libs are available for the newest Python version on the system.
-    # KDevelop should _always_ be built against the newest possible version, so notabug.
-    find_package(PythonLibs "${PYTHON_VERSION_MAJOR}.${PYTHON_VERSION_MINOR}" REQUIRED EXACT)
-endif()
-
-if ( NOT PYTHONLIBS_FOUND OR PYTHONLIBS_VERSION_STRING VERSION_LESS "3.4.3" )
-    message(FATAL_ERROR "Python >= 3.4.3 but < 3.12 with --enable-shared is required to build kdev-python")
-endif()
+set(Python3_USE_STATIC_LIBS FALSE)
+set(Python3_FIND_STRATEGY VERSION)
+find_package(Python3 3.4.3...<3.13 COMPONENTS Interpreter Development REQUIRED)
 
 configure_file(kdevpythonversion.h.cmake "${CMAKE_CURRENT_BINARY_DIR}/kdevpythonversion.h" @ONLY)
 
diff --git a/kdevpythonversion.h.cmake b/kdevpythonversion.h.cmake
index 93181401422c..161d4090911d 100644
--- a/kdevpythonversion.h.cmake
+++ b/kdevpythonversion.h.cmake
@@ -7,15 +7,15 @@
 #ifndef KDEVPYTHON_VERSION_H
 #define KDEVPYTHON_VERSION_H
 
-#define PYTHON_VERSION_MINOR @PYTHON_VERSION_MINOR@
-#define PYTHON_VERSION_MINOR_STR "@PYTHON_VERSION_MINOR@"
+#define PYTHON_VERSION_MINOR @Python3_VERSION_MINOR@
+#define PYTHON_VERSION_MINOR_STR "@Python3_VERSION_MINOR@"
 
-#define PYTHON_VERSION_MAJOR @PYTHON_VERSION_MAJOR@
-#define PYTHON_VERSION_MAJOR_STR "@PYTHON_VERSION_MAJOR@"
+#define PYTHON_VERSION_MAJOR @Python3_VERSION_MAJOR@
+#define PYTHON_VERSION_MAJOR_STR "@Python3_VERSION_MAJOR@"
 
-#define PYTHON_VERSION QT_VERSION_CHECK(@PYTHON_VERSION_MAJOR@, @PYTHON_VERSION_MINOR@, @PYTHON_VERSION_PATCH@)
-#define PYTHON_VERSION_STR "@PYTHON_VERSION_MAJOR@.@PYTHON_VERSION_MINOR@"
+#define PYTHON_VERSION QT_VERSION_CHECK(@Python3_VERSION_MAJOR@, @Python3_VERSION_MINOR@, @Python3_VERSION_PATCH@)
+#define PYTHON_VERSION_STR "@Python3_VERSION_MAJOR@.@Python3_VERSION_MINOR@"
 
-#define PYTHON_EXECUTABLE "@PYTHON_EXECUTABLE@"
+#define PYTHON_EXECUTABLE "@Python3_EXECUTABLE@"
 
 #endif
diff --git a/parser/CMakeLists.txt b/parser/CMakeLists.txt
index 75901078f27a..c7fc2f9e1353 100644
--- a/parser/CMakeLists.txt
+++ b/parser/CMakeLists.txt
@@ -16,7 +16,7 @@ ecm_qt_declare_logging_category(parser_STAT_SRCS
     EXPORT KDEVPYTHON
 )
 
-include_directories(${PYTHON_INCLUDE_DIRS})
+include_directories(${Python3_INCLUDE_DIRS})
 
 add_library( kdevpythonparser SHARED ${parser_STAT_SRCS} )
 
@@ -26,7 +26,7 @@ generate_export_header(kdevpythonparser EXPORT_MACRO_NAME KDEVPYTHONPARSER_EXPOR
 target_link_libraries(kdevpythonparser LINK_PRIVATE
     KDev::Language
     Qt5::Core
-    ${PYTHON_LIBRARIES}
+    Python3::Python
 )
 
 install(TARGETS kdevpythonparser DESTINATION ${KDE_INSTALL_TARGETS_DEFAULT_ARGS})
-- 
