From a1621c8f5320a22994384c0c59a75472d22e2ada Mon Sep 17 00:00:00 2001
From: Sven Brauch <mail@svenbrauch.de>
Date: Sun, 12 May 2024 17:41:05 +0200
Subject: [PATCH 2/5] BACKPORT: fix python string -> QString conversion

How did this ever work before? PyUnicode_GET_LENGTH is documented
to return the size of the string in code points. Except for UCS4
(which I'm pretty sure was never used... or was it?) this isn't
equal to the length of the array passed to the QString constructor.
This needs to be the size in bytes, which is pretty much completely
unrelated to the amount of code points.

I guess it worked by chance since it typically took the UCS2 path,
and typically all code points fit into 1 UCS2 surrogate. It seems
to use UTF8 now when used from KDevelop (not sure why) and that
makes it completely break down.

(cherry picked from commit 61ed3ce3d5cd7373a97f0d82dded1fdc06b1959b)
---
 parser/astbuilder.cpp | 22 ++++++++--------------
 1 file changed, 8 insertions(+), 14 deletions(-)

diff --git a/parser/astbuilder.cpp b/parser/astbuilder.cpp
index 32ab95c71157..ad3499bc367e 100644
--- a/parser/astbuilder.cpp
+++ b/parser/astbuilder.cpp
@@ -33,21 +33,15 @@ QString PyUnicodeObjectToQString(PyObject* obj) {
     auto pyObjectCleanup = [](PyObject* o) { if (o) Py_DECREF(o); };
     const auto strOwner = std::unique_ptr<PyObject, decltype(pyObjectCleanup)>(PyObject_Str(obj), pyObjectCleanup);
     const auto str = strOwner.get();
-    if (PyUnicode_READY(str) < 0) {
-        qWarning("PyUnicode_READY(%p) returned false!", (void*)str);
-        return QString();
+
+    Py_ssize_t size;
+    const char *ptr = PyUnicode_AsUTF8AndSize(str, &size);
+    if (!ptr) {
+        qCWarning(KDEV_PYTHON_PARSER) << "failed to convert python string to unicode";
+        return {};
     }
-    const auto length = PyUnicode_GET_LENGTH(str);
-    switch(PyUnicode_KIND(str)) {
-        case PyUnicode_1BYTE_KIND:
-            return QString::fromLatin1((const char*)PyUnicode_1BYTE_DATA(str), length);
-        case PyUnicode_2BYTE_KIND:
-            return QString::fromUtf16(PyUnicode_2BYTE_DATA(str), length);
-        case PyUnicode_4BYTE_KIND:
-            return QString::fromUcs4(PyUnicode_4BYTE_DATA(str), length);
-    }
-    qCritical("PyUnicode_KIND(%p) returned an unexpected value, this should not happen!", (void*)str);
-    Q_UNREACHABLE();
+
+    return QString::fromUtf8(ptr, size);
 }
 
 struct PythonParser : private QMutexLocker
