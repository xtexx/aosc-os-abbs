From 5761ce8684be20468bdb9fac4a7498283a3ec201 Mon Sep 17 00:00:00 2001
From: Antonio Rojas <arojas@archlinux.org>
Date: Sun, 17 Nov 2024 12:49:40 +0100
Subject: [PATCH 4/5] BACKPORT: Fix build with Python 3.13

Remove includes for headers which are already transitively included by Python.h and fail to be directly included in Python 3.13 without importing some c++ headers first

(cherry picked from commit 68ea8e24be31cf5e312db6cc35929ec56c3ec65e)
---
 CMakeLists.txt         | 2 +-
 parser/python_header.h | 5 -----
 2 files changed, 1 insertion(+), 6 deletions(-)

diff --git a/CMakeLists.txt b/CMakeLists.txt
index d73f03b69275..2ad0e5787232 100644
--- a/CMakeLists.txt
+++ b/CMakeLists.txt
@@ -43,7 +43,7 @@ add_definitions( -DTRANSLATION_DOMAIN=\"kdevpython\" )
 
 set(Python3_USE_STATIC_LIBS FALSE)
 set(Python3_FIND_STRATEGY VERSION)
-find_package(Python3 3.4.3...<3.13 COMPONENTS Interpreter Development REQUIRED)
+find_package(Python3 3.4.3...<3.14 COMPONENTS Interpreter Development REQUIRED)
 
 configure_file(kdevpythonversion.h.cmake "${CMAKE_CURRENT_BINARY_DIR}/kdevpythonversion.h" @ONLY)
 
diff --git a/parser/python_header.h b/parser/python_header.h
index 90dea6a51297..6fef957a7457 100644
--- a/parser/python_header.h
+++ b/parser/python_header.h
@@ -13,11 +13,6 @@
 
 #include <language/duchain/duchainlock.h>
 
-#include "pyport.h"
-#ifndef _WIN32
-#include "pyconfig.h"
-#endif
-
 #include "Python.h"
 
 #include "ast.h"
-- 
