PKGNAME=apache-arrow
PKGSEC=libs
PKGDES="A language-independent columnar memory format for flat and nested data"
PKGDEP="abseil-cpp boost gcc-runtime glibc grpc libutf8proc openssl protobuf re2 zlib"
BUILDDEP="gtest llvm"

ABTYPE=cmakeninja
CMAKE_AFTER=(
    -DARROW_BUILD_SHARED=ON
    -DARROW_BUILD_STATIC=OFF
    -DARROW_ACERO=ON
    -DARROW_AZURE=OFF       # FIXME: Requires the Azure SDK for C++
    -DARROW_COMPUTE=ON
    -DARROW_CSV=ON
    -DARROW_DATASET=ON
    -DARROW_FILESYSTEM=ON
    -DARROW_FLIGHT=ON
    -DARROW_FLIGHT_SQL=ON
    -DARROW_GANDIVA=ON
    -DARROW_GCS=OFF         # FIXME: Requires the GCloud SDK for C++
    -DARROW_HDFS=ON
    -DARROW_JEMALLOC=ON
    -DARROW_JSON=ON
    -DARROW_PARQUET=ON
    -DARROW_ORC=ON
    -DARROW_S3=OFF          # FIXME: Requires the AWS SDK for C++
    -DARROW_SKYHOOK=OFF     # FIXME: Requires librados, a part of https://github.com/ceph/ceph
    -DARROW_SUBSTRAIT=ON
    -DARROW_TENSORFLOW=ON
    -DPARQUET_REQUIRE_ENCRYPTION=ON
    -DARROW_TESTING=OFF
    -DARROW_TEST_LINKAGE=shared
)
PKGBREAK="pdal<=2.9.3"
