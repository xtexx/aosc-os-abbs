From 00272963fc5e9c832dfee248d552de351707c332 Mon Sep 17 00:00:00 2001
From: pch666777 <1005100717@qq.com>
Date: Wed, 21 May 2025 11:12:46 +0800
Subject: [PATCH 2/2] cmake build fix find zstd lib

---
 cmake/Modules/Findzstd.cmake         | 11 +++++++++++
 tiledb/CMakeLists.txt                |  2 +-
 tiledb/sm/compressors/CMakeLists.txt |  2 +-
 3 files changed, 13 insertions(+), 2 deletions(-)
 create mode 100644 cmake/Modules/Findzstd.cmake

diff --git a/cmake/Modules/Findzstd.cmake b/cmake/Modules/Findzstd.cmake
new file mode 100644
index 000000000..9c2edffda
--- /dev/null
+++ b/cmake/Modules/Findzstd.cmake
@@ -0,0 +1,11 @@
+if(NOT PkgConfig_FOUND)
+    find_package(PkgConfig REQUIRED)
+endif()
+pkg_check_modules(ZSTD REQUIRED libzstd)
+if(NOT zstd::libzstd)
+    add_library(zstd::libzstd SHARED IMPORTED)
+    set_target_properties(zstd::libzstd PROPERTIES
+        IMPORTED_LOCATION "${ZSTD_LIBDIR}/libzstd.so"
+        INTERFACE_INCLUDE_DIRECTORIES "${ZSTD_INCLUDE_DIRS}"
+        INTERFACE_COMPILE_DEFINITIONS "${ZSTD_CFLAGS_OTHER}")
+endif()
diff --git a/tiledb/CMakeLists.txt b/tiledb/CMakeLists.txt
index 30338a096..5df77815b 100644
--- a/tiledb/CMakeLists.txt
+++ b/tiledb/CMakeLists.txt
@@ -571,7 +571,7 @@ find_package(BZip2 REQUIRED)
 find_package(LZ4 MODULE REQUIRED)
 find_package(spdlog REQUIRED)
 find_package(ZLIB REQUIRED)
-find_package(zstd CONFIG REQUIRED)
+find_package(zstd MODULE REQUIRED)
 find_package(LibMagic MODULE REQUIRED)
 target_link_libraries(TILEDB_CORE_OBJECTS_ILIB
   INTERFACE
diff --git a/tiledb/sm/compressors/CMakeLists.txt b/tiledb/sm/compressors/CMakeLists.txt
index a1ac41ec1..711b165df 100644
--- a/tiledb/sm/compressors/CMakeLists.txt
+++ b/tiledb/sm/compressors/CMakeLists.txt
@@ -39,7 +39,7 @@ commence(object_library compressors)
     find_package(BZip2 REQUIRED)
     find_package(LZ4 MODULE REQUIRED)
     find_package(ZLIB REQUIRED)
-    find_package(zstd CONFIG REQUIRED)
+    find_package(zstd MODULE REQUIRED)
     this_target_link_libraries(BZip2::BZip2 lz4::lz4 ZLIB::ZLIB zstd::libzstd)
 conclude(object_library)
 
-- 
2.49.0

