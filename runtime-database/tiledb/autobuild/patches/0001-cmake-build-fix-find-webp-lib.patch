From 2f1969364c13129ff9ffa2c9d48046affa7c1bde Mon Sep 17 00:00:00 2001
From: pch666777 <1005100717@qq.com>
Date: Wed, 21 May 2025 10:08:48 +0800
Subject: [PATCH 1/2] cmake build fix find webp lib

---
 cmake/Modules/FindWebP.cmake | 11 +++++++++++
 1 file changed, 11 insertions(+)
 create mode 100644 cmake/Modules/FindWebP.cmake

diff --git a/cmake/Modules/FindWebP.cmake b/cmake/Modules/FindWebP.cmake
new file mode 100644
index 000000000..ead8fefbf
--- /dev/null
+++ b/cmake/Modules/FindWebP.cmake
@@ -0,0 +1,11 @@
+if(NOT PkgConfig_FOUND)
+    find_package(PkgConfig REQUIRED)
+endif()
+pkg_check_modules(WebP REQUIRED libwebp)
+if(NOT WebP::webp)
+    add_library(WebP::webp SHARED IMPORTED)
+    set_target_properties(WebP::webp PROPERTIES
+        IMPORTED_LOCATION "${WebP_LIBDIR}/libwebp.so"
+        INTERFACE_INCLUDE_DIRECTORIES "${WebP_INCLUDE_DIRS}"
+        INTERFACE_COMPILE_DEFINITIONS "${WebP_CFLAGS_OTHER}")
+endif()
