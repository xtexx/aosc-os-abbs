# Fedora: Replace bundled droid-fonts-fallback
abinfo "Replacing bundled DroidSansFallBackFull ..."
ln -svf "../../../fonts/TTF/DroidSansFallbackFull.ttf" \
	"${PKGDIR}/usr/share/ghostscript/Resource/CIDFSubst/DroidSansFallback.ttf"

# Fedora: Replace bundled urw-fonts files
for font in $(basename --multiple "$PKGDIR/usr/share/ghostscript/Resource/Font/"*); do
	abinfo "Replacing bundled ${font} ..."
	ln -svf "../../../fonts/Type1/${font}.afm" \
		"$PKGDIR/usr/share/ghostscript/Resource/Font/${font}"
done

# Fedora: Replace bundled CMap files
abinfo "Replacing bundled CMap files with ones from poppler-data ..."
for directory in $(ls "/usr/share/poppler/cMap"); do
	for file in $(ls "/usr/share/poppler/cMap/${directory}"); do
		if [ ! -f "${PKGDIR}/usr/share/ghostscript/Resource/CMap/${file}" ]; then
			continue
		fi
		abinfo "Replacing bundled CMap ${file} ..."
		ln -svf "../../../poppler/cMap/${directory}/${file}" \
			"$PKGDIR/usr/share/ghostscript/Resource/CMap/${file}"
	done
done

# Remove libgxps.so symlink to avoid conflict with libgxps
rm -v "${PKGDIR}/usr/lib/libgxps.so"

# Create symlink for gs -> gsc
ln -sv gsc "${PKGDIR}/usr/bin/gs"
