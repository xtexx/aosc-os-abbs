PKGNAME=lyx
PKGSEC=tex
PKGDEP="boost enchant file imagemagick mythes qt-6 texlive"
PKGSUG="rcs"
BUILDDEP="bc"
PKGDES="Graphical LaTeX editor and document processor"

ABTYPE=cmakeninja
CMAKE_AFTER=(
    '-DLYX_CPACK=OFF'
    '-DLYX_INSTALL=ON'
    '-DLYX_NLS=ON'
    '-DLYX_REQUIRE_SPELLCHECK=OFF'
    '-DLYX_ASPELL=ON'
    '-DLYX_ENCHANT=ON'
    '-DLYX_HUNSPELL=ON'
    '-DLYX_RELEASE=ON'
    '-DLYX_DEBUG=OFF'
    '-DLYX_NO_OPTIMIZE=OFF'
    '-DLYX_ENABLE_ASSERTIONS=OFF'
    '-DLYX_PCH=OFF'
    '-DLYX_MERGE_FILES=OFF'
    '-DLYX_MERGE_REBUILD=OFF'
    '-DLYX_QUIET=OFF'
    '-DLYX_BUNDLE=OFF'
    '-DLYX_ENABLE_URLTESTS=OFF'
    '-DLYX_ENABLE_EXPORT_TESTS=OFF'
    '-DLYX_ENABLE_KEYTESTS=OFF'
    '-DLYX_ENABLE_VALGRIND_TESTS=OFF'
    '-DLYX_USE_QT=QT6'
    '-DLYX_USE_IPO=ON'
    '-DLYX_DISABLE_CALLSTACK_PRINTING=OFF'
    '-DLYX_EXTERNAL_Z=ON'
    '-DLYX_EXTERNAL_DTL=ON'
    '-DLYX_EXTERNAL_ICONV=ON'
    '-DLYX_EXTERNAL_HUNSPELL=ON'
    '-DLYX_EXTERNAL_MYTHES=ON'
    '-DLYX_PROFILE=ON'
    '-DLYX_PROGRAM_SUFFIX=OFF'
    '-DLYX_DEBUG_GLIBC=OFF'
    '-DLYX_DEBUG_GLIBC_PEDANTIC=OFF'
    '-DLYX_DEBUG_GLIBC_ASSERTIONS=OFF'
    '-DLYX_STDLIB_DEBUG=OFF'
