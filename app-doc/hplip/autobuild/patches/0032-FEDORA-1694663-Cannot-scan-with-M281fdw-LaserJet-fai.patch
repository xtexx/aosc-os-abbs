From fe505905c41139ade6300952472cd5465421d49e Mon Sep 17 00:00:00 2001
From: Mingcong Bai <jeffbai@aosc.io>
Date: Wed, 19 Nov 2025 19:05:08 +0800
Subject: [PATCH 32/74] FEDORA: 1694663 - Cannot scan with M281fdw LaserJet -
 failed: Error during device I/O (hpmud/model.c)

Signed-off-by: Zdenek Dohnal <zdohnal@redhat.com>

Link: https://src.fedoraproject.org/rpms/hplip/c/e04106b6551fb6d4b28df992c9e55d4538fddda5?branch=rawhide
Signed-off-by: Mingcong Bai <jeffbai@aosc.io>
---
 io/hpmud/model.c | 5 ++++-
 1 file changed, 4 insertions(+), 1 deletion(-)

diff --git a/io/hpmud/model.c b/io/hpmud/model.c
index 4ea8990..72c630b 100644
--- a/io/hpmud/model.c
+++ b/io/hpmud/model.c
@@ -420,7 +420,10 @@ static int ParseFile(char *datFile, char *model, char *attr, int attrSize, int *
          strncpy(section, rcbuf+1, sizeof(section)); /* found new section */
          n = strlen(section);
          section[n-2]=0; /* remove ']' and CR */
-         if (strcasecmp(model, section) == 0)
+         if (strcasecmp(model, section) == 0 ||
+            (section[0] == 'h' && section[1] == 'p' &&
+             section[2] == '_' &&
+             strcasecmp(model, section + 3) == 0))
          {
             /* Found model match. */
             *bytes_read = ResolveAttributes(fp, attr, attrSize); 
