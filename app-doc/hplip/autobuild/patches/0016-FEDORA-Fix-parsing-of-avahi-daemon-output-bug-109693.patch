From 2d977484645fc55797bf639be998ff8fdf077b83 Mon Sep 17 00:00:00 2001
From: Mingcong Bai <jeffbai@aosc.io>
Date: Wed, 19 Nov 2025 19:05:08 +0800
Subject: [PATCH 16/74] FEDORA: Fix parsing of avahi-daemon output (bug
 #1096939).

Signed-off-by: Jiri Popelka <jpopelka@redhat.com>

Link: https://src.fedoraproject.org/rpms/hplip/blob/6806ada431e5a2b56298e9957f9e95a48cd15aaa/f/hplip-avahi-parsing.patch
Signed-off-by: Mingcong Bai <jeffbai@aosc.io>
---
 base/avahi.py | 7 ++++++-
 1 file changed, 6 insertions(+), 1 deletion(-)

diff --git a/base/avahi.py b/base/avahi.py
index 51795dd..dd9c790 100755
--- a/base/avahi.py
+++ b/base/avahi.py
@@ -52,9 +52,14 @@ def detectNetworkDevices(ttl=4, timeout=10):
                              'status_code': 0, 'device2': '0', 'device3': '0', 'note': ''}
                         y['ip'] = ip
                         y['hn'] = bits[6].replace('.local', '')
-                        details = bits[9].split('" "')
+                        details = bits[9].rstrip ().strip ('"').split('" "')
                         for item in details:
                             key, value = item.split('=', 1)
+                            keyvalue = item.split('=', 1)
+                            if len (keyvalue) < 2:
+                                # Skip parts that don't match key=value
+                                continue
+                            key, value = keyvalue
                             if key == 'ty':
                                 y['mdns'] = value
                                 y['device1'] = "MFG:Hewlett-Packard;MDL:%s;CLS:PRINTER;" % value
-- 
