From 4454e0fe7773c45929c50530cd07ad7d9bf352b5 Mon Sep 17 00:00:00 2001
From: Mingcong Bai <jeffbai@aosc.io>
Date: Wed, 19 Nov 2025 21:23:41 +0800
Subject: [PATCH 67/74] FEDORA: Use new HP GPG key for plugin validation

HP now uses new key pair for signing plugin tarball as fix for
CVE-2025-43023, but hplip code was still downloading the old one, thus
validation always failed.

Signed-off-by: Zdenek Dohnal <zdohnal@redhat.com>

Link: https://src.fedoraproject.org/rpms/hplip/c/be70bd6792c1b3d232805da4c8678273e2ddf7c6?branch=rawhide
Signed-off-by: Mingcong Bai <jeffbai@aosc.io>
---
 base/validation.py | 2 +-
 1 file changed, 1 insertion(+), 1 deletion(-)

diff --git a/base/validation.py b/base/validation.py
index 812f8c5..ca0e051 100644
--- a/base/validation.py
+++ b/base/validation.py
@@ -45,7 +45,7 @@ class GPG_Verification(DigiSign_Verification):
     def __init__(self, keyservers = ['keyserver.ubuntu.com',
                                      'pgp.surf.nl',
                                      'pgp.mit.edu'],
-                 key = 0x4ABA2F66DBD5A95894910E0673D770CDA59047B9):
+                 key = 0x82FFA7C6AA7411D934BDE173AC69536A2CF3A243):
         self.__keyservers = keyservers
         self.__key = key
         self.__gpg = utils.which('gpg',True)
-- 
2.51.1

