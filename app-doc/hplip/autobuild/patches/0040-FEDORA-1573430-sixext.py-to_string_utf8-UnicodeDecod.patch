From 1e6e92ef013753579c2d493367595d1fa56acd3f Mon Sep 17 00:00:00 2001
From: Mingcong Bai <jeffbai@aosc.io>
Date: Wed, 19 Nov 2025 19:05:09 +0800
Subject: [PATCH 40/74] FEDORA: 1573430 -
 sixext.py:to_string_utf8:UnicodeDecodeError: 'utf-8' codec can't decode bytes

Signed-off-by: Zdenek Dohnal <zdohnal@redhat.com>

Link: https://src.fedoraproject.org/rpms/hplip/c/9ac914b020a3df5aad8b4ede8be4cc28a7540796?branch=rawhide
Signed-off-by: Mingcong Bai <jeffbai@aosc.io>
---
 base/sixext.py | 4 ++--
 1 file changed, 2 insertions(+), 2 deletions(-)

diff --git a/base/sixext.py b/base/sixext.py
index 0bf4fc4..311bf72 100644
--- a/base/sixext.py
+++ b/base/sixext.py
@@ -110,11 +110,11 @@ if PY3:
 
 
     def to_string_utf8(s):
-        return s.decode("utf-8")
+        return s.decode("utf-8", 'ignore')
 
 
     def to_string_latin(s):
-        return s.decode("latin-1")
+        return s.decode("latin-1", 'ignore')
 
 
     def to_unicode(s, enc=None):
-- 
2.51.1

