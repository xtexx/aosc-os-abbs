From 998da84b08338f10834701439cc911699e42fb2e Mon Sep 17 00:00:00 2001
From: Mingcong Bai <jeffbai@aosc.io>
Date: Thu, 20 Nov 2025 15:41:46 +0800
Subject: [PATCH 74/74] AOSCOS: correctly handle --disable-imageProcessor-build

DISABLE_IMAGEPROCESSOR_BUILD, the variable associated with
--disable-imageProcessor-build, was defined in configure.in, but was never
referenced by Makefile.am, nor used to disable linkage to the closed-
source libImageProcessor.

Correct this by adding a condition for it in Makefile.in.

Link: https://bugs.launchpad.net/hplip/+bug/2131999
Signed-off-by: Mingcong Bai <jeffbai@aosc.io>
---
 Makefile.am | 7 ++++++-
 1 file changed, 6 insertions(+), 1 deletion(-)

diff --git a/Makefile.am b/Makefile.am
index 8f7e735..b8fe9b0 100644
--- a/Makefile.am
+++ b/Makefile.am
@@ -598,7 +598,10 @@ hpcups_SOURCES = prnt/hpcups/HPCupsFilter.cpp prnt/hpcups/HPCupsFilter.h prnt/hp
 	prnt/hpcups/ImageProcessor.h
 
 hpcups_CXXFLAGS = $(APDK_ENDIAN_FLAG) $(DBUS_CFLAGS)
-hpcups_LDADD = -L./prnt/hpcups/ -ljpeg -ldl -lImageProcessor -lcups -lcupsimage -lz $(DBUS_LIBS)
+hpcups_LDADD = -L./prnt/hpcups/ -ljpeg -ldl -lcups -lcupsimage -lz $(DBUS_LIBS)
+if !DISBALE_IMAGEPROCESSOR_BUILD
+hpcups_LDADD += -lImageProcessor
+endif
 #else
 #hpcupsdir = $(cupsfilterdir)
 #hpcups_PROGRAMS = hpcups
@@ -702,6 +705,7 @@ endif #HPLIP_CLASS_DRIVER
 
 install-data-hook:
 if HPLIP_BUILD
+if !DISBALE_IMAGEPROCESSOR_BUILD
 	if [ \( "$(UNAME)" = "x86_64" -a  -d "$(libdir)/" \) ]; then \
 		cp prnt/hpcups/libImageProcessor-x86_64.so $(libdir)/ ; \
 		chmod 775 $(libdir)/libImageProcessor-x86_64.so ; \
@@ -712,6 +716,7 @@ if HPLIP_BUILD
 		chmod 775 $(libdir)/libImageProcessor-x86_32.so ; \
 		ln -sf $(libdir)/libImageProcessor-x86_32.so $(libdir)/libImageProcessor.so ; \
 	fi
+endif
 	if [ -d "/usr/share/ipp-usb/quirks/" ]; then \
 		echo "ipp-usb directory exists"; \
 		cp prnt/ipp-usb/HPLIP.conf /usr/share/ipp-usb/quirks/ ; \
-- 
