From d91b77bb731fbe44c4633485a84cb9d54c1e4547 Mon Sep 17 00:00:00 2001
From: Mingcong Bai <jeffbai@aosc.io>
Date: Wed, 19 Nov 2025 19:05:09 +0800
Subject: [PATCH 49/74] FEDORA: 1985251 - Incorrect permission for gpg
 directory

Signed-off-by: Zdenek Dohnal <zdohnal@redhat.com>

Link: https://src.fedoraproject.org/rpms/hplip/c/581db10c37b226869e4202881eec72bf08332732?branch=rawhide
Signed-off-by: Mingcong Bai <jeffbai@aosc.io>
---
 base/validation.py | 2 +-
 1 file changed, 1 insertion(+), 1 deletion(-)

diff --git a/base/validation.py b/base/validation.py
index fe5fbe3..812f8c5 100644
--- a/base/validation.py
+++ b/base/validation.py
@@ -58,7 +58,7 @@ class GPG_Verification(DigiSign_Verification):
 
         if not os.path.exists(self.__gpg_dir):
             try:
-                os.mkdir(self.__gpg_dir, 0o755)
+                os.mkdir(self.__gpg_dir, 0o700)
             except OSError:
                 log.error("Failed to create %s" % self.__gpg_dir)
         self.__change_owner()
-- 
