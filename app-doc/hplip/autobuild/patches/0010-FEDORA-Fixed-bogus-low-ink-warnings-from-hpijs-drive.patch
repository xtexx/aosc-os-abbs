From 08872bfc540857e881cb00a9063b627b4825d6ee Mon Sep 17 00:00:00 2001
From: Mingcong Bai <jeffbai@aosc.io>
Date: Wed, 19 Nov 2025 19:05:08 +0800
Subject: [PATCH 10/74] FEDORA: Fixed bogus low ink warnings from hpijs driver
 (bug #643643).
MIME-Version: 1.0
Content-Type: text/plain; charset=UTF-8
Content-Transfer-Encoding: 8bit

Also:
  Fixed typo causing ";marker-supply-low-warning' state reason (bug #675151).

Signed-off-by: Tim Waugh <twaugh@redhat.com>
Signed-off-by: Jaromír Končický <jkoncick@redhat.com>

Link: https://src.fedoraproject.org/rpms/hplip/blob/69dc6c43d6ee3ac6696602942a565e598b21e001/f/hplip-hpijs-marker-supply.patch
Signed-off-by: Mingcong Bai <jeffbai@aosc.io>
---
 prnt/hpijs/hpijs.cpp | 8 ++++++--
 1 file changed, 6 insertions(+), 2 deletions(-)

diff --git a/prnt/hpijs/hpijs.cpp b/prnt/hpijs/hpijs.cpp
index 64b0121..ac67bb9 100644
--- a/prnt/hpijs/hpijs.cpp
+++ b/prnt/hpijs/hpijs.cpp
@@ -588,6 +588,7 @@ int main (int argc, char *argv[], char *evenp[])
    char *raster = NULL, *k_raster = NULL;
    int status = EXIT_FAILURE;
    int ret, n, i, kn=0, width, k_width;
+   int low_marker = 0;
    char user_name[32]={0,};
         
    openlog("hpijs", LOG_PID,  LOG_DAEMON);
@@ -675,14 +676,17 @@ int main (int argc, char *argv[], char *evenp[])
 			case WARN_LOW_INK_YELLOW:
 			case WARN_LOW_INK_MULTIPLE_PENS:
                         {
-                           fputs("STATE: +marker-supply-low-warning\n", stderr);
+			   low_marker = 1;
                            break;
                         }
 			default:
-                           fputs("STATE: +marker-supply-low-warning\n", stderr);
+			   low_marker = 1;
 		}
     }
 
+    fprintf(stderr, "STATE: %cmarker-supply-low-warning\n",
+	    low_marker ? '+' : '-');
+
 #if 0
    BUG("device model=%s\n", pSS->pPC->PrinterModel());
    BUG("device class=%s\n",  pSS->pPC->PrintertypeToString(pSS->pPC->SelectedDevice()));
-- 
