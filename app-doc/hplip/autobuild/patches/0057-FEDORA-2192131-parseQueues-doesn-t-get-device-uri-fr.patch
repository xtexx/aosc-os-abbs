From 30ad7b76da5b331dcc54f98c44b3b345eac3a6e4 Mon Sep 17 00:00:00 2001
From: Mingcong Bai <jeffbai@aosc.io>
Date: Wed, 19 Nov 2025 19:05:10 +0800
Subject: [PATCH 57/74] FEDORA: 2192131 - parseQueues() doesn't get device uri
 from 'lpstat -v', because parsing pattern changed

Signed-off-by: Zdenek Dohnal <zdohnal@redhat.com>

Link: https://src.fedoraproject.org/rpms/hplip/c/031349c9fd4e0d4e1d145151671128d7fc7e2f0c?branch=rawhide
Signed-off-by: Mingcong Bai <jeffbai@aosc.io>
---
 base/queues.py | 2 +-
 1 file changed, 1 insertion(+), 1 deletion(-)

diff --git a/base/queues.py b/base/queues.py
index 33a8d65..ac739e9 100755
--- a/base/queues.py
+++ b/base/queues.py
@@ -101,7 +101,7 @@ def parseQueues(mode):
             try:
                 match = LPSTAT_PATTERN.search(p)
                 printer_name = match.group(1)
-                device_uri = match.group(2)
+                device_uri = match.group(3)
                 cups_printers.append((printer_name, device_uri))
             except AttributeError:
                 pass
