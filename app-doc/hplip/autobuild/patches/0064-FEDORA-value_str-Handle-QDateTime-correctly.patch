Subject: [PATCH 64/74] FEDORA: value_str: Handle QDateTime correctly

Signed-off-by: FeRD (Frank Dana) <ferdnyc@gmail.com>

Link: https://src.fedoraproject.org/rpms/hplip/c/ea1621b02f742057f7efbe4cab4b38888e83505a?branch=rawhide
Signed-off-by: Mingcong Bai <jeffbai@aosc.io>
---
 ui5/ui_utils.py | 5 ++++-
 1 file changed, 4 insertions(+), 1 deletion(-)

diff --git a/ui5/ui_utils.py b/ui5/ui_utils.py
index caba339..225ca1c 100644
--- a/ui5/ui_utils.py
+++ b/ui5/ui_utils.py
@@ -105,7 +105,10 @@ def value_str(data):
     if data is None:
         return ""
     try:
-        if not PY3:
+        if PY3:
+            if isinstance(data, QDateTime):
+                data = data.toString()
+        else:
             try:
                 data = data.toString()
             except AttributeError as e:
