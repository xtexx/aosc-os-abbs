From 885b916fa242ee23506224088efc67d5e73757fd Mon Sep 17 00:00:00 2001
From: Mingcong Bai <jeffbai@aosc.io>
Date: Wed, 19 Nov 2025 19:05:09 +0800
Subject: [PATCH 43/74] FEDORA: fix infinite loop in password dialog in
 hp-toolbox

Signed-off-by: Zdenek Dohnal <zdohnal@redhat.com>

Link: https://src.fedoraproject.org/rpms/hplip/blob/ac182d7612c9f582a657f2b519e9caa41aa3efde/f/hplip-dialog-infinite-loop.patch
Signed-off-by: Mingcong Bai <jeffbai@aosc.io>
---
 ui5/devmgr5.py | 11 ++++++-----
 1 file changed, 6 insertions(+), 5 deletions(-)

diff --git a/ui5/devmgr5.py b/ui5/devmgr5.py
index 8a19840..31b8f0f 100644
--- a/ui5/devmgr5.py
+++ b/ui5/devmgr5.py
@@ -2318,14 +2318,15 @@ class PasswordDialog(QDialog):
 # XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
 
 def showPasswordUI(prompt):
+    dlg = None
+
     try:
         dlg = PasswordDialog(prompt, None)
+    except Exception as e:
+        log.error('Unable to open password dialog due following error:\n {}'.format(e))
 
-        if dlg.exec_() == QDialog.Accepted:
-            return (dlg.getUsername(), dlg.getPassword())
-
-    finally:
-        pass
+    if dlg and dlg.exec_() == QDialog.Accepted:
+        return (dlg.getUsername(), dlg.getPassword())
 
     return ("", "")
 
-- 
2.51.1

