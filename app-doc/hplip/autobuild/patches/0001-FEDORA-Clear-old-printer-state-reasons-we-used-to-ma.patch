From 9149275d1d7a529994d9993b6b551c393a989514 Mon Sep 17 00:00:00 2001
From: Mingcong Bai <jeffbai@aosc.io>
Date: Wed, 19 Nov 2025 18:59:36 +0800
Subject: [PATCH 01/74] FEDORA: - Clear old printer-state-reasons we used to
 manage (bug #510926).

Signed-off-by: Tim Waugh <twaugh@fedoraproject.org>
Signed-off-by: Jiri Popelka <jpopelka@redhat.com>

Link: https://src.fedoraproject.org/rpms/hplip/blob/90fce7b6d2d6a2342d2ba621f6b9eab33fde0328/f/hplip-clear-old-state-reasons.patch
Signed-off-by: Mingcong Bai <jeffbai@aosc.io>
---
 prnt/hpcups/HPCupsFilter.cpp | 7 +++++++
 1 file changed, 7 insertions(+)

diff --git a/prnt/hpcups/HPCupsFilter.cpp b/prnt/hpcups/HPCupsFilter.cpp
index 6750684..132e1c9 100644
--- a/prnt/hpcups/HPCupsFilter.cpp
+++ b/prnt/hpcups/HPCupsFilter.cpp
@@ -599,6 +599,13 @@ int HPCupsFilter::StartPrintJob(int  argc, char *argv[])
 
     signal(SIGTERM, HPCancelJob);
 
+/*
+ *  Prior to the re-write of hpcups, this filter managed the
+ *  marker-supply-low-warning printer state reason.  Make sure to
+ *  clear that state reason so that upgrades work correctly.
+ */
+    fputs ("STATE: -marker-supply-low-warning\n", stderr);
+
     cups_raster = cupsRasterOpen(fd, CUPS_RASTER_READ);
 
     if (cups_raster == NULL) {
-- 
