From 0af301a3814c4c47d3773df819cbd68644294962 Mon Sep 17 00:00:00 2001
From: Mingcong Bai <jeffbai@aosc.io>
Date: Wed, 19 Nov 2025 19:05:08 +0800
Subject: [PATCH 19/74] FEDORA: Don't try to write bytecode cache for hpfax
 backend (bug #1192761).

Resolves: rhbz#1192761

Also:
  - Don't try to write bytecode cache for hpps filter (bug #1241548).
  - Don't try to write bytecode cache for hp-config_usb_printer (bug #1266903).

Signed-off-by: Tim Waugh <twaugh@redhat.com>
Sigend-off-by: Jiri Popelka <jpopelka@redhat.com>

Link: https://src.fedoraproject.org/rpms/hplip/blob/7e44942d45690b583eb85878e3777f582f1a6183/f/hplip-no-write-bytecode.patch
Signed-off-by: Mingcong Bai <jeffbai@aosc.io>
---
 config_usb_printer.py | 2 +-
 fax/backend/hpfax.py  | 2 +-
 prnt/filters/hpps     | 2 +-
 3 files changed, 3 insertions(+), 3 deletions(-)

diff --git a/config_usb_printer.py b/config_usb_printer.py
index 2fc9508..10b352f 100755
--- a/config_usb_printer.py
+++ b/config_usb_printer.py
@@ -1,4 +1,4 @@
-#!/usr/bin/env python
+#!/usr/bin/env python -B
 # -*- coding: utf-8 -*-
 #
 # (c) Copyright 2011-2015 HP Development Company, L.P.
diff --git a/fax/backend/hpfax.py b/fax/backend/hpfax.py
index 4082ecc..f77f284 100755
--- a/fax/backend/hpfax.py
+++ b/fax/backend/hpfax.py
@@ -1,4 +1,4 @@
-#!/usr/bin/env python
+#!/usr/bin/env python -B
 # -*- coding: utf-8 -*-
 #
 # (c) Copyright 2003-2015 HP Development Company, L.P.
diff --git a/prnt/filters/hpps b/prnt/filters/hpps
index 00a4931..6681657 100644
--- a/prnt/filters/hpps
+++ b/prnt/filters/hpps
@@ -1,4 +1,4 @@
-#!/usr/bin/env python
+#!/usr/bin/env python -B
 # -*- coding: utf-8 -*-
 #
 # (c) Copyright 2003-2015 HP Development Company, L.P.
