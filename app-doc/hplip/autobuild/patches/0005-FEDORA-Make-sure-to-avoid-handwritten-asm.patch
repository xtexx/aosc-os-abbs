From b66f93f4f11543621ecfe55e664b35a8a144960d Mon Sep 17 00:00:00 2001
From: Mingcong Bai <jeffbai@aosc.io>
Date: Wed, 19 Nov 2025 19:05:07 +0800
Subject: [PATCH 05/74] FEDORA: Make sure to avoid handwritten asm.

Also:
  - Removed never-used definition of BREAKPOINT in scan/sane/common.h in hope
    of fixing the build.

Signed-off-by: Tim Waugh <twaugh@fedoraproject.org>
Signed-off-by: Jiri Popelka <jpopelka@redhat.com>

Link: https://src.fedoraproject.org/rpms/hplip/blob/b5dbf8cf037fb97b25c3762c6d3bf7ed794e4a51/f/hplip-no-asm.patch
Signed-off-by: Mingcong Bai <jeffbai@aosc.io>
---
 ip/xfax.c          | 13 -------------
 scan/sane/common.h |  2 --
 2 files changed, 15 deletions(-)

diff --git a/ip/xfax.c b/ip/xfax.c
index 8d7373b..8a72c18 100644
--- a/ip/xfax.c
+++ b/ip/xfax.c
@@ -1680,19 +1680,6 @@ static BOOL bits_flush_to_eol (
                  & ((1u<<n_bits) - 1u);                                      \
 }
 
-#if 0
-
-#define BITS_LOAD(g, num_bits, par_result) {                                 \
-    int n_bits = (int)(num_bits);                                            \
-                                                                             \
-    par_result = g->gb_cache;                                                \
-                                                                             \
-    asm ("extract %1,%2,%0"                                                  \
-        : "=d" (par_result)                                                  \
-        : "dI" (g->gb_cache_cnt - n_bits), "dI" (n_bits), "0" (par_result)); \
-}
-
-#endif
 
 
 
diff --git a/scan/sane/common.h b/scan/sane/common.h
index cdddd94..9c03c47 100644
--- a/scan/sane/common.h
+++ b/scan/sane/common.h
@@ -53,8 +53,6 @@
 
 #define BACKEND_NAME hpaio
 
-#define BREAKPOINT __asm( "int3" )
-
 #define OK 1
 #define ERROR 0
 #define MAX_LIST_SIZE 32
-- 
2.51.1

