From acdb60b315bdb629efec26c7c977d3f25e9cca33 Mon Sep 17 00:00:00 2001
From: Mingcong Bai <jeffbai@aosc.io>
Date: Wed, 19 Nov 2025 19:05:08 +0800
Subject: [PATCH 14/74] FEDORA: Scan to /var/tmp instead of /tmp (bug
 #1076954).

Resolves: rhbz#1076954

Also:
  Fixed scan-tmp patch (bug #1076954).
  Resolves: rhbz#1076954

Signed-off-by: Tim Waugh <twaugh@redhat.com>
Signed-off-by: Jiri Popelka <jpopelka@redhat.com>
Sigend-off-by: Zdenek Dohnal <zdohnal@redhat.com>

Link: https://src.fedoraproject.org/rpms/hplip/blob/faa6c09fce31f45a13899756a8be868c55ad63e6/f/hplip-scan-tmp.patch
Signed-off-by: Mingcong Bai <jeffbai@aosc.io>
---
 scan.py      | 2 +-
 scan/sane.py | 3 ++-
 2 files changed, 3 insertions(+), 2 deletions(-)

diff --git a/scan.py b/scan.py
index 1509b3a..30e5f19 100755
--- a/scan.py
+++ b/scan.py
@@ -1998,7 +1998,7 @@ try:
         if ('editor' in dest or 'viewer' in dest or 'email' in dest or 'print' in dest) \
             and not file_saved:
 
-            output_fd, output = utils.make_temp_file(suffix='.png')
+            output_fd, output = utils.make_temp_file(dir='/var/tmp', suffix='.png')
             try:
                 '''pyPlatform = platform.python_version()
                 num = pyPlatform.split('.')
diff --git a/scan/sane.py b/scan/sane.py
index e903bd5..7c29340 100755
--- a/scan/sane.py
+++ b/scan/sane.py
@@ -426,7 +426,8 @@ class ScanThread(threading.Thread):
         self.dev = device
         self.update_queue = update_queue
         self.event_queue = event_queue
-        self.buffer_fd, self.buffer_path = utils.make_temp_file(prefix='hpscan')
+        self.buffer_fd, self.buffer_path = utils.make_temp_file(dir='/var/tmp',
+                                                                prefix='hpscan')
         self.buffer = os.fdopen(self.buffer_fd, "w+b")
         self.format = -1
         self.format_name = ''
-- 
2.51.1

