From 273d63f4af2a8c6e6907ca97b83d090f55e4f010 Mon Sep 17 00:00:00 2001
From: Mingcong Bai <jeffbai@aosc.io>
Date: Wed, 19 Nov 2025 19:05:08 +0800
Subject: [PATCH 20/74] FEDORA: Ignore IOError when logging output (bug
 #712537).

Resolves: rhbz#712537

Signed-off-by: Tim Waugh <twaugh@redhat.com>

Link: https://src.fedoraproject.org/rpms/hplip/c/35446f4accc8bb5101c691080a101b523b1c0c15?branch=rawhide
Signed-off-by: Mingcong Bai <jeffbai@aosc.io>
---
 base/logger.py | 2 ++
 1 file changed, 2 insertions(+)

diff --git a/base/logger.py b/base/logger.py
index 653e8ff..7a95961 100644
--- a/base/logger.py
+++ b/base/logger.py
@@ -200,6 +200,8 @@ class Logger(object):
                         out.write('\n')
 
                     out.flush()
+                except IOError:
+                    pass
                 finally:
                     self._lock.release()
 
-- 
