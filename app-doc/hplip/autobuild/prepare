abinfo "Adding Python 3 include to CFLAGS, CXXFLAGS ..."
export CFLAGS="${CFLAGS} $(python3-config --includes)"
export CXXFLAGS="${CXXFLAGS} $(python3-config --includes)"

abinfo "Unsetting AUTOTOOLS_DEF ..."
export AUTOTOOLS_DEF=""

# FIXME: Makefile.am: error: required file './AUTHORS' not found
abinfo "Creating misc files required by autoreconf ..."
touch "$SRCDIR"/{AUTHORS,ChangeLog,NEWS,README}

abinfo "Updating printer device IDs ..."
mv -v "$SRCDIR"/prnt/drv/hpijs.drv.in{,.deviceIDs-drv-hpijs}
python3 "$SRCDIR"/autobuild/copy-deviceids.py \
    "$SRCDIR"/prnt/drv/hpcups.drv.in \
    "$SRCDIR"/prnt/drv/hpijs.drv.in.deviceIDs-drv-hpijs \
    > "$SRCDIR"/prnt/drv/hpijs.drv.in
