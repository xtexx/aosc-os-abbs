PKGNAME=graphviz
PKGSEC=graphics
PKGDES="Graph visualization software"

PKGDEP="libgd libtool librsvg x11-lib ghostscript pango gts libnsl2"
BUILDDEP=""

ABSHADOW=0

# FIXME: FTBFS with LTO
NOLTO=1

# FIXME: FTBFS
AUTOTOOLS_AFTER="--disable-ocaml \
                 --disable-php"
AUTOTOOLS_STRICT=0

# Installation fails with parallelism.
NOPARALLEL=1
