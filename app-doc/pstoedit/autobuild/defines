PKGNAME=pstoedit
PKGSEC=graphics
PKGDEP="libgd plotutils imagemagick"
PKGDES="Translates PostScript and PDF graphics into other vector formats"

ABTYPE=autotools
AUTOTOOLS_AFTER=(
    '--disable-docs'
    '--with-emf'
    '--with-magick'
    '--without-gui' # FIXME: qmake6: command not found
    '--with-libplot'
    '--with-swf'
    '--with-pptx'
)
# FIXME: /bin/sh: line 1: pstoedit.pro: No such file or directory
ABSHADOW=0
