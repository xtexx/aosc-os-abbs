PKGNAME=fish
PKGSEC=shells
PKGDEP="bc gcc-runtime ncurses coreutils findutils gawk python-3 \
        groff pcre2"
BUILDDEP="sphinx rustc llvm which"
PKGDES="A smart and user-friendly shell intended mostly for interactive use"

CMAKE_AFTER=(
    '-DBUILD_DOCS=ON'
    '-DFISH_USE_SYSTEM_PCRE2=ON'
    '-DCMAKE_INSTALL_SYSCONFDIR=/etc'
)

USECLANG=1
ABSHADOW=0

PKGBREAK="just<=1.39.0 rclone<=1.68.0-1"
