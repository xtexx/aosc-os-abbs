if ab_match_arch loongarch64 || ab_match_arch loongarch64_nosimd; then
    abinfo "Installing .NET source built artifacts ..."
    tar -xzvf /opt/Private.SourceBuilt.Artifacts.*.linux-loongarch64.tar.gz -C /usr/lib/dotnet/library-packs
fi

abinfo "Building PowerShell ..."
pwsh -File "$SRCDIR/autobuild/build.ps1"

abinfo "Creating symlink ..."
install -dv "$PKGDIR"/usr/bin
ln -sv /usr/lib/powershell/pwsh \
    "$PKGDIR"/usr/bin/pwsh

if ab_match_arch loongarch64 || ab_match_arch loongarch64_nosimd; then
    abinfo "Building native component ..."
    cd "$SRCDIR"/libpsl/src/libpsl-native/
    cmake -B build "$SRCDIR"/libpsl/src/libpsl-native/ "${CMAKE_DEF[@]}" "${CMAKE_AFTER[@]}"
    cmake --build build

    install -Dvm644 \
        "$SRCDIR"/libpsl/src/powershell-unix/libpsl-native.so \
        "$PKGDIR"/usr/lib/powershell
fi
