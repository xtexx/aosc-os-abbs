PKGNAME=opencolorio
PKGSEC=libs
PKGDEP="expat freeglut gcc-runtime glew glibc glu imath lcms2 minizip yaml-cpp"
BUILDDEP="python-3 pybind11"
PKGSUG="python-3"
PKGDES="Color management framework for visual effects and animation"

ABTYPE=cmakeninja
CMAKE_AFTER=(
    '-DBUILD_SHARED_LIBS=ON'
    '-DBUILD_TESTING=OFF'
    '-DOCIO_BUILD_APPS=ON'
    '-DOCIO_BUILD_DOCS=OFF'
    '-DOCIO_BUILD_GPU_TESTS=OFF'
    '-DOCIO_BUILD_JAVA=OFF'
    '-DOCIO_BUILD_NUKE=OFF'
    '-DOCIO_BUILD_OPENFX=OFF'
    '-DOCIO_BUILD_PYTHON=ON'
    '-DOCIO_BUILD_TESTS=OFF'
    '-DOCIO_ENABLE_SANITIZER=OFF'
    "-DOCIO_PYTHON_VERSION=${ABPY3VER}"
)

PKGBREAK="blender<=4.4.3-1 krita<=5.2.15-1 openimageio<=2.5.19.1-4"
