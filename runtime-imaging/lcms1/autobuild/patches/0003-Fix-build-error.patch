From: pch666777 <1005100717@qq.com>
Date: Mon, 3 Nov 2025 15:21:35 +0800
Subject: [PATCH] Fix build error

- Fix argument 'unsigned int' mismatch DWORD(long unsigned int).
---
 jpegicc/jpegicc.c | 5 ++++-
 1 file changed, 4 insertions(+), 1 deletion(-)

diff --git a/jpegicc/jpegicc.c b/jpegicc/jpegicc.c
index 38a793c..476bbe4 100755
--- a/jpegicc/jpegicc.c
+++ b/jpegicc/jpegicc.c
@@ -708,6 +708,7 @@ int TransformImage(char *cDefInpProf, char *cOutProf)
        int OutputColorSpace;
        DWORD dwFlags = 0; 
        DWORD EmbedLen;
+       unsigned int IccDataLen;
        LPBYTE EmbedBuffer;
 
 	   // Observer adaptation state (only meaningful on absolute colorimetric intent)
@@ -749,8 +750,10 @@ int TransformImage(char *cDefInpProf, char *cOutProf)
        }
         else {
 
-        if (!IgnoreEmbedded && read_icc_profile(&Decompressor, &EmbedBuffer, &EmbedLen))
+            // FIXME: error: passing argument 3 of ‘read_icc_profile’ from incompatible pointer type
+        if (!IgnoreEmbedded && read_icc_profile(&Decompressor, &EmbedBuffer, &IccDataLen))
         {
+              EmbedLen = (DWORD)IccDataLen;
               hIn = cmsOpenProfileFromMem(EmbedBuffer, EmbedLen);
 
                if (Verbose) {
