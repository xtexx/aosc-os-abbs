PKGNAME=librsvg
PKGDES="SVG rendering and manipulation library"
PKGSEC=libs
PKGDEP="cairo pango gdk-pixbuf dav1d glib freetype libxml2"
BUILDDEP="gobject-introspection vala rustc llvm cargo-c"
PKGDEP__RETRO="libcroco pango gdk-pixbuf"
# NOTE: Regenerating configure requires gtkdocize.
BUILDDEP__RETRO="gtk-doc"

ABTYPE=meson
MESON_AFTER=(
    '-Dintrospection=enabled'
    '-Dpixbuf=enabled'
    '-Drsvg-convert=enabled'
    '-Dpixbuf-loader=enabled'
    '-Ddocs=disabled'
    '-Dvala=enabled'
    '-Dtests=false'
    '-Davif=enabled'
)

ABTYPE__RETRO=autotools
AUTOTOOLS_AFTER__RETRO=(
	"--disable-vala"
	"--disable-gtk-doc"
	"--disable-introspection"
)

USECLANG=1
USECLANG__RETRO=0
