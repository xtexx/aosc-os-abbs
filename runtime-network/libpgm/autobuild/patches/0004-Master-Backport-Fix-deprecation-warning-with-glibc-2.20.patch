From 4038d32e67329549d248273b6849e4652efed32b Mon Sep 17 00:00:00 2001
From: Alexander Lukichev <alexander.lukichev@gmail.com>
Date: Sun, 20 Nov 2022 10:36:09 +0200
Subject: [PATCH 4/6] Fix deprecation warning with glibc >=2.20

From v2.20 on, glibc causes a warning if _BSD_SOURCE is defined
without _DEFAULT_SOURCE being defined as well (some light on
rationale is shed by LWN: https://lwn.net/Articles/590381/). That
makes builds on Linux with glibc-based toolchains polluted with
those warnings. This removes them.

Signed-off-by: Alexander Lukichev <alexander.lukichev@gmail.com>
---
 openpgm/pgm/configure.ac | 2 +-
 1 file changed, 1 insertion(+), 1 deletion(-)

diff --git a/configure.ac b/configure.ac
index 5d1854c..43082d4 100644
--- a/configure.ac
+++ b/configure.ac
@@ -45,7 +45,7 @@ CFLAGS="$CFLAGS -D_REENTRANT"
 AM_CONDITIONAL([AIX_XLC], [false])
 case "$host_os" in
 linux*)
-	CFLAGS="$CFLAGS -D_XOPEN_SOURCE=600 -D_BSD_SOURCE"
+	CFLAGS="$CFLAGS -D_XOPEN_SOURCE=600 -D_BSD_SOURCE -D_DEFAULT_SOURCE"
 	;;
 solaris*)
 	CFLAGS="$CFLAGS -D_XOPEN_SOURCE=600 -D__EXTENSIONS__"
