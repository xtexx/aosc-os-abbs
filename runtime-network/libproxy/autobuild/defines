PKGNAME=libproxy
PKGSEC=libs
PKGDEP="curl duktape gcc-runtime glib glibc"
BUILDDEP="gsettings-desktop-schemas gobject-introspection vala"
PKGDES="Library that provides automatic proxy configuration management"

ABTYPE=meson
MESON_AFTER=(
    '-Ddocs=false'
    '-Dtests=false'
    '-Dconfig-env=true'
    '-Dconfig-gnome=true'
    '-Dconfig-windows=true'
    '-Dconfig-sysconfig=true'
    '-Dconfig-osx=true'
    '-Dconfig-kde=true'
    '-Dconfig-xdp=true'
    '-Dpacrunner-duktape=true'
    '-Dvapi=true'
    '-Dcurl=true'
    '-Dintrospection=true'
    '-Drelease=true'
)
