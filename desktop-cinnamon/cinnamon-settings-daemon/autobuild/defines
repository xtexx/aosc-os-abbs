PKGNAME=cinnamon-settings-daemon
PKGSEC=Cinnamon
PKGDEP="cinnamon-desktop colord cups fontconfig gtk-3 lcms2 libcanberra \
        libnotify librsvg libwacom nss polkit systemd upower"
PKGDES="Settings daemon for Cinnamon"

ABTYPE=meson
MESON_AFTER=(
    '-Duse_polkit=enabled'
    '-Duse_logind=enabled'
    '-Duse_gudev=enabled'
    '-Duse_cups=enabled'
    '-Duse_smartcard=enabled'
    '-Duse_color=enabled'
    '-Duse_wacom=enabled'
    '-Denable_debug=false'
    '-Dgenerate_tz_coords=false'
)
