PKGNAME=openshadinglanguage
PKGSEC=libs
PKGDEP="gcc-runtime glibc imath llvm-runtime openimageio partio \
        pugixml qt-6"
BUILDDEP="llvm pybind11 python-3 robin-map"
PKGDES="Shading language for production GI renderers"

ABTYPE=cmakeninja
CMAKE_AFTER=(
    '-DBUILD_SHARED_LIBS=ON'
    '-DOSL_BUILD_PLUGINS=ON'
    '-DOSL_BUILD_SHADERS=ON'
    '-DOSL_BUILD_TESTS=OFF'
    '-DINSTALL_DOCS=OFF'
    '-DUSE_PYTHON=ON'
    '-DUSE_QT=ON'
)
