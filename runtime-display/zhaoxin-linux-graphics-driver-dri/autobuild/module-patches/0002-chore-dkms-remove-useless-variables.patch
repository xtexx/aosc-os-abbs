From a6628ccaee3695b8c8df4f043c609397026caa75 Mon Sep 17 00:00:00 2001
From: Aether Chen <15167799+chenjunyu19@users.noreply.github.com>
Date: Sat, 1 Nov 2025 16:50:19 +0800
Subject: [PATCH 2/9] chore: dkms: remove useless variables

REMAKE_INITRD was deprecated. SKIP_IMMD_MODPROBE is not standard.

Link: https://github.com/dkms-project/dkms/commit/961f9ceac4cf6772cb4c52bf4836a0f6c9818239
---
 dkms.conf | 5 -----
 1 file changed, 5 deletions(-)

diff --git a/dkms.conf b/dkms.conf
index 000017b..8c6ae33 100644
--- a/dkms.conf
+++ b/dkms.conf
@@ -1,16 +1,12 @@
 PACKAGE_NAME="zx"
 PACKAGE_VERSION=21.00.85
 AUTOINSTALL="yes"
-#REMAKE_INITRD="yes"
-SKIP_IMMD_MODPROBE=1
 
 
 BUILT_MODULE_NAME[0]="zx"
-BUILT_MODULE_LOCATION[0]=""
 DEST_MODULE_LOCATION[0]="/updates"
 
 BUILT_MODULE_NAME[1]="zx_core"
-BUILT_MODULE_LOCATION[1]=""
 DEST_MODULE_LOCATION[1]="/updates"
 
 
@@ -27,4 +23,3 @@ num_cpu_cores()
 }
 
 MAKE[0]="make -j$(num_cpu_cores) LINUXDIR=$kernel_source_dir -C $kernel_source_dir M=$dkms_tree/$module/$module_version/build"
-#POST_REMOVE="post-remove.sh $kernelver"
-- 
2.52.0

