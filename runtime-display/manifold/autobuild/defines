PKGNAME=manifold
PKGSEC=libs
PKGDEP="gcc-runtime glibc nanobind tbb"
BUILDDEP="python-3"
PKGSUG="python-3"
PKGDES="Geometry library for topological robustness"

ABTYPE=cmakeninja
CMAKE_AFTER=(
    '-DBUILD_SHARED_LIBS=ON'
    '-DBUILD_TESTING=OFF'
    '-DFETCHCONTENT_QUIET=OFF'
    '-DMANIFOLD_ASSERT=OFF'
    '-DMANIFOLD_CBIND=ON'
    '-DMANIFOLD_CROSS_SECTION=ON'
    '-DMANIFOLD_DEBUG=OFF'
    '-DMANIFOLD_DOWNLOADS=ON'
    '-DMANIFOLD_OPTIMIZED=ON'
    '-DMANIFOLD_PAR=ON'
    '-DMANIFOLD_PYBIND=ON'
    '-DMANIFOLD_STRICT=OFF'
    '-DMANIFOLD_TEST=ON'
    '-DMANIFOLD_USE_BUILTIN_CLIPPER2=ON'
    '-DMANIFOLD_USE_BUILTIN_NANOBIND=OFF'
    '-DMANIFOLD_USE_BUILTIN_TBB=OFF'
    '-DUSE_EXTERNAL_GBENCHMARK=OFF'
    '-DUSE_EXTERNAL_GTEST=OFF'
)
