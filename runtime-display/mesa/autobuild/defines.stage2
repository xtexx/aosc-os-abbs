PKGNAME=mesa
PKGSEC=libs
PKGDES="MesaLib - a OpenGL implementation"
PKGDEP="x11-lib libdrm expat elfutils nettle libglvnd pyyaml"
BUILDDEP="x11-proto mako"

PKGEPOCH=1

# Note: -Dwrap_mode=default is used for Crate dependencies.
MESON_AFTER=(
# Note: For stable-bound updates, use the following to disable assert().
    '-Db_ndebug=true'
# Note: Comment out line above for preview (RC or x.y.0) releases.
    '-Dsplit-debug=disabled'
    '-Dplatforms=x11'
    '-Degl-native-platform=auto'
    '-Ddri-drivers-path=/usr/lib/xorg/modules/dri'
    '-Dgallium-extra-hud=false'
    '-Dgallium-va=disabled'
    '-Dgallium-rusticl=false'
    '-Dstatic-libclc='
    '-Damdgpu-virtio=true'
    '-Dimagination-srv=true'
    '-Dshader-cache=enabled'
    '-Dshader-cache-default=true'
    '-Dvulkan-layers='
    '-Dgles1=enabled'
    '-Dgles2=enabled'
    '-Dopengl=true'
    '-Dlibgbm-external=false'
    '-Dglx=dri'
    '-Degl=enabled'
    '-Dglvnd=enabled'
    '-Dllvm=disabled'
    '-Dshared-llvm=disabled'
    '-Ddraw-use-llvm=false'
    '-Damd-use-llvm=false'
    '-Dllvm-orcjit=false'
    '-Dvalgrind=disabled'
    '-Dlibunwind=disabled'
    '-Dlmsensors=disabled'
    '-Dhtml-docs=disabled'
    '-Dtools='
    '-Dxlib-lease=enabled'
    '-Dglx-direct=true'
    '-Dzstd=enabled'
    '-Dzlib=enabled'
    '-Dsse2=false'
    '-Dperfetto=false'
    '-Dteflon=false'
    '-Dgpuvis=false'
    '-Dsysprof=false'
    '-Dvmware-mks-stats=false'
    '-Dvulkan-beta=false'
    '-Dintel-rt=disabled'
    '-Dintel-elk=false'
    '-Dvideo-codecs='
    '-Dgallium-d3d12-video=disabled'
    '-Dgallium-d3d12-graphics=disabled'
    '-Dxmlconfig=enabled'
    '-Dvirtgpu_kumquat=true'
    '-Dwrap_mode=default'
    # We actually needs nothing here for stage 2, but if the list is empty
    # meson will say "EGL requires DRI."
    '-Dgallium-drivers=softpipe'
    '-Dvulkan-drivers='
)

# FIXME: LLVM + Mesa + LTO + AMDGPU = artifacts.
NOLTO=1

# Note: Extra Provides for Spiral.
PKGPROV="libglx-mesa0_spiral"
