PKGNAME=libxkbcommon
PKGDES="Keyboard handling library using XKB data for X11 XCB clients"
PKGDEP="libxcb libxml2 wayland xkeyboard-config"
PKGDEP__RETRO="libxcb libxml2 xkeyboard-config"
PKGDEP__ARMV4="${PKGDEP__RETRO}"
PKGDEP__ARMV6HF="${PKGDEP__RETRO}"
PKGDEP__ARMV7HF="${PKGDEP__RETRO}"
PKGDEP__I486="${PKGDEP__RETRO}"
PKGDEP__LOONGSON2F="${PKGDEP__RETRO}"
PKGDEP__M68K="${PKGDEP__RETRO}"
PKGDEP__POWERPC="${PKGDEP__RETRO}"
PKGDEP__PPC64="${PKGDEP__RETRO}"
BUILDDEP="doxygen util-macros valgrind wayland-protocols bash-completion pyyaml"
# FIXME: Valgrind is not yet available.
BUILDDEP__LOONGARCH64="${BUILDDEP/valgrind/}"
BUILDDEP__RISCV64="${BUILDDEP/valgrind/}"
BUILDDEP__RETRO="util-macros"
PKGSEC=libs

ABTYPE=meson
MESON_AFTER=(
    '-Denable-x11=true'
    '-Denable-docs=true'
    '-Denable-cool-uris=true'
    '-Denable-wayland=true'
    '-Denable-xkbregistry=true'
    '-Denable-bash-completion=true'
)
MESON_AFTER__RETRO=(
    '-Denable-x11=true'
    '-Denable-docs=false'
    '-Denable-cool-uris=false'
    '-Denable-wayland=false'
    '-Denable-xkbregistry=false'
    '-Denable-bash-completion=false'
)
