From 3852924a24b815bd9d3decae71ae461271d9f320 Mon Sep 17 00:00:00 2001
From: =?UTF-8?q?=E5=90=B4=E5=B0=8F=E7=99=BD?= <296015668@qq.com>
Date: Thu, 27 Nov 2025 14:20:18 +0800
Subject: [PATCH 1/3] Add LoongArch64 support with 16KB page size
MIME-Version: 1.0
Content-Type: text/plain; charset=UTF-8
Content-Transfer-Encoding: 8bit

Signed-off-by: 吴小白 <296015668@qq.com>
---
 .../jemalloc/include/jemalloc/internal/jemalloc_internal_defs.h | 2 ++
 1 file changed, 2 insertions(+)

diff --git a/extension/jemalloc/jemalloc/include/jemalloc/internal/jemalloc_internal_defs.h b/extension/jemalloc/jemalloc/include/jemalloc/internal/jemalloc_internal_defs.h
index fca216858a..baf4fef118 100644
--- a/extension/jemalloc/jemalloc/include/jemalloc/internal/jemalloc_internal_defs.h
+++ b/extension/jemalloc/jemalloc/include/jemalloc/internal/jemalloc_internal_defs.h
@@ -259,6 +259,8 @@
 #define LG_PAGE 12 // x86 and x86_64 typically have a 4KB page size
 #elif defined(__powerpc__) || defined(__ppc__)
 #define LG_PAGE 16 // PowerPC architectures often use 64KB page size
+#elif defined(__loongarch__)
+#define LG_PAGE 14 // LoongArch architectures uses a 16KB page size
 #elif defined(__sparc__)
 #define LG_PAGE 13 // SPARC architectures usually have an 8KB page size
 #elif defined(__aarch64__) || defined(__ARM_ARCH)
-- 
