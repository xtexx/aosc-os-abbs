#!/bin/bash

# Note for this post installation maintainer scrpit:
# I originally proposed to let user choose to perform the migration
# automatically. But later I realized that it is better to let the
# user perform the migration themselves, mainly due to these reasons:
#
# 1. The data directories can be anywhere. However the user have to
#    modify the systemd unit file to use their custom data directory.
#    But it is still a problem for the original idea. Even now we only
#    scan the home directory of the postgres user for possible data
#    directories.
# 2. Migration can not be done automatically (mainly by pg_upgrade),
#    if the database uses extensions or external plugins that may alter
#    the underlying data structure. These kinds of migrations must be
#    carefully configured and done.
# 3. To perform the migration, the corresponding release of the old
#    data must be installed, i.e. if one is migrating from PostgreSQL
#    13 to 16, both PostgreSQL 13 and 16 must be installed. We can
#    not ship the packages of later releases that depend on the old
#    release, as this will cause unwanted dependencies.
# 4. Because of 3, if we do ship packages of current release that
#    depends on the previous release we maintained, then the migration
#    dialog will always show up, regardless of whether the user is
#    performing a fresh install, because the data directory of the
#    previous release will always be initialized, thus the script
#    will mistakenly treat it as a database that contains some data.
# 5. If we do not ship packages that depends on the previous release,
#    then there's no point to have the option to migrate automatically,
#    since the old release is not installed.
#
# Now this script only checks for old data directories and prompts the
# user to perform the migration if they wish to. However this script
# can not check if the database actually contains user data, not an
# just-initialized empty database.
#
# ~Cyan

set -eE

OLD_VER=
NEW_VER=

case "$1" in
	install)
		# We can ignore the conffiles, since they actually do
		# nothing. Treating any kind of install as fresh installs.
		exit 0
		;;
	upgrade)
		OLD_VER="$2"
		NEW_VER="$3"
		;;
	*)
		;;
esac

PGMAJOR=@MAJORVER@
OLDMAJOR="${OLD_VER##*:}"
OLDMAJOR="${OLDMAJOR%%-*}"
OLDMAJOR="${OLDMAJOR%%\.*}"
NEWMAJOR="${NEW_VER##*:}"
NEWMAJOR="${NEWMAJOR%%-*}"
NEWMAJOR="${NEWMAJOR%%\.*}"

if [ "$OLDMAJOR" = "$NEWMAJOR" ] ; then
	# Not an major upgrade.
	exit 0
fi

if [ "$NEWMAJOR" -lt "$PGMAJOR" ] ; then
	# No need to inform the user when downgrading.
	exit 0
fi

if [ "$NEWMAJOR" != "$PGMAJOR" ] ; then
	PGMAJOR="$NEWMAJOR"
fi

