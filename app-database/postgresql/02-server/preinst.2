#!/bin/bash

# NOTE: Procedures to update PO template and catalog files:
# 1. Add or modify strings in this file. Be sure to use $"..." quoted strings
#    otherwise the internationalization won't work.
# 2. Update the PO template (Remember to bump the package version):
#    xgettext --copyright-holder="AOSC OS Maintainers <maintainers@aosc.io>" \
#        --package-name=aosc-postgresql-preinst \
#        --package-version=0.1.1 \
#        -L Shell -o po/aosc-postgresql-preinst.pot preinst.2
# 3. Update the catalog files:
#    for f in po/*.po ; do
#        msgmerge -U $f po/aosc-postgresql-preinst.pot
#    done
# 4. Edit the PO catalog files.
# 5. Inspect the diffs using `git diff'.

TMPDIR=$(mktemp -d)
if [ -z "$TMPDIR" ]; then
	echo "Can not create a temporary directory. Translations will be unavailable."
fi
export TEXTDOMAINDIR="$TMPDIR"/locale
export TEXTDOMAIN="aosc-postgresql-preinst"

mkdir "$TMPDIR"/locale
for lang in "${LINGUAS[@]}" ; do
	mkdir -p "$TMPDIR"/locale/$lang/LC_MESSAGES
	key="TRANSLATION_${lang//[!0-9a-zA-Z_]/_}"
	val=${!key}
	echo -n "$val" | base64 -d > "$TMPDIR"/locale/$lang/LC_MESSAGES/$TEXTDOMAIN.mo
done
DIALOG=dialog
INTERACTIVE=1

DIALOG_OPTS=(
	"--keep-tite"
	"--cr-wrap"
	"--scrollbar"
	"--cursor-off-label"
	"--ok-button"
	$"OK"
	"--hline"
	$"Cursor keys to scroll, Enter to acknowledge"
)

DOCURL="https://www.postgresql.org/docs/current/upgrading.html"

# NOTE: Keep these prompts 72 characters wide. DO NOT exceed this
# limit! Surronding quotes does not count. Variables must use their
# expected width, i.e. $PGMAJOR is 2 characters wide.
TITLE_TRANSITION=$"ATTENTION - POSTGRESQL PACKAGE TRANSITION"
PROMPT_TRANSITION=\
$"The \`postgresql' package no longer holds the PostgreSQL server itself,
and now  automatically  depend  on  the  latest  major release, so the
previously installed  PostgreSQL  release  can still serve connections,
and migration to the new major release can be easily done.

We now ship officially supported PostgreSQL releases under the names
like \`postgresql-VERSION', for example \`postgresql-$PGMAJOR'.

Executable names now have version on them, for example \`psql-$PGMAJOR',
\`pg_dump-$PGMAJOR', \`pg_ctl-$PGMAJOR' and so on. Systemd service names also
have version on them, for example, to start PostgreSQL $PGMAJOR:

  sudo systemctl start postgresqld-$PGMAJOR.service

The executables without version on them point to their corresponding
executables of the currently latest release, for example, \`psql' points
to \`psql-$PGMAJOR'. There are no versioned systemd service name.

If you are using the PostgreSQL from AOSC OS to serve data, please note
that the currently installed PostgreSQL $OLDMAJOR must be stopped and removed
in order to continue the transition (your data will not be removed).
After the transition, you must install the old release in order to
either continue using without migration, or migrate to PostgreSQL $PGMAJOR:

  sudo oma install postgresql-$OLDMAJOR

To continue using PostgreSQL $OLDMAJOR, run the following command:

  sudo systemctl start postgresqld-$OLDMAJOR.service

Or, after performing the migration, you can remove the old release and
use the new server:

  systemctl start postgresql-$PGMAJOR
  sudo oma remove postgresql-$OLDMAJOR
"

PROMPT_DOWNTIME=\
$"The old PostgreSQL server which is installed before this transition
is still running.

Due to the package scheme transition, it is required to shut down the
running old server in order to prevent damage of the data and to aid
the migration to the later release.

Please shut down any services that uses the PostgreSQL on your system
now, and press Enter to shut down the PostgreSQL server."

# This message will be displayed once the user upgraded from PostgreSQL 17,
# which is after the transition.
NOTE_ON_NEW_RELEASE=\
$"The new major release of PostgreSQL ($PGMAJOR) is installed on your
system. PostgreSQL $OLDMAJOR will be kept installed on your system until
the next major release. You can run \`oma hold postgresql-$OLDMAJOR' to
prevent it from being automatically removed.
"

TITLE_REMOVAL=$"Pending Removal of Older Releases of PostgreSQL"
NOTE_ON_REMOVAL=\
$"PostgreSQL releases from 13 to 16 will be removed from the AOSC OS
package repository during our next PostgreSQL updating survey.

If you are still running these PostgreSQL releases, please migrate to
the latest PostgreSQL release before May 2026.
"

NOTE_ON_MIGRATING=\
$"To migrate from a previous PostgreSQL release, you can use either
\`pg_upgrade' or \`pg_dump'. Refer the following link to learn more
about migration:

  $DOCURL
"

ERR_NOT_INTERACTIVE=\
$"Due to the transition, this upgrade must be manually performed.
Rejecting upgrade."

ERR_INTERRUPTED=$"The upgrade is interrupted."
PROMPT_TRYAGAIN=\
$"Please run 'oma fix-broken -n' to try again."

info() {
(
	IFS=$'\n' lines=($@)
	echo -e "-- ${lines[0]}"
	unset "lines[0]"
	for line in "${lines[@]}" ; do
		echo "   $line"
	done
) >&2
}

err() {
(
	IFS=$'\n' lines=($@)
	echo -e "!! ${lines[0]}"
	unset "lines[0]"
	for line in "${lines[@]}" ; do
		echo "   $line"
	done
) >&2
}

trap "err \"\$ERR_INTERRUPTED\" ; err \"\$PROMPT_TRYAGAIN\" ; rm -r $TMPDIR ; exit 1" SIGTERM SIGINT

inform_transition() {
	if (( $INTERACTIVE )) ; then
		"$DIALOG" \
			"${DIALOG_OPTS[@]}" \
			--title "$TITLE_TRANSITION" \
			--msgbox \
			"$PROMPT_TRANSITION" \
			20 76
	fi
	info "$TITLE_TRANSITION"
	info "$PROMPT_TRANSITION"
	echo ""
}

inform_removal() {
	if (( $INTERACTIVE )) ; then
		"$DIALOG" \
			"${DIALOG_OPTS[@]}" \
			--title "$TITLE_REMOVAL" \
			--msgbox \
			"$NOTE_ON_REMOVAL" \
			20 76
	fi
	info "$TITLE_REMOVAL"
	info "$NOTE_ON_REMOVAL"
	echo ""
}

inform_shutdown() {
	if (( $INTERACTIVE )) ; then
		"$DIALOG" \
			"${DIALOG_OPTS[@]}" \
			--title "$TITLE_TRANSITION" \
			--msgbox \
			"$PROMPT_DOWNTIME" \
			20 76
	fi
	info "$PROMPT_DOWNTIME"
	echo ""
}

inform_new_major_release() {
	if (( $INTERACTIVE )) ; then
		"$DIALOG" \
			"${DIALOG_OPTS[@]}" \
			--title "$TITLE_TRANSITION" \
			--msgbox \
			"$NOTE_ON_NEW_RELEASE\n$NOTE_ON_MIGRATING" \
			20 76
	fi
	info "$NOTE_ON_NEW_RELEASE"
	info "$NOTE_ON_MIGRATING"
	echo ""
}

if [ "x$DEBIAN_FRONTEND" = "xnoninteractive" ]; then
	INTERACTIVE=0
elif [ -z "$TERM" ]; then
	INTERACTIVE=0
elif ! [ -t 0 ] || \
	! [ -t 1 ] || \
	! [ -t 2 ] ; then
	INTERACTIVE=0
fi

if [ "$OLDMAJOR" = "13" ] ; then
	# Inform the user about the transition.
	inform_transition
	inform_removal
	if systemctl --quiet is-active postgresqld.service ; then
		if !(( $INTERACTIVE )) ; then
			err "$ERR_NOT_INTERACTIVE"
			err "$PROMPT_TRYAGAIN"
			exit 1
		fi
		if inform_shutdown ; then
			systemctl stop postgresqld.service
		else
			err $"The upgrade is interrupted."
			err "$PROMOT_TRY_AGAIN"
			exit 1
		fi
	fi
else
	# Inform the user about the new release.
	# No more data directories scan and other fusses.
	if inform_new_major_release && inform_removal ; then
		exit 0
	else
		err $"The upgrade is interrupted."
		err "$PROMOT_TRY_AGAIN"
		exit 1
	fi
fi

rm -r "$TMPDIR"

exit 0
