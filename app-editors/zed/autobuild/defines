PKGNAME="zed"
PKGDES="A general-purpose, multiplayer code editor"
PKGSEC=devel
PKGDEP="alsa-lib gcc-runtime glibc libxcb libxkbcommon x11-lib zlib"
BUILDDEP="rustc llvm mold"

# FIXME: Limited by wasmtime support.
#
# See https://wasmtime.dev/install.sh for architecture support.
#
# riscv64: zed Livekit only support amd64 and arm64
FAIL_ARCH="!(amd64|arm64)"

USECLANG=1

CARGO_AFTER=("--package" "zed" "--package" "cli" "-p")

# FIXME: lto fail with rustc>=1.90
# mold: error: undefined symbol: aws_lc_0_29_0_AES_set_decrypt_key
# = note: ld.lld: error: undefined symbol: aws_lc_0_29_0_EVP_parse_private_key
NOLTO=1
