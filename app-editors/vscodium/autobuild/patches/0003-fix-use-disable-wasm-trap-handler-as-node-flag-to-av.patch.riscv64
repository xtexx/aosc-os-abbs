From 70a9bc1279c5adfec0f9a97e53a5148250baffba Mon Sep 17 00:00:00 2001
From: darkyzhou <me@zqy.io>
Date: Sat, 26 Apr 2025 20:35:59 +0800
Subject: [PATCH 3/4] fix: use --disable-wasm-trap-handler as node flag to
 avoid a compilation error on riscv

Compilation error: RangeError: WebAssembly.Instance(): Out of memory: Cannot allocate Wasm memory for new instance
Related PR from Node: https://github.com/nodejs/node/pull/52766
---
 patches/riscv-disable-wasm-trap-handler.patch | 13 +++++++++++++
 1 file changed, 13 insertions(+)
 create mode 100644 patches/riscv-disable-wasm-trap-handler.patch

diff --git a/patches/riscv-disable-wasm-trap-handler.patch b/patches/riscv-disable-wasm-trap-handler.patch
new file mode 100644
index 0000000..e9dcfca
--- /dev/null
+++ b/patches/riscv-disable-wasm-trap-handler.patch
@@ -0,0 +1,13 @@
+diff --git a/package.json b/package.json
+index 39b8e38..41485c2 100644
+--- a/package.json
++++ b/package.json
+@@ -34,7 +34,7 @@
+     "watch-extensionsd": "deemon npm run watch-extensions",
+     "kill-watch-extensionsd": "deemon --kill npm run watch-extensions",
+     "precommit": "node --experimental-strip-types build/hygiene.ts",
+-    "gulp": "node --max-old-space-size=8192 ./node_modules/gulp/bin/gulp.js",
++    "gulp": "node --max-old-space-size=8192 --disable-wasm-trap-handler ./node_modules/gulp/bin/gulp.js",
+     "electron": "node build/lib/electron.ts",
+     "7z": "7z",
+     "update-grammars": "node build/npm/update-all-grammars.ts",
-- 
2.52.0

