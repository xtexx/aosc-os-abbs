PKGNAME=virt-install
PKGSEC=admin
PKGDEP="cpio libisoburn libosinfo libvirt-python pygobject-3 requests"
BUILDDEP="docutils dbus-python graphite gtk-vnc gtk-4 gtksourceview-4 \
          intltool ipy librsvg libspice-gtk libvirt-glib \
          libxml2 netcat vte yajl gtk-update-icon-cache"
PKGDES="Command line tools for creating new KVM, Xen, or Linux container guests"

ABTYPE=meson
MESON_AFTER=(
    "-Dupdate-icon-cache=true"
    "-Dcompile-schemas=true"
    "-Ddefault-graphics=spice"
    "-Ddefault-hvs=qemu,xen,lxc,bhyve,vz"
    "-Dtests=disabled"
)

PKGBREAK="virt-manager<=3.2.0"
PKGREP="virt-manager<=3.2.0"

ABHOST=noarch
