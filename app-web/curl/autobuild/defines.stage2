PKGNAME=curl
PKGSEC=utils
PKGDES="URL retrieval utility and library"
PKGDEP="ca-certs nghttp2 openssl"

ABTYPE=self
AUTOTOOLS_AFTER=(
    "--mandir=/usr/share/man"
    "--disable-ldap"
    "--disable-ldaps"
    "--enable-ipv6"
    "--enable-manual"
    "--enable-threaded-resolver"
    "--with-ngtcp2"
    "--without-gssapi"
    "--without-libidn2"
    "--without-libssh2"
    "--without-brotli"
    "--without-libpsl"
    "--with-ca-bundle=/etc/ssl/ca-bundle.crt"
)
