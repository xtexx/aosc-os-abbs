PKGNAME=curl
PKGSEC=utils
PKGDEP="ca-certs openssl krb5 libidn2 libssh2 nghttp2 gnutls zlib \
        brotli libpsl zstd e2fsprogs nghttp3 ngtcp2"
BUILDDEP="patchelf"
PKGDES="URL retrieval utility and library"
PKGRECOM="ca-certs"

# HTTP/2, HTTP/3 and QUIC support.
PKGDEP__RETRO="ca-certs openssl nghttp2 nghttp3 ngtcp2"

ABTYPE=self
AUTOTOOLS_AFTER=(
    "--mandir=/usr/share/man"
    "--disable-ldap"
    "--disable-ldaps"
    "--enable-ipv6"
    "--enable-manual"
    "--enable-threaded-resolver"
    "--with-gssapi"
    "--with-libidn2"
    "--with-libssh2"
    "--with-brotli"
    "--with-libpsl"
    "--with-ngtcp2"
    "--with-nghttp3"
    "--with-ca-bundle=/etc/ssl/ca-bundle.crt"
)
AUTOTOOLS_AFTER__RETRO=(
    "--mandir=/usr/share/man"
    "--disable-ldap"
    "--disable-ldaps"
    "--enable-ipv6"
    "--enable-manual"
    "--enable-threaded-resolver"
    "--with-ngtcp2"
    "--with-nghttp3"
    "--without-gssapi"
    "--without-libidn2"
    "--without-libssh2"
    "--without-brotli"
    "--without-libpsl"
    "--with-ca-bundle=/etc/ssl/ca-bundle.crt"
)

# Note: Extra Provides for Spiral (Debian compatibility).
PKGPROV="libcurl3-gnutls_spiral libcurl4-gnutls-dev_spiral \
         libcurl4-openssl-dev_spiral libcurl3_spiral"

PKGESS=1
