abinfo "Installing dependencies..."
make deps

abinfo "Building static assets..."
make assets

abinfo "Building anubis..."
make prebaked-build

abinfo "Installing Anubis binaries..."
install -Dvm755 "$SRCDIR"/var/anubis "$PKGDIR"/usr/bin/anubis
install -Dvm755 "$SRCDIR"/var/robots2policy "$PKGDIR"/usr/bin/robots2policy

abinfo "Installing systemd service..."
install -Dvm644 "$SRCDIR"/run/anubis@.service "$PKGDIR"/usr/lib/systemd/system/anubis@.service
install -Dvm644 "$SRCDIR"/run/default.env "$PKGDIR"/etc/anubis/default.env

abinfo "Installing documentation..."
docdir="$PKGDIR/usr/share/doc/$PKGNAME"
install -Dvm644 "$SRCDIR"/README.md "$docdir"/README.md
cp -a "$SRCDIR"/docs/docs "$SRCDIR"/data "$docdir"/
find "$docdir" \( -name _category_.json -o -name '*.go' \) -delete
