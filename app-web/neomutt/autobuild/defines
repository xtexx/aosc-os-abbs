PKGNAME=neomutt
PKGSEC=net
PKGDEP="gnupg libxslt mime-types notmuch python-3 libidn lua-5.4"
BUILDDEP="docbook-xsl"
PKGDES="Command-line mail reader"

# FIXME:
#
# Assembler messages:
# Fatal error: can't create cli/objects.o: No such file or directory
ABSHADOW=0

ABTYPE=autosetup
AUTOSETUP_AFTER=(
    '--prefix=/usr'
    '--enable-gpgme'
    '--enable-lua'
    '--enable-notmuch'
    '--with-gss=/usr'
    '--with-ssl=/usr'
    '--with-sasl=/usr'
    '--with-idn=/usr'
    '--with-gdbm=/usr'
)
