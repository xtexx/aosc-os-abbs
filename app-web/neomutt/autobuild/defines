PKGNAME=neomutt
PKGSEC=net
PKGDEP="gnupg libxslt mime-types notmuch python-3 libidn lua-5.4"
BUILDDEP="docbook-xsl"
PKGDES="Command-line mail reader"

# Note: Multi-level Autotools source tree.
AUTOTOOLS_STRICT=0
AUTOTOOLS_AFTER=(
    '--prefix=/usr'
    '--enable-gpgme'
    '--enable-lua'
    '--enable-notmuch'
    '--with-gss=/usr'
    '--with-ssl=/usr'
    '--with-sasl=/usr'
    '--with-idn=/usr'
    '--with-gdbm=/usr'
)
