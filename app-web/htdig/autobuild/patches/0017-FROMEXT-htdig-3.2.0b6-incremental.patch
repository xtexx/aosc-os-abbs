From 058b4c8492725838b504933cf0bb19a6896603a7 Mon Sep 17 00:00:00 2001
From: Ilikara <3435193369@qq.com>
Date: Mon, 29 Sep 2025 17:15:09 +0800
Subject: [PATCH 17/17] FROMEXT: htdig-3.2.0b6-incremental

FIXME: IDK where the patch come from, it's here since 2016

Signed-off-by: Ilikara <3435193369@qq.com>
---
 installdir/rundig      | 10 +++++++++-
 installdir/rundig.1.in |  3 +++
 2 files changed, 12 insertions(+), 1 deletion(-)

diff --git a/installdir/rundig b/installdir/rundig
index 6705ba5e..ac7f6c92 100755
--- a/installdir/rundig
+++ b/installdir/rundig
@@ -14,6 +14,7 @@ conffile=/etc/htdig/htdig.conf
 
 # To help debug problems, try running rundig -vvv
 # This will add lots of debugging output to all of the programs
++incremental=0
 stats= opts= alt= nohtnotify=
 while [ "$#" -gt 0 ]
 do
@@ -25,6 +26,7 @@ do
          conffile="$1"
 	 opts="$opts -c $conffile"
 	;;
+    +i) incremental=1;;
     *)   opts="$opts $1" ;;	# e.g. -v
     esac
     shift
@@ -54,7 +56,13 @@ fi
 TMPDIR=$DBDIR
 export TMPDIR
 
-$BINDIR/htdig -i $opts $stats $alt
+if [ $incremental -ne 0 ]
+then
+    $BINDIR/htdig $opts $stats $alt
+else
+    $BINDIR/htdig -i $opts $stats $alt
+fi
+
 $BINDIR/htpurge $opts $alt
 case "$alt" in
 -a)
diff --git a/installdir/rundig.1.in b/installdir/rundig.1.in
index 58a5628d..0b2cab3f 100644
--- a/installdir/rundig.1.in
+++ b/installdir/rundig.1.in
@@ -23,6 +23,9 @@ Print statistics about the dig after completion
 .TP
 .B \-c configfile
 Use alternate config file.
+.TP
+.B \+i
+Use incremental digging instead non-incremental
 .SH "SEE ALSO"
 Please refer to the HTML pages (in the htdig-doc package)
 .B /usr/share/doc/htdig-doc/html/index.html
-- 
2.51.0

