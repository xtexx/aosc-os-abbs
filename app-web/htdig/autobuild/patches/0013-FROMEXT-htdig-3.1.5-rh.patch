From 41cf21ff80e8bf73c696511cc4b7bc1c56b91b8d Mon Sep 17 00:00:00 2001
From: Ilikara <3435193369@qq.com>
Date: Mon, 29 Sep 2025 17:07:13 +0800
Subject: [PATCH 13/17] FROMEXT: htdig-3.1.5-rh

FIXME: IDK where the patch come from, it's here since 2016

Signed-off-by: Ilikara <3435193369@qq.com>
---
 installdir/htdig.conf | 16 ++++++++++++++--
 installdir/rundig     | 15 ++++++++++++++-
 2 files changed, 28 insertions(+), 3 deletions(-)

diff --git a/installdir/htdig.conf b/installdir/htdig.conf
index 7b7d8ffc..5090108a 100755
--- a/installdir/htdig.conf
+++ b/installdir/htdig.conf
@@ -17,6 +17,18 @@
 #
 database_dir:		@DATABASE_DIR@
 
+#
+# Define common_dir, which is used in several of the examples.
+#
+common_dir:     /var/www/html/htdig
+
+#
+# Disable the translation of the ISO Latin 1 SGML entities from the
+# documents into upper end 8-bit characters in the database,
+# and then back to the Latin 1 SGML entities in htsearch results.
+#
+translate_latin1:	false
+
 #
 # This specifies the URL where the robot (htdig) will start.  You can specify
 # multiple URLs here.  Just separate them by some whitespace.
@@ -25,7 +37,7 @@ database_dir:		@DATABASE_DIR@
 # You could also index all the URLs in a file like so:
 # start_url:	       `${common_dir}/start.url`
 #
-start_url:		http://www.htdig.org/
+start_url:		http://localhost
 
 #
 # This attribute limits the scope of the indexing process.  The default is to
@@ -76,7 +88,7 @@ bad_extensions:		.wav .gz .z .sit .au .zip .tar .hqx .exe .com .gif \
 # The string htdig will send in every request to identify the robot.  Change
 # this to your email address.
 #
-maintainer:		unconfigured@htdig.searchengine.maintainer
+maintainer:		root@localhost
 
 #
 # The excerpts that are displayed in long results rely on stored information
diff --git a/installdir/rundig b/installdir/rundig
index 7baf6fd6..7ab27b6a 100755
--- a/installdir/rundig
+++ b/installdir/rundig
@@ -84,11 +84,24 @@ fi
 if [ "`ls -t $COMMONDIR/english.0 $COMMONDIR/word2root.db 2>/dev/null | sed 1q`" = \
 	"$COMMONDIR/english.0" ]
 then
-    $BINDIR/htfuzzy $opts endings
+      cat <<EOF
+ Warning:
+       The following is a lengthly process, but it is run only
+       the first time you start ht://Dig. Initializing database...
+EOF
+     $BINDIR/htfuzzy $opts endings
 fi
 
 if [ "`ls -t $COMMONDIR/synonyms $COMMONDIR/synonyms.db 2>/dev/null | sed 1q`" = \
 	"$COMMONDIR/synonyms" ]
 then
+     cat <<EOF
+ Warning:
+       The following is a lengthly process, but it is run only
+       the first time you start ht://Dig. Initializing database...
+EOF
     $BINDIR/htfuzzy $opts synonyms
 fi
+
+@BIN_DIR@/htfuzzy $verbose metaphone
+@BIN_DIR@/htfuzzy $verbose soundex
-- 
