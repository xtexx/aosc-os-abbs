From 7e2c19062545e805c3bc10967fefe803f77aa87b Mon Sep 17 00:00:00 2001
From: Mingcong Bai <jeffbai@aosc.io>
Date: Tue, 8 Apr 2025 14:54:04 +0800
Subject: [PATCH 07/14] AOSCOS: blink: fix build with gperf 3.2

gperf >= 3.2 fixes an issue where explicit fallthrough statements
(`[[fallthrough]];') were not generated even if -std=c++17 was specified.

The original script works around this issue by substituting /*FALLGHROUGH*/
statements manually - with 3.2, this caused the statement to be transcribed
twice, confusing the compiler.

Remove the extra substitution to fix build.

Link: https://savannah.gnu.org/bugs/index.php?53029
Suggested-by: Jiajie Chen <c@jia.je>
Signed-off-by: Mingcong Bai <jeffbai@aosc.io>
---
 third_party/blink/renderer/build/scripts/gperf.py | 5 -----
 1 file changed, 5 deletions(-)

diff --git a/third_party/blink/renderer/build/scripts/gperf.py b/third_party/blink/renderer/build/scripts/gperf.py
index 42630d37c5..c5d284371a 100644
--- a/third_party/blink/renderer/build/scripts/gperf.py
+++ b/third_party/blink/renderer/build/scripts/gperf.py
@@ -34,11 +34,6 @@ def generate_gperf(gperf_path, gperf_input, gperf_args):
         # it from gperf's output.
         # https://savannah.gnu.org/bugs/index.php?53028
         gperf_output = re.sub(r'\bregister ', '', gperf_output)
-        # -Wimplicit-fallthrough needs an explicit fallthrough statement,
-        # so replace gperf's /*FALLTHROUGH*/ comment with the statement.
-        # https://savannah.gnu.org/bugs/index.php?53029
-        gperf_output = gperf_output.replace('/*FALLTHROUGH*/',
-                                            '  [[fallthrough]];')
         # -Wpointer-to-int-cast warns about casting pointers to smaller ints
         # Replace {(int)(long)&(foo), bar} with
         # {static_cast<int>(reinterpret_cast<uintptr_t>(&(foo)), bar}
-- 
