 13 files changed, 72 insertions(+), 49 deletions(-)

diff --git a/base/system/sys_info.cc b/base/system/sys_info.cc
index 5782b000d3..0551f89030 100644
--- a/base/system/sys_info.cc
+++ b/base/system/sys_info.cc
@@ -254,6 +254,8 @@ std::string SysInfo::ProcessCPUArchitecture() {
   return "ARM_64";
 #elif defined(ARCH_CPU_RISCV64)
   return "RISCV_64";
+#elif defined(ARCH_CPU_LOONGARCH64)
+  return "LOONGARCH_64";
 #else
   return std::string();
 #endif
diff --git a/build/config/loongarch64.gni b/build/config/loongarch64.gni
index 9a95ec9151..a9dc9d28db 100644
--- a/build/config/loongarch64.gni
+++ b/build/config/loongarch64.gni
@@ -7,7 +7,7 @@ import("//build/config/v8_target_cpu.gni")
 if (current_cpu == "loong64") {
   declare_args() {
     # LOONGARCH64 SIMD Arch compilation flag.
-    loongarch64_use_lsx = false
+    loongarch64_use_lsx = true
     loongarch64_use_lasx = false
   }
 }
diff --git a/build/rust/gni_impl/rust_target.gni b/build/rust/gni_impl/rust_target.gni
index 947dfaf9d6..eed8b46116 100644
--- a/build/rust/gni_impl/rust_target.gni
+++ b/build/rust/gni_impl/rust_target.gni
@@ -445,6 +445,9 @@ template("rust_target") {
       if (_rustc_metadata != "") {
         rustflags += [ "-Cmetadata=${_rustc_metadata}" ]
       }
+      if (current_cpu == "loong64") {
+        rustflags += [ "-Ccode-model=medium" ]
+      }
       rustenv = _rustenv
 
       if (_generate_crate_root) {
diff --git a/chrome/browser/extensions/api/runtime/chrome_runtime_api_delegate.cc b/chrome/browser/extensions/api/runtime/chrome_runtime_api_delegate.cc
index 8fdbfb6170..a37158a7cc 100644
--- a/chrome/browser/extensions/api/runtime/chrome_runtime_api_delegate.cc
+++ b/chrome/browser/extensions/api/runtime/chrome_runtime_api_delegate.cc
@@ -342,6 +342,8 @@ extensions::api::runtime::PlatformNaclArch GetPlatformInfoNaClArch() {
   return extensions::api::runtime::PlatformNaclArch::kMips;
 #elif defined(ARCH_CPU_MIPS64EL)
   return extensions::api::runtime::PlatformNaclArch::kMips64;
+#elif defined(ARCH_CPU_LOONGARCH64)
+  return extensions::api::runtime::PlatformNaclArch::kLoongarch64;
 #else
   // NOTE: Other architectures did not support extensions at the time
   // of NaCl removal.
@@ -383,6 +385,8 @@ bool ChromeRuntimeAPIDelegate::GetPlatformInfo(PlatformInfo* info) {
     info->arch = extensions::api::runtime::PlatformArch::kMips64;
   } else if (arch == "riscv64") {
     info->arch = extensions::api::runtime::PlatformArch::kRiscv64;
+  } else if (arch == "loongarch64") {
+    info->arch = extensions::api::runtime::PlatformArch::kLoongarch64;
   } else {
     NOTREACHED();
   }
diff --git a/components/embedder_support/user_agent_utils.cc b/components/embedder_support/user_agent_utils.cc
index 8c44d2265b..fe7883e165 100644
--- a/components/embedder_support/user_agent_utils.cc
+++ b/components/embedder_support/user_agent_utils.cc
@@ -805,6 +805,8 @@ std::string GetCpuArchitecture() {
               cpu_info.substr(2, 2) == "86") ||
              base::StartsWith(cpu_info, "x86")) {
     return "x86";
+  } else if (base::StartsWith(cpu_info, "loong")) {
+    return "loongarch";
   }
 #elif BUILDFLAG(IS_FUCHSIA)
   std::string cpu_arch = base::SysInfo::ProcessCPUArchitecture();
diff --git a/components/metrics/debug/metrics_internals_utils.cc b/components/metrics/debug/metrics_internals_utils.cc
index b63ffa6dfa..f2dc230772 100644
--- a/components/metrics/debug/metrics_internals_utils.cc
+++ b/components/metrics/debug/metrics_internals_utils.cc
@@ -73,6 +73,8 @@ std::string CpuArchitectureToString(
       return "arm32";
     case variations::Study::TRANSLATED_X86_64:
       return "translated_x86_64";
+    case variations::Study::LOONGARCH64:
+      return "loongarch64";
   }
   NOTREACHED();
 }
diff --git a/components/variations/proto/study.proto b/components/variations/proto/study.proto
index 909de4e18e..23a8515fc1 100644
--- a/components/variations/proto/study.proto
+++ b/components/variations/proto/study.proto
@@ -293,6 +293,8 @@ message Study {
     // A Mac-only value, indicating an x86-64 binary running on an arm64 host
     // via "Rosetta 2" binary translation.
     TRANSLATED_X86_64 = 4;
+
+    LOONGARCH64 = 5;
   }
 
   // Enum to pass as optional bool.
diff --git a/components/variations/service/variations_field_trial_creator.cc b/components/variations/service/variations_field_trial_creator.cc
index 395171d59a..c2eef69c48 100644
--- a/components/variations/service/variations_field_trial_creator.cc
+++ b/components/variations/service/variations_field_trial_creator.cc
@@ -104,6 +104,9 @@ Study::CpuArchitecture GetCurrentCpuArchitecture() {
   if (process_arch == "x86") {
     return Study::X86_32;
   }
+  if (process_arch == "LOONGARCH_64") {
+    return Study::LOONGARCH64;
+  }
   if (process_arch == "x86_64") {
     std::string os_arch = base::SysInfo::OperatingSystemArchitecture();
     if (base::StartsWith(os_arch, "arm",
diff --git a/extensions/common/api/runtime.json b/extensions/common/api/runtime.json
