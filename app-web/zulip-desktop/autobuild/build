abinfo "Installing zulip-desktop dependencies..."
pnpm install

abinfo "Building zulip-desktop..."
if ab_match_arch arm64; then
    pnpm run dist --arm64
elif ab_match_arch amd64; then
    pnpm run dist
fi

abinfo "Installing zulip-desktop..."
install -dvm755 "$PKGDIR"/usr/lib/zulip-desktop
cp -rv "$SRCDIR"/dist/*-unpacked/* \
    "$PKGDIR"/usr/lib/zulip-desktop/

abinfo "Creating symbolic link..."
install -dvm755 "$PKGDIR"/usr/bin
ln -sv ../lib/zulip-desktop/zulip "$PKGDIR"/usr/bin/zulip

abinfo "Installing applications icons..."
install -Dvm644 "$SRCDIR"/build/zulip.png \
    "$PKGDIR"/usr/share/pixmaps/zulip.png
