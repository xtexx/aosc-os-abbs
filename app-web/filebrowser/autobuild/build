abinfo "Building frontend ..."
cd "$SRCDIR"/frontend
if ab_match_arch loongarch64; then
    abinfo "Overriding NPM registry for loongarch64 ..."
    pnpm set registry https://registry.loongnix.cn:5873
fi
pnpm install
pnpm run build

abinfo "Building backend ..."
cd "$SRCDIR"
go build -ldflags="-s -w -X \"github.com/filebrowser/filebrowser/v2/version.Version=$PKGVER\" -X \"github.com/filebrowser/filebrowser/v2/version.CommitSHA=$(git log -n 1 --format=%h)\""  -o filebrowser .

abinfo "Installing ..."
install -Dvm755 "$SRCDIR"/filebrowser "$PKGDIR"/usr/bin/filebrowser
