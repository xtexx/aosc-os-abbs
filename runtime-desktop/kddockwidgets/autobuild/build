for qt6on in ON OFF; do
    export CMAKE_AFTER=(
        "-DKDDockWidgets_QT6=${qt6on}"
        '-DKDDockWidgets_STATIC=OFF'
        '-DKDDockWidgets_TESTS=ON'
        '-DKDDockWidgets_EXAMPLES=OFF'
        '-DKDDockWidgets_DOCS=OFF'
        '-DKDDockWidgets_PYTHON_BINDINGS=OFF'
    )

    # Note: Following cmakeninja ABTYPE, abinfo included.
    build_cmakeninja_configure
    build_cmakeninja_build
    build_cmakeninja_install

    abinfo "Cleaning up after build ..."
    rm -rv "$BLDDIR"
done
