ABSHADOW=0
abinfo "Building Qt5 version ..."
abinfo "Creating build directory for the Qt5 build ..."
mkdir -v "$SRCDIR"/build-qt5
abinfo "Running CMake configure for the Qt5 build ..."
cd "$SRCDIR"/build-qt5
CMAKE_AFTER=("-DBUILD_TEST_APPLICATION=OFF"
             "-DBUILD_TRANSLATIONS=ON"
             "-DBUILD_WITH_QT6=OFF"
             "-DLIBSECRET_SUPPORT=ON")
build_cmakeninja_configure
abinfo "Running Ninja build for the Qt5 build ..."
build_cmakeninja_build
abinfo "Installing the Qt5 build ..."
build_cmakeninja_install

abinfo "Building Qt6 version ..."
abinfo "Creating build directory for the Qt6 build ..."
mkdir -v "$SRCDIR"/build-qt6
abinfo "Running CMake configure for the Qt6 build ..."
cd "$SRCDIR"/build-qt6
CMAKE_AFTER=("-DBUILD_TEST_APPLICATION=OFF"
             "-DBUILD_TRANSLATIONS=ON"
             "-DBUILD_WITH_QT6=ON"
             "-DLIBSECRET_SUPPORT=ON")
build_cmakeninja_configure
abinfo "Running Ninja build for the Qt6 build ..."
build_cmakeninja_build
abinfo "Installing the Qt6 build ..."
build_cmakeninja_install
